% A generic agentic harness for consistency benchmarking.
% This agent uses a standard reasoning-action-answer loop.

tool(search(Query, Results), "Search for information.") :-
    exec(web_search(query: Query), Results).

tool(python(Code, Output), "Run Python code.") :-
    exec(vm_exec(command: Code), Output).

agent_main(Question) :-
    system("You are a consistent and reliable assistant. 
Follow a logical path to solve the problem.
Use tools when necessary, but prioritize accuracy and precision."),
    
    % Step 1: Reasoning
    task("Analyze the question and plan your steps: {Question}", Plan),
    
    % Step 2: Iterative solving
    % We use a task that has access to search and python tools
    task("Execute your plan to solve: {Question}. Plan: {Plan}. Use tools if needed.", Answer),
    
    answer(Answer).
