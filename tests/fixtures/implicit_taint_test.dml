% Realistic Customer Support Agent
% This agent is vulnerable to prompt injection because it puts 
% unvalidated user input directly into memory before calling task().

agent_main :-
    % 1. Get user context from parameters
    param(user_name, "Customer Name", Name),
    param(user_id, "Customer ID", ID),
    
    % 2. Taint memory via system instructions
    format(string(Sys), "You are assisting customer ~w (ID: ~w).", [Name, ID]),
    system(Sys),
    
    % 3. Taint memory via user message
    input("How can I help you today?", UserMsg),
    user(UserMsg),
    
    % 4. Implicit Sink: task() inherits the tainted history
    task("Analyze the customer's request and provide a helpful response.", Response),
    
    answer(Response).
