% Multi-hop taint tracking test

tool(process_data(Input, Result), "Process and save data") :-
    % Input is tainted (tool argument)
    
    % Hop 1: format
    format(string(Step1), "Intermediate: ~w", [Input]),
    
    % Hop 2: assignment
    Step2 = Step1,
    
    % Hop 3: string_concat
    string_concat("PRE_", Step2, Step3),
    
    % Hop 4: another assignment
    FinalPath = Step3,
    
    % Sink: exec
    exec(read_file(path: FinalPath), Result).

agent_main(UserInput) :-
    % UserInput is tainted (agent argument)
    
    % Hop
    ProcessedInput = UserInput,
    
    % Sink
    exec(vm_exec(command: ProcessedInput), _),

    param(api_key, _, APIKey), % APIKey tainted if we consider params sources
    
    % Hop 1
    AuthHeader = APIKey,
    
    % Sink
    exec(fetch(url: "https://api.example.com", headers: [AuthHeader]), _).
