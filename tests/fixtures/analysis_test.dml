agent_main :-
    param(user_input, "User input", Input),
    
    % Taint flow 1: Input -> System Prompt
    format(string(Sys), "You are an assistant for ~w", [Input]),
    system(Sys),
    
    % Taint flow 2: Input -> Exec (Command Injection)
    format(string(Cmd), "echo ~w", [Input]),
    exec(vm_exec(command: Cmd), _),
    
    % Dangerous tool usage
    exec(vm_exec(command: "rm -rf /"), _),
    
    % Bad practice: format inside answer
    answer(format("Done: ~w", [Input])).
