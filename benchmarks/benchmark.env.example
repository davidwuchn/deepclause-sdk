# Copy this file to benchmarks/benchmark.env, fill in the values you need,
# then run the benchmark wrapper with:
#   benchmarks/swebench.sh run --env-file benchmarks/benchmark.env --config <config>

# Standard provider env vars. The benchmark runner forwards these into worker containers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# Optional proxy env vars. These are also forwarded into worker containers.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Custom provider example for model ids like custom:aliyun:qwen3.6-27b.
# DeepClause resolves custom providers from:
#   LLM_PROVIDER_<PROVIDER_NAME>_API_KEY
#   LLM_PROVIDER_<PROVIDER_NAME>_BASE_URL
# so for custom:aliyun:... use:
LLM_PROVIDER_ALIYUN_API_KEY=
LLM_PROVIDER_ALIYUN_BASE_URL=