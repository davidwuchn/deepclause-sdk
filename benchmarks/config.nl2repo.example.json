{
  "dataset": {
    "testDataDir": "benchmarks/nl2repo/test-data",
    "tasks": ["emoji"],
    "limit": 1,
    "offset": 0
  },
  "modes": ["plan-execute"],
  "deepclause": {
    "version": "0.0.78",
    "models": {
      "gateway": "custom:aliyun:qwen3.6-35b-a3b",
      "run": "custom:aliyun:qwen3.6-35b-a3b",
      "compile": "custom:aliyun:qwen3.6-35b-a3b"
    },
    "temperatures": {
      "gateway": 0.7,
      "run": 0.7,
      "compile": 0.4
    },
    "shell": { "wrapper": "clean-room", "strictIsolation": false },
    "agentvm": { "network": false }
  },
  "execution": {
    "maxWorkers": 1,
    "agentTimeoutSeconds": 7200,
    "setupTimeoutSeconds": 1800,
    "maxIterations": 100,
    "verbose": false
  },
  "docker": {
    "platform": "linux/amd64",
    "workerImage": "deepclause-nl2repo-worker:latest",
    "rebuildImages": false,
    "skipImageBuild": false
  },
  "evaluation": {
    "pullBaseImages": true,
    "removePackageFiles": true,
    "removeTestFiles": true
  },
  "artifacts": { "outputRoot": "benchmarks/runs" }
}
