tool(run_bash(Command, Output), "Run a shell command in the workspace. Use cat to read files, use heredocs to write files: cat > path/to/file.py << 'ENDOFFILE'\ncode here\nENDOFFILE\nUse mkdir -p before writing to new directories. Use ls to list directories.") :-
    exec(bash(command: Command), Output).

agent_main :-
    exec(bash(command: 'cat start.md'), SpecResult),
    get_dict(stdout, SpecResult, SpecContent),
    format(string(SysPrompt), "You are an expert Python developer. You MUST implement a complete library from the specification below.\n\nCRITICAL RULES:\n1. Start coding IMMEDIATELY. The full specification is below — do NOT re-read start.md.\n2. Use run_bash for EVERYTHING: write files with heredocs, run commands.\n3. To write a file: run_bash with: mkdir -p dirname && cat > filepath << 'ENDOFFILE'\n... file content ...\nENDOFFILE\n4. NEVER call write_file_content or read_file_content — they do not exist.\n5. After writing each file, verify it with cat or python -c 'import module'.\n6. Work autonomously. No user interaction. No web_search, news_search, url_fetch, or create_skill.\n7. If a task seems unclear, make reasonable assumptions and implement anyway.\n8. DO NOT spend more than 2 iterations reading. By iteration 3 you MUST be writing code.\n9. At the end of each task, briefly summarize what you did and what is left to do. This summary carries forward to the next task.\n\n--- BEGIN SPECIFICATION ---\n~w\n--- END SPECIFICATION ---", [SpecContent]),
    system(SysPrompt),
    task("Set up the project directory structure with all necessary folders including asteval/, doc/, doc/_static/, and doc/_templates/, along with placeholder files like .gitignore, LICENSE, README.rst, MANIFEST.in, INSTALL, and .codecov.yml.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum1)),
    task("Create pyproject.toml with project metadata, dependencies including numpy>=1.20.0, numpy_financial>=1.0.0, pytest>=6.0.0, pytest-cov>=2.0.0, and coverage>=5.0.0.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum2)),
    task("Implement the constants and configuration section in asteval/astutils.py including HAS_NUMPY, HAS_NUMPY_FINANCIAL with fallback import mechanism, MAX_EXPONENT, MAX_STR_LEN, MAX_SHIFT, MAX_OPEN_BUFFER, RESERVED_WORDS, NAME_MATCH, UNSAFE_ATTRS, and all FROM_* tuples.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum3)),
    task("Implement the safe utility functions in asteval/astutils.py including safe_pow, safe_mult, safe_add, safe_lshift, _open, and _type functions with proper overflow and security protections.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum4)),
    task("Implement the symbol validation and operator helper functions in asteval/astutils.py including valid_symbol_name, valid_varname, op2func, get_ast_names, and the OPERATORS dictionary mapping.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum5)),
    task("Implement the Empty, ExceptionHolder, and Group classes in asteval/astutils.py with all their methods including __init__, __nonzero__, __repr__, get_error, __setattr__, __getattr__, __setitem__, get, and _repr_html_.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum6)),
    task("Implement the Procedure class in asteval/astutils.py with __init__, __setattr__, __dir__, __repr__, and __call__ methods for user-defined function support.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum7)),
    task("Implement the NameFinder class and make_symbol_table function in asteval/astutils.py including BUILTINS_TABLE, MATH_TABLE construction and the nested symbol table support.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum8)),
    task("Implement the configuration constants in asteval/asteval.py including ALL_NODES list, MINIMAL_CONFIG dictionary, and DEFAULT_CONFIG dictionary.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum9)),
    task("Implement the Interpreter class skeleton and __init__ method in asteval/asteval.py including all parameter handling, configuration setup, node handler registration, and readonly_symbols initialization.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum10)),
    task("Implement the core Interpreter methods in asteval/asteval.py including remove_nodehandler, set_nodehandler, user_defined_symbols, unimplemented, raise_exception, parse, run, __call__, eval, and dump.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum11)),
    task("Implement the basic AST node handlers in asteval/asteval.py including on_expr, on_module, on_expression, on_constant, on_num, on_str, on_bytes, on_name, on_nameconstant, on_pass, on_ellipsis, on_index, and on_repr.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum12)),
    task("Implement the data structure node handlers in asteval/asteval.py including on_list, on_tuple, on_set, on_dict, on_subscript, on_slice, on_extslice, and _getsym.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum13)),
    task("Implement the assignment and attribute handlers in asteval/asteval.py including node_assign, on_assign, on_augassign, on_attribute, and on_delete.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum14)),
    task("Implement the operator node handlers in asteval/asteval.py including on_unaryop, on_binop, on_boolop, and on_compare with chained comparison support.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum15)),
    task("Implement the control flow node handlers in asteval/asteval.py including on_if, on_ifexp, on_while, on_for, on_with, on_assert, on_break, on_continue, and on_interrupt.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum16)),
    task("Implement the function and call handlers in asteval/asteval.py including on_functiondef, on_arg, on_call, and on_return.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum17)),
    task("Implement the exception and comprehension handlers in asteval/asteval.py including on_try, on_excepthandler, on_raise, on_listcomp, on_setcomp, on_dictcomp, and comprehension_data.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum18)),
    task("Implement the import handlers in asteval/asteval.py including on_import, on_importfrom, and import_module method with security restrictions.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum19)),
    task("Implement the f-string handlers in asteval/asteval.py including on_joinedstr and on_formattedvalue methods.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum20)),
    task("Implement the _printer method and finalize all remaining Interpreter methods in asteval/asteval.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum21)),
    task("Create asteval/__init__.py as the unified API entry point exporting Interpreter, NameFinder, make_symbol_table, get_ast_names, valid_symbol_name, and __version__.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum22)),
    task("Install the package in development mode using pip install and verify that basic imports from asteval work correctly.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum23)),
    task("Write comprehensive test suite covering basic expression evaluation, dictionary indexing, list slicing, tuple and set operations, string operations, f-string support, numpy array operations, loop control structures, conditional statements, function definition and calls, comprehensions, exception handling, mathematical operations, symbol table management, safety restrictions, AST parsing, configuration options, error handling, and output redirection.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum24)),
    task("Run the full test suite and fix any failures until all tests pass.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum25)),
    task("Create pyproject.toml or setup.py so the project is installable with pip install -e. Store a summary in the output variable.", string(SumPyproj)),
    task("Install the package with pip install -e . and verify basic imports work. Store a summary in the output variable.", string(SumInstall)),
    task("Run the full test suite and fix any failures until all tests pass. Store a summary in the output variable.", string(SumTests)),
    answer("Done.").

agent_main :-
    answer("Failed.").
