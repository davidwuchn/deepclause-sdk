[log] bash[68] stdout # Basic exception handling
[log] bash[68] stdout interp("""
[log] bash[68] stdout x = 5
[log] bash[68] stdout try:
[log] bash[68] stdout     x = x/0
[log] bash[68] stdout except ZeroDivisionError:
[log] bash[68] stdout     print('Error Seen!')
[log] bash[68] stdout     x = -999
[log] bash[68] stdout """)
