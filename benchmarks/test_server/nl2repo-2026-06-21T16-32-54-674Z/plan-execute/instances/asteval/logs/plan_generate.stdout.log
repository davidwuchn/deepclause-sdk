[log] bash[68] stdout # Exception handling with else
[log] bash[68] stdout interp("""
[log] bash[68] stdout def dotry(x, y):
[log] bash[68] stdout     out, ok, clean = 0, False, False
[log] bash[68] stdout     try:
[log] bash[68] stdout         out = x/y
[log] bash[68] stdout     except ZeroDivisionError:
[log] bash[68] stdout         out = -1
[log] bash[68] stdout     else:
[log] bash[68] stdout         ok = True
[log] bash[68] stdout     finally:
[log] bash[68] stdout         clean = True
[log] bash[68] stdout     return out, ok, clean
[log] bash[68] stdout """)
[log] bash[68] stdout result = interp("dotry(1, 2.0)")
[log] bash[68] stdout print(result)  # (0.5, True, True)
[log] bash[68] stdout result = interp("dotry(1, 0.0)")
[log] bash[68] stdout print(result)  # (-1, False, True)
[log] bash[68] stdout # General exception handling
[log] bash[68] stdout interp("""
[log] bash[68] stdout x = 15
[log] bash[68] stdout try:
[log] bash[68] stdout     raise Exception()
[log] bash[68] stdout     x = 20
[log] bash[68] stdout except:
[log] bash[68] stdout     pass
[log] bash[68] stdout """)
[log] bash[68] stdout result = interp("x")
[log] bash[68] stdout print(result)  # 15
[log] bash[68] stdout # Test verification
[log] bash[68] stdout assert interp("x") == -999  # First exception handling
[log] bash[68] stdout assert interp("dotry(1, 2.0)") == (0.5, True, True)
[log] bash[68] stdout assert interp("dotry(1, 0.0)") == (-1, False, True)
[log] bash[68] stdout assert interp("x") == 15  # General exception handling
[log] bash[68] stdout ```
