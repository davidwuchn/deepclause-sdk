tool(run_bash(Command, Output), "Run a shell command in the workspace. Use cat to read files, use heredocs to write files: cat > path/to/file.py << 'ENDOFFILE'\ncode here\nENDOFFILE\nUse mkdir -p before writing to new directories. Use ls to list directories.") :-
    exec(bash(command: Command), Output).

agent_main :-
    exec(bash(command: 'cat start.md'), SpecResult),
    get_dict(stdout, SpecResult, SpecContent),
    format(string(SysPrompt), "You are an expert Python developer. You MUST implement a complete library from the specification below.\n\nCRITICAL RULES:\n1. Start coding IMMEDIATELY. The full specification is below — do NOT re-read start.md.\n2. Use run_bash for EVERYTHING: write files with heredocs, run commands.\n3. To write a file: run_bash with: mkdir -p dirname && cat > filepath << 'ENDOFFILE'\n... file content ...\nENDOFFILE\n4. NEVER call write_file_content or read_file_content — they do not exist.\n5. After writing each file, verify it with cat or python -c 'import module'.\n6. Work autonomously. No user interaction. No web_search, news_search, url_fetch, or create_skill.\n7. If a task seems unclear, make reasonable assumptions and implement anyway.\n8. DO NOT spend more than 2 iterations reading. By iteration 3 you MUST be writing code.\n9. At the end of each task, briefly summarize what you did and what is left to do. This summary carries forward to the next task.\n\n--- BEGIN SPECIFICATION ---\n~w\n--- END SPECIFICATION ---", [SpecContent]),
    system(SysPrompt),
    task("Set up the project directory structure with all necessary __init__.py files for src/aiofiles, src/aiofiles/tempfile, and src/aiofiles/threadpool packages.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum1)),
    task("Create pyproject.toml with project metadata, version information, and dependencies including pytest and pytest-asyncio to make the project installable.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum2)),
    task("Implement the base.py module with AsyncBase class, AsyncIndirectBase class, AiofilesContextManager class, and the wrap() decorator function for OS operations.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum3)),
    task("Implement the threadpool/utils.py module with helper functions _make_delegate_method, _make_proxy_method, _make_proxy_property, _make_cond_delegate_method, and the class decorators delegate_to_executor, proxy_method_directly, proxy_property_directly, and cond_delegate_to_executor.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum4)),
    task("Implement the threadpool/binary.py module with AsyncBufferedIOBase, AsyncBufferedReader, AsyncFileIO, AsyncIndirectBufferedIOBase, AsyncIndirectBufferedReader, and AsyncIndirectFileIO classes using the decorator utilities.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum5)),
    task("Implement the threadpool/text.py module with AsyncTextIOWrapper and AsyncTextIndirectIOWrapper classes using the decorator utilities.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum6)),
    task("Implement the threadpool/__init__.py module with the open() function, singledispatch wrap() function with registered handlers for TextIOBase, BufferedWriter, BufferedIOBase, BufferedReader, BufferedRandom, and FileIO types, and the stdin, stdout, stderr stdio objects plus their byte versions.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum7)),
    task("Implement the tempfile/temptypes.py module with AsyncSpooledTemporaryFile class including _check, write, and writelines methods, AsyncTemporaryDirectory class with close method, and AiofilesContextManagerTempDir class.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum8)),
    task("Implement the tempfile/__init__.py module with the TemporaryFile, NamedTemporaryFile, SpooledTemporaryFile, and TemporaryDirectory factory functions, and the singledispatch wrap() function with registered handlers.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum9)),
    task("Implement the os.py module with async versions of stat, rename, renames, replace, remove, unlink, mkdir, makedirs, rmdir, removedirs, symlink, readlink, link, listdir, scandir, access, getcwd, and the wrap() function.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum10)),
    task("Implement the ospath.py module with async versions of abspath, exists, isfile, isdir, islink, ismount, getsize, getatime, getctime, getmtime, samefile, and sameopenfile.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum11)),
    task("Implement the main src/aiofiles/__init__.py module with unified API exports including open, tempfile, stdin, stdout, stderr, stdin_bytes, stdout_bytes, and stderr_bytes.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum12)),
    task("Install the package in development mode and verify that all basic imports work correctly.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum13)),
    task("Write a comprehensive test suite with async tests covering async file opening and reading, async file writing, async iteration, async temporary files, async OS operations, async path operations, standard I/O stream operations, and concurrent file operations.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum14)),
    task("Run the full test suite and fix any failures until all tests pass.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum15)),
    task("Create pyproject.toml or setup.py so the project is installable with pip install -e. Store a summary in the output variable.", string(SumPyproj)),
    task("Install the package with pip install -e . and verify basic imports work. Store a summary in the output variable.", string(SumInstall)),
    task("Run the full test suite and fix any failures until all tests pass. Store a summary in the output variable.", string(SumTests)),
    answer("Done.").

agent_main :-
    answer("Failed.").
