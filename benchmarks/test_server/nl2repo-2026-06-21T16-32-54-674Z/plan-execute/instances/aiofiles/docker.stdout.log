ng property.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\", encoding=\"utf-8\") as f:\n            assert f.encoding == \"utf-8\"\n\n    async def test_buffer_property(self, sample_text_file):\n        \"\"\"Test buffer property exists.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            assert f.buffer is not None\n\n    async def test_errors_property(self, sample_text_file):\n        \"\"\"Test errors property.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\", errors=\"strict\") as f:\n            assert f.errors == \"strict\"\n\n    async def test_newlines_property(self, sample_text_file):\n        \"\"\"Test newlines property.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            await f.read()\n            # After reading, newlines should be set\n            nl = f.newlines\n\n    async def test_line_buffering_property(self, sample_text_file):\n        \"\"\"Test line_buffering property.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            lb = f.line_buffering\n        assert isinstance(lb, bool)\n\n\nclass TestTextIteration:\n    \"\"\"Test async iteration over text files.\"\"\"\n\n    async def test_async_for_iteration(self, sample_text_file):\n        \"\"\"Test async for iteration reads lines.\"\"\"\n        lines = []\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            async for line in f:\n                lines.append(line)\n        assert lines == [\"Line 1\\n\", \"Line 2\\n\", \"Line 3\\n\"]\n\n    async def test_async_for_empty_file(self, tmp_path):\n        \"\"\"Test async for on empty file.\"\"\"\n        fpath = str(tmp_path / \"empty.txt\")\n        with open(fpath, \"w\"):\n            pass\n        lines = []\n        async with aiofiles.open(fpath, \"r\") as f:\n            async for line in f:\n                lines.append(line)\n        assert lines == []\n\n    async def test_async_for_large_file(self, sample_large_file):\n        \"\"\"Test async for on larger file.\"\"\"\n        lines = []\n        async with aiofiles.open(sample_large_file, \"r\") as f:\n            async for line in f:\n                lines.append(line)\n        assert len(lines) == 100\n\n    async def test_aiter_returns_self(self, sample_text_file):\n        \"\"\"Test __aiter__ returns self.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            assert f.__aiter__() is f\n\n    async def test_anext_raises(self, tmp_path):\n        \"\"\"Test __anext__ raises StopAsyncIteration at EOF.\"\"\"\n        fpath = str(tmp_path / \"empty.txt\")\n        with open(fpath, \"w\"):\n            pass\n        async with aiofiles.open(fpath, \"r\") as f:\n            with pytest.raises(StopAsyncIteration):\n                await f.__anext__()\n\n    async def test_anext_returns_line(self, sample_text_file):\n        \"\"\"Test __anext__ returns next line.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            line = await f.__anext__()\n        assert line == \"Line 1\\n\"\n\n    async def test_repr(self, sample_text_file):\n        \"\"\"Test __repr__ includes wrapped file repr.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            r = repr(f)\n        assert \"wrapping\" in r\nENDOFFILE"}
