[AGENT] Tool call: run_bash {"arg1":"cat > src/aiofiles/tempfile/temptypes.py << 'ENDOFFILE'\n\"\"\"Asynchronous wrappers for temporary file and directory operations.\n\nProvides async versions of Python's tempfile module classes:\n- AsyncSpooledTemporaryFile    – wraps tempfile.SpooledTemporaryFile\n- AsyncTemporaryDirectory       – wraps tempfile.TemporaryDirectory\n- AiofilesContextManagerTempDir – context manager that returns the dir path\n\"\"\"\n\nfrom aiofiles.base import AsyncBase, AiofilesContextManager\nfrom aiofiles.threadpool.utils import (\n    cond_delegate_to_executor,\n    delegate_to_executor,\n    proxy_property_directly,\n)\n\n\n# ---------------------------------------------------------------------------\n# AsyncSpooledTemporaryFile\n# ---------------------------------------------------------------------------\n\n@delegate_to_executor(\"fileno\", \"rollover\")\n@cond_delegate_to_executor(\n    \"close\",\n    \"flush\",\n    \"isatty\",\n    \"read\",\n    \"readline\",\n    \"readlines\",\n    \"seek\",\n    \"tell\",\n    \"truncate\",\n)\n@proxy_property_directly(\"closed\", \"encoding\", \"mode\", \"name\", \"newlines\")\nclass AsyncSpooledTemporaryFile(AsyncBase):\n    \"\"\"Async wrapper for SpooledTemporaryFile class.\n\n    Wraps a ``tempfile.SpooledTemporaryFile`` instance so that all blocking\n    I/O methods are executed in a thread-pool executor after rollover, and\n    run directly (synchronously) while the data is still in memory.\n    \"\"\"\n\n    async def _check(self) -> bool:\n        \"\"\"Check if the file has been rolled over to disk.\n\n        Returns:\n            bool: ``True`` if the underlying SpooledTemporaryFile has been\n                rolled over to a real on-disk file (i.e. its internal\n                ``_file`` attribute is not ``None``), ``False`` otherwise.\n        \"\"\"\n        return self._file._file is not None\n\n    async def write(self, s) -> int:\n        \"\"\"Write data to the spooled temporary file, anticipating rollover.\n\n        Before writing, checks whether the spooled file will exceed its\n        max_size after this write.  If so, forces a rollover to disk\n        *before* the write so that the blocking write is correctly\n        delegated through the executor.\n\n        Args:\n            s: The string or bytes to write to the file.\n\n        Returns:\n            int: The number of bytes / characters written.\n        \"\"\"\n        loop = self._loop\n\n        # Force rollover *before* the write if this would exceed max_size\n        if self._file._file is None and self._file._rolled:\n            # Already rolled — nothing to do\n            pass\n        elif self._file._file is None:\n            # Still in-memory; check whether the write will trigger rollover\n            current_size = len(self._file._buf)\n            write_size = len(s)\n            if current_size + write_size > self._file._max_size:\n                # Roll over before writing so the executor picks it up\n                await loop.run_in_executor(\n                    self._executor,\n                    self._file.rollover,\n                )\n\n        # Now perform the actual write\n        return await loop.run_in_executor(\n            self._executor,\n            self._file.write,\n            s,\n        )\n\n    async def writelines(self, iterable) -> int:\n        \"\"\"Write a list of lines to the spooled temporary file.\n\n        Anticipates rollover by summing the sizes of all lines first and,\n        if needed, rolling over before any writes occur.\n\n        Args:\n            iterable: An iterable of strings or bytes to write.\n\n        Returns:\n            int: The number of bytes / characters written (sum of all lines).\n        \"\"\"\n        loop = self._loop\n\n        # Pre-evaluate if total size will trigger rollover\n        if self._file._file is None:\n            current_size = len(self._file._buf)\n            total_size = sum(len(item) for item in iterable)\n            if current_size + total_size > self._file._max_size:\n                await loop.run_in_executor(\n                    self._executor,\n                    self._file.rollover,\n                )\n\n        return await loop.run_in_executor(\n            self._executor,\n            self._file.writelines,\n            iterable,\n        )\n\n\n# ---------------------------------------------------------------------------\n# AsyncTemporaryDirectory\n# ---------------------------------------------------------------------------\n\n@delegate_to_executor(\"cleanup\")\n@proxy_property_directly(\"name\")\nclass AsyncTemporaryDirectory:\n    \"\"\"Async wrapper for TemporaryDirectory class.\n\n    Wraps a ``tempfile.TemporaryDirectory`` instance so that the blocking\n    cleanup call is delegated to a thread-pool executor.\n    \"\"\"\n\n    def __init__(self, file, loop=None, executor=None):\n        self._file = file\n        self._loop = loop\n        self._executor = executor\n\n    async def close(self):\n        \"\"\"Close and clean up the temporary directory.\"\"\"\n        await self.cleanup()\n\n\n# ---------------------------------------------------------------------------\n# AiofilesContextManagerTempDir\n# ---------------------------------------------------------------------------\n\nclass AiofilesContextManagerTempDir(AiofilesContextManager):\n    \"\"\"Async context manager for TemporaryDirectory.\n\n    Unlike the regular AiofilesContextManager, this class returns the\n    *directory path string* (not the wrapper object) from ``__aenter__``,\n    matching the behaviour of the synchronous ``tempfile.TemporaryDirectory``.\n    \"\"\"\n\n    async def __aenter__(self):\n        \"\"\"Enter the context manager.\n\n        Returns:\n            str: The path of the created temporary directory.\n        \"\"\"\n        self._obj = await self._coro\n        return self._obj.name\nENDOFFILE"}
