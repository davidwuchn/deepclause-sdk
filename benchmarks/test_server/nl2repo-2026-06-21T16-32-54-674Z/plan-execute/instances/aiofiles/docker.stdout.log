th aiofiles.open(sample_binary_file, \"rb\") as f:\n            assert f.readable()\n\n    async def test_writable(self, tmp_path):\n        \"\"\"Test writable() returns True for write-mode file.\"\"\"\n        fpath = str(tmp_path / \"writable.bin\")\n        async with aiofiles.open(fpath, \"wb\") as f:\n            assert await f.writable()\n\n    async def test_isatty(self, sample_binary_file):\n        \"\"\"Test isatty() returns False for regular files.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            assert not await f.isatty()\n\n    async def test_fileno(self, sample_binary_file):\n        \"\"\"Test fileno() returns integer file descriptor.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            fd = f.fileno()\n        assert isinstance(fd, int)\n        assert fd >= 0\n\n\nclass TestBinaryProperties:\n    \"\"\"Test binary file property access.\"\"\"\n\n    async def test_closed_property(self, sample_binary_file):\n        \"\"\"Test closed property.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            assert not f.closed\n        assert f.closed\n\n    async def test_name_property(self, sample_binary_file):\n        \"\"\"Test name property returns file path.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            assert f.name == sample_binary_file\n\n    async def test_mode_property(self, sample_binary_file):\n        \"\"\"Test mode property returns open mode.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            assert f.mode == \"rb\"\n\n    async def test_raw_property(self, sample_binary_file):\n        \"\"\"Test raw property exists.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            assert f.raw is not None\n\n\nclass TestAsyncFileIO:\n    \"\"\"Test AsyncFileIO (buffering=0, raw I/O).\"\"\"\n\n    async def test_readall(self, sample_binary_file):\n        \"\"\"Test readall() on raw FileIO.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\", buffering=0) as f:\n            data = await f.readall()\n        assert data == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_readinto_raw(self, sample_binary_file):\n        \"\"\"Test readinto() on raw FileIO.\"\"\"\n        buf = bytearray(10)\n        async with aiofiles.open(sample_binary_file, \"rb\", buffering=0) as f:\n            n = await f.readinto(buf)\n        assert n == 6\n        assert buf[:6] == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_readline_raw(self, tmp_path):\n        \"\"\"Test readline() on raw FileIO.\"\"\"\n        fpath = str(tmp_path / \"raw.bin\")\n        with open(fpath, \"wb\") as f:\n            f.write(b\"line1\\nline2\\n\")\n        async with aiofiles.open(fpath, \"rb\", buffering=0) as f:\n            line = await f.readline()\n        assert line == b\"line1\\n\"\n\n    async def test_seek_raw(self, sample_binary_file):\n        \"\"\"Test seek/tell on raw FileIO.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\", buffering=0) as f:\n            await f.seek(2)\n            assert await f.tell() == 2\nENDOFFILE"}
