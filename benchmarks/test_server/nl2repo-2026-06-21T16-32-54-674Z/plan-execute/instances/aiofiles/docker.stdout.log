[AGENT] Tool call: run_bash {"arg1":"cat > tests/threadpool/test_binary.py << 'ENDOFFILE'\n\"\"\"Tests for async binary file operations.\"\"\"\n\nimport asyncio\nimport array\nimport pytest\nimport aiofiles\nfrom aiofiles.threadpool import open as aioopen\nfrom aiofiles.threadpool import wrap\n\n\nclass TestBinaryRead:\n    \"\"\"Test binary file reading operations.\"\"\"\n\n    async def test_read_all(self, sample_binary_file):\n        \"\"\"Test read() reads entire binary file.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            data = await f.read()\n        assert data == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n        assert isinstance(data, bytes)\n\n    async def test_read_partial(self, sample_binary_file):\n        \"\"\"Test read(n) reads up to n bytes.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            data = await f.read(3)\n        assert data == b\"\\x00\\x01\\x02\"\n\n    async def test_read_zero(self, sample_binary_file):\n        \"\"\"Test read(0) returns empty bytes.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            data = await f.read(0)\n        assert data == b\"\"\n\n    async def test_read_after_eof(self, sample_binary_file):\n        \"\"\"Test reading past EOF returns empty bytes.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            data1 = await f.read()\n            data2 = await f.read()\n        assert data1 == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n        assert data2 == b\"\"\n\n    async def test_readline(self, tmp_path):\n        \"\"\"Test readline() on binary file.\"\"\"\n        fpath = str(tmp_path / \"lines.bin\")\n        with open(fpath, \"wb\") as f:\n            f.write(b\"line1\\nline2\\nline3\\n\")\n        async with aiofiles.open(fpath, \"rb\") as f:\n            line1 = await f.readline()\n            line2 = await f.readline()\n        assert line1 == b\"line1\\n\"\n        assert line2 == b\"line2\\n\"\n\n    async def test_readlines(self, tmp_path):\n        \"\"\"Test readlines() on binary file.\"\"\"\n        fpath = str(tmp_path / \"lines.bin\")\n        with open(fpath, \"wb\") as f:\n            f.write(b\"line1\\nline2\\nline3\\n\")\n        async with aiofiles.open(fpath, \"rb\") as f:\n            lines = await f.readlines()\n        assert lines == [b\"line1\\n\", b\"line2\\n\", b\"line3\\n\"]\n\n    async def test_read1(self, sample_binary_file):\n        \"\"\"Test read1() on buffered binary file.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            data = await f.read1(2)\n        assert data == b\"\\x00\\x01\"\n\n    async def test_readall_raw(self, sample_binary_file):\n        \"\"\"Test readall() on raw binary file (buffering=0).\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\", buffering=0) as f:\n            data = await f.readall()\n        assert data == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_readinto(self, sample_binary_file):\n        \"\"\"Test readinto() on binary file.\"\"\"\n        buf = bytearray(10)\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            n = await f.readinto(buf)\n        assert n == 6\n        assert buf[:6] == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_readinto_array(self, sample_binary_file):\n        \"\"\"Test readinto() with array buffer.\"\"\"\n        buf = array.array(\"b\", [0] * 10)\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            n = await f.readinto(buf)\n        assert n == 6\n\n    async def test_peek(self, tmp_path):\n        \"\"\"Test peek() on BufferedReader.\"\"\"\n        fpath = str(tmp_path / \"peek.bin\")\n        with open(fpath, \"wb\") as f:\n            f.write(b\"Hello World\")\n        async with aiofiles.open(fpath, \"rb\") as f:\n            await f.read(2)  # consume \"He\"\n            preview = await f.peek(5)\n        assert preview == b\"llo W\"\n        # peek should not advance position\n        data = await f.read(2) if not f.closed else b\"\"\n\n    async def test_peek_does_not_advance(self, tmp_path):\n        \"\"\"Test peek() does not move file pointer.\"\"\"\n        fpath = str(tmp_path / \"peek2.bin\")\n        with open(fpath, \"wb\") as f:\n            f.write(b\"ABCDEFGHIJ\")\n        async with aiofiles.open(fpath, \"rb\") as f:\n            pos_before = await f.tell()\n            preview = await f.peek(3)\n            pos_after = await f.tell()\n        assert pos_before == pos_after\n        assert preview == b\"ABC\"\n\n\nclass TestBinaryWrite:\n    \"\"\"Test binary file writing operations.\"\"\"\n\n    async def test_write(self, tmp_path):\n        \"\"\"Test write() on binary file.\"\"\"\n        fpath = str(tmp_path / \"write.bin\")\n        async with aiofiles.open(fpath, \"wb\") as f:\n            n = await f.write(b\"Hello\")\n        assert n == 5\n        with open(fpath, \"rb\") as f:\n            assert f.read() == b\"Hello\"\n\n    async def test_writelines(self, tmp_path):\n        \"\"\"Test writelines() on binary file.\"\"\"\n        fpath = str(tmp_path / \"writelines.bin\")\n        lines = [b\"line1\\n\", b\"line2\\n\", b\"line3\\n\"]\n        async with aiofiles.open(fpath, \"wb\") as f:\n            await f.writelines(lines)\n        with open(fpath, \"rb\") as f:\n            assert f.read() == b\"line1\\nline2\\nline3\\n\"\n\n    async def test_flush(self, tmp_path):\n        \"\"\"Test flush() on binary file.\"\"\"\n        fpath = str(tmp_path / \"flush.bin\")\n        async with aiofiles.open(fpath, \"wb\") as f:\n            await f.write(b\"data\")\n            await f.flush()\n        with open(fpath, \"rb\") as f:\n            assert f.read() == b\"data\"\n\n    async def test_truncate(self, tmp_path):\n        \"\"\"Test truncate() on binary file.\"\"\"\n        fpath = str(tmp_path / \"truncate.bin\")\n        async with aiofiles.op