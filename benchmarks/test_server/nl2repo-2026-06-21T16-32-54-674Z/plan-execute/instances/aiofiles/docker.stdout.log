[log] bash[69] stdout     # readall() - only for FileIO/RawIOBase
[log] bash[69] stdout     # all_data = await f.readall()
[log] bash[69] stdout     # Output: bytes object of all file content
[log] bash[69] stdout     
[log] bash[69] stdout     # readinto() - only for binary files
[log] bash[69] stdout     # import array
