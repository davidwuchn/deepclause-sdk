[log] bash[119] stdout from functools import wraps
[log] bash[119] stdout from typing import Any, Callable
[log] bash[119] stdout # ---------------------------------------------------------------------------
[log] bash[119] stdout # Helper functions that generate methods / properties
[log] bash[119] stdout # ---------------------------------------------------------------------------
[log] bash[119] stdout def _make_delegate_method(attr_name: str) -> Callable:
[log] bash[119] stdout     """Create an async method that delegates a call to the underlying file
[log] bash[119] stdout     object via *self._loop.run_in_executor*.
[log] bash[119] stdout     Args:
[log] bash[119] stdout         attr_name: The name of the attribute (method) on the underlying
[log] bash[119] stdout             file object to delegate to.
[log] bash[119] stdout     Returns:
[log] bash[119] stdout         An async method suitable for assignment to the wrapper class.
[log] bash[119] stdout     """
[log] bash[119] stdout     async def method(self, *args, **kwargs):
[log] bash[119] stdout         loop = self._loop
[log] bash[119] stdout         func = getattr(self._file, attr_name)
[log] bash[119] stdout         return await loop.run_in_executor(self._executor, func, *args, **kwargs)
[log] bash[119] stdout     method.__name__ = attr_name
[log] bash[119] stdout     return method
[log] bash[119] stdout def _make_proxy_method(attr_name: str) -> Callable:
[log] bash[119] stdout     """Create a synchronous method that directly proxies a call to the
[log] bash[119] stdout     underlying file object.
[log] bash[119] stdout     Used for methods that return non-blocking information (e.g. *fileno*,
[log] bash[119] stdout     *readable*) and should **not** be awaited.
[log] bash[119] stdout     Args:
[log] bash[119] stdout         attr_name: The name of the attribute (method) on the underlying
[log] bash[119] stdout             file object to proxy.
[log] bash[119] stdout     Returns:
[log] bash[119] stdout         A synchronous method suitable for assignment to the wrapper class.
[log] bash[119] stdout     """
[log] bash[119] stdout     def method(self, *args, **kwargs):
[log] bash[119] stdout         return getattr(self._file, attr_name)(*args, **kwargs)
[log] bash[119] stdout     method.__name__ = attr_name
[log] bash[119] stdout     return method
[log] bash[119] stdout def _make_proxy_property(attr_name: str) -> property:
[log] bash[119] stdout     """Create a property that reads an attribute directly from the
[log] bash[119] stdout     underlying file object.
[log] bash[119] stdout     Args:
[log] bash[119] stdout         attr_name: The name of the attribute on the underlying file
[log] bash[119] stdout             object to expose as a property.
[log] bash[119] stdout     Returns:
[log] bash[119] stdout         A ``property`` that returns the value of *attr_name* from the
[log] bash[119] stdout         wrapped file.
[log] bash[119] stdout     """
[log] bash[119] stdout     def proxy_property(self):
[log] bash[119] stdout         return getattr(self._file, attr_name)
[log] bash[119] stdout     proxy_property.__name__ = attr_name
[log] bash[119] stdout     return property(proxy_property)
[log] bash[119] stdout def _make_cond_delegate_method(attr_name: str) -> Callable:
[log] bash[119] stdout     """For spooled temporary files, delegate only if the file has been
[log] bash[119] stdout     rolled over to a real on-disk file object.
[log] bash[119] stdout     If the underlying ``SpooledTemporaryFile`` is still in-memory (i.e.
