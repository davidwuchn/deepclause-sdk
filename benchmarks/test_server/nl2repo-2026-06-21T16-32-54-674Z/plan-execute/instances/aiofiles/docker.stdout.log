s operations.\"\"\"\n\n    async def test_makedirs(self, tmp_path):\n        \"\"\"Test creating nested directories.\"\"\"\n        dirpath = str(tmp_path / \"a\" / \"b\" / \"c\")\n        await aios.makedirs(dirpath)\n        assert os.path.isdir(dirpath)\n\n    async def test_makedirs_exist_ok(self, tmp_path):\n        \"\"\"Test makedirs with exist_ok=True.\"\"\"\n        dirpath = str(tmp_path / \"a\" / \"b\")\n        await aios.makedirs(dirpath)\n        # Should not raise with exist_ok\n        await aios.makedirs(dirpath, exist_ok=True)\n\n\nclass TestRmdir:\n    \"\"\"Test async rmdir operations.\"\"\"\n\n    async def test_rmdir(self, tmp_path):\n        \"\"\"Test removing an empty directory.\"\"\"\n        dirpath = str(tmp_path / \"empty\")\n        await aios.mkdir(dirpath)\n        await aios.rmdir(dirpath)\n        assert not os.path.exists(dirpath)\n\n    async def test_rmdir_nonempty(self, tmp_path):\n        \"\"\"Test rmdir on non-empty directory raises.\"\"\"\n        dirpath = str(tmp_path / \"nonempty\")\n        await aios.mkdir(dirpath)\n        fpath = os.path.join(dirpath, \"file.txt\")\n        with open(fpath, \"w\"):\n            pass\n        with pytest.raises(OSError):\n            await aios.rmdir(dirpath)\n\n\nclass TestRemovedirs:\n    \"\"\"Test async removedirs operations.\"\"\"\n\n    async def test_removedirs(self, tmp_path):\n        \"\"\"Test recursively removing empty directories.\"\"\"\n        dirpath = str(tmp_path / \"rm_a\" / \"rm_b\" / \"rm_c\")\n        await aios.makedirs(dirpath)\n        await aios.removedirs(str(tmp_path / \"rm_a\"))\n        assert not os.path.exists(str(tmp_path / \"rm_a\"))\n\n    async def test_removedirs_nonempty(self, tmp_path):\n        \"\"\"Test removedirs on non-empty raises.\"\"\"\n        dirpath = str(tmp_path / \"re_a\" / \"re_b\")\n        await aios.makedirs(dirpath)\n        fpath = os.path.join(dirpath, \"file.txt\")\n        with open(fpath, \"w\"):\n            pass\n        with pytest.raises(OSError):\n            await aios.removedirs(str(tmp_path / \"re_a\"))\n\n\nclass TestRename:\n    \"\"\"Test async rename operations.\"\"\"\n\n    async def test_rename(self, tmp_path):\n        \"\"\"Test renaming a file.\"\"\"\n        old = str(tmp_path / \"old.txt\")\n        new = str(tmp_path / \"new.txt\")\n        with open(old, \"w\") as f:\n            f.write(\"content\")\n        await aios.rename(old, new)\n        assert os.path.exists(new)\n        assert not os.path.exists(old)\n        with open(new, \"r\") as f:\n            assert f.read() == \"content\"\n\n    async def test_rename_dir(self, tmp_path):\n        \"\"\"Test renaming a directory.\"\"\"\n        old = str(tmp_path / \"olddir\")\n        new = str(tmp_path / \"newdir\")\n        await aios.mkdir(old)\n        await aios.rename(old, new)\n        assert os.path.isdir(new)\n        assert not os.path.exists(old)\n\n\nclass TestReplace:\n    \"\"\"Test async replace operation.\"\"\"\n\n    async def test_replace_file(self, tmp_path):\n        \"\"\"Test replacing a file.\"\"\"\n        target = str(tmp_path / \"target.txt\")\n        source = str(tmp_path / \"source.txt\")\n        with open(target, \"w\") as f:\n            f.write(\"old\")\n        with open(source, \"w\") as f:\n            f.write(\"new\")\n        await aios.replace(source, target)\n        with open(target, \"r\") as f:\n            assert f.read() == \"new\"\n        assert not os.path.exists(source)\n\n\nclass TestRemove:\n    \"\"\"Test async remove operations.\"\"\"\n\n    async def test_remove(self, tmp_path):\n        \"\"\"Test removing a file.\"\"\"\n        fpath = str(tmp_path / \"remove.txt\")\n        with open(fpath, \"w\") as f:\n            f.write(\"data\")\n        await aios.remove(fpath)\n        assert not os.path.exists(fpath)\n\n    async def test_remove_nonexistent(self, tmp_path):\n        \"\"\"Test removing nonexistent file raises.\"\"\"\n        with pytest.raises(FileNotFoundError):\n            await aios.remove(str(tmp_path / \"nope.txt\"))\n\n\nclass TestUnlink:\n    \"\"\"Test async unlink operations.\"\"\"\n\n    async def test_unlink(self, tmp_path):\n        \"\"\"Test unlinking a file.\"\"\"\n        fpath = str(tmp_path / \"unlink.txt\")\n        with open(fpath, \"w\") as f:\n            f.write(\"data\")\n        await aios.unlink(fpath)\n        assert not os.path.exists(fpath)\n\n    async def test_unlink_dir(self, tmp_path):\n        \"\"\"Test unlinking a directory raises (on Unix).\"\"\"\n        dirpath = str(tmp_path / \"dir_to_unlink\")\n        await aios.mkdir(dirpath)\n        with pytest.raises(OSError):\n            await aios.unlink(dirpath)\n\n\nclass TestListdir:\n    \"\"\"Test async listdir operations.\"\"\"\n\n    async def test_listdir(self, tmp_path):\n        \"\"\"Test listing directory contents.\"\"\"\n        for name in [\"a.txt\", \"b.txt\", \"c.txt\"]:\n            with open(str(tmp_path / name), \"w\"):\n                pass\n        files = await aios.listdir(str(tmp_path))\n        assert \"a.txt\" in files\n        assert \"b.txt\" in files\n        assert \"c.txt\" in files\n\n    async def test_listdir_empty(self, tmp_path):\n        \"\"\"Test listing empty directory.\"\"\"\n        files = await aios.listdir(str(tmp_path))\n        assert isinstance(files, list)\n\n\nclass TestScandir:\n    \"\"\"Test async scandir operations.\"\"\"\n\n    async def test_scandir(self, tmp_path):\n        \"\"\"Test scanning directory.\"\"\"\n        for name in [\"a.txt\", \"b.txt\"]:\n            with open(str(tmp_path / name), \"w\"):\n                pass\n        entries = await aios.scandir(str(tmp_path))\n        names = [e.name for e in entries]\n        assert \"a.txt\" in names\n        assert \"b.txt\" in names\n\n    async def test_scandir_is_file_is_dir(self, tmp_path):\n        \"\"\"Test scandir entry is_file and is_dir.\"\"\"\n        with open(str(tmp_path / \"f.txt\"), \"w\"):\n            pass\n        await aios.mkdir(str(tmp_path / \"subdir\"))\n        entries = await aios.scandir(str(tmp_path))\n        entry_map = {e.name: e for e in entries}\n        assert entry_map[\"f.txt\"].is_file()\n        assert entry_map[\"subdir\"].is_dir()\n\n\nclass TestAccess:\n    \"\"\"Test async access operations.\"\"\"\n\n    async def test_access_readable(self, sample_text_file):\n        \"\"\"Test access for read permission.\"\"\"\n        result = await aios.access(sample_text_file, os.R_OK)\n        assert result is True\n\n    async def test_access_writable(self, tmp_path):\n        \"\"\"Test access for write permission.\"\"\"\n        fpath = str(tmp_path / \"access.txt\")\n        with open(fpath, \"w\"):\n            pass\n        result = await aios.access(fpath, os.W_OK)\n        assert result is True\n\n    async def test_access_nonexistent(self):\n        \"\"\"Test access on nonexistent file.\"\"\"\n        result = await aios.access(\"/nonexistent_xyz\", os.F_OK)\n        assert result is False\n\n\nclass TestSymlink:\n    \"\"\"Test async symbolic link operations.\"\"\"\n\n    async def test_symlink(self, tmp_path):\n        \"\"\"Test creating a symbolic link.\"\"\"\n        target = str(tmp_path / \"target.txt\")\n        link = str(tmp_path / \"link.txt\")\n        with open(target, \"w\") as f:\n            f.write(\"content\")\n        await aios.symlink(target, link)\n        assert os.path.islink(link)\n\n    async def test_readlink(self, tmp_path):\n        \"\"\"Test reading a symbolic link.\"\"\"\n        target = str(tmp_path / \"target.txt\")\n        link = str(tmp_path / \"link.txt\")\n        with open(target, \"w\"):\n            pass\n        await aios.symlink(target, link)\n        resolved = await aios.readlink(link)\n        assert resolved == target\n\n    @pytest.mark.skipif(\n        sys.platform == \"win32\" and not hasattr(os, \"link\"),\n        reason=\"link not supported\",\n    )\n    async def test_hardlink(self, tmp_path):\n        \"\"\"Test creating a hard link.\"\"\"\n        if not hasattr(aios, \"link\") or aios.link is None:\n            pytest.skip(\"link not supported on this platform\")\n        target = str(tmp_path / \"target.txt\")\n        link = str(tmp_path / \"hardlink.txt\")\n        with open(target, \"w\") as f:\n            f.write(\"shared\")\n        await aios.link(target, link)\n        with open(link, \"r\") as f:\n            assert f.read() == \"shared\"\n\n\nclass TestRenames:\n    \"\"\"Test async renames operations.\"\"\"\n\n    async def test_renames(self, tmp_path):\n        \"\"\"Test recursively renaming a nested directory.\"\"\"\n        oldpath = str(tmp_path / \"rn_a\" / \"rn_b\" / \"rn_c\" / \"file.txt\")\n        newpath = str(tmp_path / \"rn_x\" / \"rn_y\" / \"rn_z\" / \"file.txt\")\n        await aios.makedirs(os.path.dirname(oldpath))\n        with open(oldpath, \"w\") as f:\n            f.write(\"nested\")\n        await aios.renames(oldpath, newpath)\n        assert os.path.exists(newpath)\n        with open(newpath, \"r\") as f:\n            assert f.read() == \"nested\"\n\n\nclass TestOsWrap:\n    \"\"\"Test the os.wrap() function.\"\"\"\n\n    async def test_os_wrap(self, sample_text_file):\n        \"\"\"Test os.wrap() wraps an os function.\"\"\"\n        async_stat = aios.wrap(os.stat)\n        result = await async_stat(sample_text_file)\n        assert result.st_size > 0\nENDOFFILE"}
