await f.read()\n        assert data == b\"Hello\"\n\n    async def test_temporary_file_encoding(self):\n        \"\"\"Test TemporaryFile with encoding.\"\"\"\n        async with aiofiles.tempfile.TemporaryFile(\n            mode=\"w+\", encoding=\"utf-8\"\n        ) as f:\n            await f.write(\"Unicode: 日本語\")\n            await f.seek(0)\n            data = await f.read()\n        assert data == \"Unicode: 日本語\"\n\n    async def test_temporary_file_close(self):\n        \"\"\"Test TemporaryFile close.\"\"\"\n        f = None\n        async with aiofiles.tempfile.TemporaryFile() as f:\n            await f.write(b\"data\")\n        assert f.closed\n\n\nclass TestNamedTemporaryFile:\n    \"\"\"Test async NamedTemporaryFile operations.\"\"\"\n\n    async def test_named_temporary_file_write_read(self):\n        \"\"\"Test writing and reading from NamedTemporaryFile.\"\"\"\n        async with aiofiles.tempfile.NamedTemporaryFile() as f:\n            await f.write(b\"named data\")\n            await f.seek(0)\n            data = await f.read()\n        assert data == b\"named data\"\n\n    async def test_named_temporary_file_text_mode(self):\n        \"\"\"Test NamedTemporaryFile in text mode.\"\"\"\n        async with aiofiles.tempfile.NamedTemporaryFile(mode=\"w+\", delete=False) as f:\n            await f.write(\"named text\")\n            await f.seek(0)\n            data = await f.read()\n            name = f.name\n        assert data == \"named text\"\n        assert name is not None\n        os.unlink(name)  # cleanup since delete=False\n\n    async def test_named_temporary_file_has_name(self):\n        \"\"\"Test that NamedTemporaryFile has a name attribute.\"\"\"\n        async with aiofiles.tempfile.NamedTemporaryFile() as f:\n            name = f.name\n            assert name is not None\n            assert isinstance(name, str)\n            assert len(name) > 0\n\n    async def test_named_temporary_file_delete_true(self):\n        \"\"\"Test NamedTemporaryFile with delete=True (default).\"\"\"\n        async with aiofiles.tempfile.NamedTemporaryFile(delete=True) as f:\n            await f.write(b\"data\")\n            name = f.name\n        # File should be deleted\n        assert not os.path.exists(name)\n\n    async def test_named_temporary_file_delete_false(self, tmp_path):\n        \"\"\"Test NamedTemporaryFile with delete=False.\"\"\"\n        async with aiofiles.tempfile.NamedTemporaryFile(\n            dir=str(tmp_path), delete=False\n        ) as f:\n            await f.write(b\"data\")\n            name = f.name\n        # File should still exist\n        assert os.path.exists(name)\n        with open(name, \"rb\") as f:\n            assert f.read() == b\"data\"\n        os.unlink(name)  # cleanup\n\n    async def test_named_temporary_file_prefix_suffix(self):\n        \"\"\"Test NamedTemporaryFile with prefix and suffix.\"\"\"\n        async with aiofiles.tempfile.NamedTemporaryFile(\n            prefix=\"aio_\", suffix=\".dat\", delete=False\n        ) as f:\n            name = f.name\n        basename = os.path.basename(name)\n        assert basename.startswith(\"aio_\")\n        assert basename.endswith(\".dat\")\n        os.unlink(name)\n\n\nclass TestSpooledTemporaryFile:\n    \"\"\"Test async SpooledTemporaryFile operations.\"\"\"\n\n    async def test_spooled_temporary_file_write_read(self):\n        \"\"\"Test writing and reading from SpooledTemporaryFile.\"\"\"\n        async with aiofiles.tempfile.SpooledTemporaryFile() as f:\n            await f.write(b\"spooled data\")\n            await f.seek(0)\n            data = await f.read()\n        assert data == b\"spooled data\"\n\n    async def test_spooled_temporary_file_text_mode(self):\n        \"\"\"Test SpooledTemporaryFile in text mode.\"\"\"\n        async with aiofiles.tempfile.SpooledTemporaryFile(\n            mode=\"w+\", max_size=1024\n        ) as f:\n            await f.write(\"spooled text\")\n            await f.seek(0)\n            data = await f.read()\n        assert data == \"spooled text\"\n\n    async def test_spooled_temporary_file_rollover(self):\n        \"\"\"Test SpooledTemporaryFile rollover to disk when exceeding max_size.\"\"\"\n        max_size = 100\n        async with aiofiles.tempfile.SpooledTemporaryFile(\n            max_size=max_size\n        ) as f:\n            # Write more than max_size\n            data = b\"x\" * (max_size + 50)\n            await f.write(data)\n            await f.seek(0)\n            read_data = await f.read()\n        assert read_data == data\n\n    async def test_spooled_temporary_file_writelines(self):\n        \"\"\"Test writelines on SpooledTemporaryFile.\"\"\"\n        async with aiofiles.tempfile.SpooledTemporaryFile(\n            max_size=50\n        ) as f:\n            lines = [b\"line1\\n\", b\"line2\\n\", b\"line3\\n\"]\n            await f.writelines(lines)\n            await f.seek(0)\n            data = await f.read()\n        assert data == b\"line1\\nline2\\nline3\\n\"\n\n    async def test_spooled_temporary_file_fileno(self):\n        \"\"\"Test fileno on SpooledTemporaryFile (after rollover).\"\"\"\n        async with aiofiles.tempfile.SpooledTemporaryFile(\n            max_size=10\n        ) as f:\n            # Force rollover by writing more than max_size\n            await f.write(b\"x\" * 20)\n            fd = f.fileno()\n            assert isinstance(fd, int)\n\n    async def test_spooled_temporary_file_close(self):\n        \"\"\"Test SpooledTemporaryFile close.\"\"\"\n        f = None\n        async with aiofiles.tempfile.SpooledTemporaryFile() as f:\n            await f.write(b\"data\")\n        assert f.closed\n\n    async def test_spooled_temporary_file_readline(self):\n        \"\"\"Test readline on SpooledTemporaryFile.\"\"\"\n        async with aiofiles.tempfile.SpooledTemporaryFile() as f:\n            await f.write(b\"line1\\nline2\\n\")\n            await f.seek(0)\n            line = await f.readline()\n        assert line == b\"line1\\n\"\n\n    async def test_spooled_temporary_file_truncate(self):\n        \"\"\"Test truncate on SpooledTemporaryFile.\"\"\"\n        async with aiofiles.tempfile.SpooledTemporaryFile() as f:\n            await f.write(b\"Hello World\")\n            await f.seek(0)\n            await f.truncate(5)\n            data = await f.read()\n        assert data == b\"Hello\"\n\n\nclass TestTemporaryDirectory:\n    \"\"\"Test async TemporaryDirectory operations.\"\"\"\n\n    async def test_temporary_directory_create(self):\n        \"\"\"Test creating a TemporaryDirectory.\"\"\"\n        async with aiofiles.tempfile.TemporaryDirectory() as temp_dir:\n            assert isinstance(temp_dir, str)\n            assert os.path.isdir(temp_dir)\n\n    async def test_temporary_directory_auto_cleanup(self):\n        \"\"\"Test that TemporaryDirectory is cleaned up on close.\"\"\"\n        temp_dir = None\n        async with aiofiles.tempfile.TemporaryDirectory() as temp_dir:\n            dir_path = temp_dir\n        assert not os.path.exists(dir_path)\n\n    async def test_temporary_directory_with_file(self):\n        \"\"\"Test creating a file inside TemporaryDirectory.\"\"\"\n        async with aiofiles.tempfile.TemporaryDirectory() as temp_dir:\n            fpath = os.path.join(temp_dir, \"test.txt\")\n            async with aiofiles.open(fpath, \"w\") as f:\n                await f.write(\"content\")\n            with open(fpath, \"r\") as f:\n                assert f.read() == \"content\"\n\n    async def test_temporary_directory_prefix_suffix(self):\n        \"\"\"Test TemporaryDirectory with prefix and suffix.\"\"\"\n        async with aiofiles.tempfile.TemporaryDirectory(\n            prefix=\"aio_\", suffix=\"_tmp\"\n        ) as temp_dir:\n            basename = os.path.basename(temp_dir)\n            assert basename.startswith(\"aio_\")\n            assert basename.endswith(\"_tmp\")\n\n    async def test_temporary_directory_in_parent(self, tmp_path):\n        \"\"\"Test TemporaryDirectory in a specific parent directory.\"\"\"\n        async with aiofiles.tempfile.TemporaryDirectory(\n            dir=str(tmp_path)\n        ) as temp_dir:\n            parent = os.path.dirname(temp_dir)\n            assert parent == str(tmp_path)\n\n    async def test_temporary_directory_name_property(self):\n        \"\"\"Test name property on AsyncTemporaryDirectory.\"\"\"\n        import aiofiles.tempfile.temptypes as temptypes\n        async with aiofiles.tempfile.TemporaryDirectory() as temp_dir:\n            # The context manager returns the name string\n            assert isinstance(temp_dir, str)\n\n    async def test_temporary_directory_cleanup_explicit(self):\n        \"\"\"Test explicit cleanup call.\"\"\"\n        import aiofiles.tempfile.temptypes as temptypes\n        import tempfile as std_tempfile\n\n        dir_obj = std_tempfile.TemporaryDirectory()\n        async_dir = temptypes.AsyncTemporaryDirectory(dir_obj)\n        assert async_dir.name == dir_obj.name\n        await async_dir.cleanup()\n        assert not os.path.exists(dir_obj.name)\n\n    async def test_temporary_directory_with_exception(self):\n        \"\"\"Test TemporaryDirectory cleanup even on exception.\"\"\"\n        temp_dir = None\n        try:\n            async with aiofiles.tempfile.TemporaryDirectory() as temp_dir:\n                raise ValueError(\"test\")\n        except ValueError:\n            pass\n        assert not os.path.exists(temp_dir)\nENDOFFILE"}
