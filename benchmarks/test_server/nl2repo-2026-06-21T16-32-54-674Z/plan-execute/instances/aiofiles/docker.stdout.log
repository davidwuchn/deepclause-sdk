    await asyncio.gather(*tasks)\n\n        for i in range(10):\n            fpath = str(tmp_path / f\"out{i}.txt\")\n            with open(fpath, \"r\") as f:\n                assert f.read() == f\"data_{i}\"\n\n    async def test_concurrent_read_write(self, tmp_path):\n        \"\"\"Test concurrent read and write operations.\"\"\"\n        fpath = str(tmp_path / \"rw_test.txt\")\n        async with aiofiles.open(fpath, \"w\") as f:\n            await f.write(\"Initial content\\n\")\n\n        async def read_all():\n            async with aiofiles.open(fpath, \"r\") as f:\n                return await f.read()\n\n        async def append_line():\n            async with aiofiles.open(fpath, \"a\") as f:\n                await f.write(\"Appended\\n\")\n\n        # Write then read concurrently\n        tasks = [\n            asyncio.create_task(append_line()),\n            asyncio.create_task(append_line()),\n        ]\n        await asyncio.gather(*tasks)\n\n        result = await read_all()\n        assert \"Initial content\" in result\n        assert result.count(\"Appended\") == 2\n\n\nclass TestConcurrentMixed:\n    \"\"\"Test mixed concurrent operations.\"\"\"\n\n    async def test_concurrent_text_and_binary(self, tmp_path):\n        \"\"\"Test concurrent text and binary file operations.\"\"\"\n        text_path = str(tmp_path / \"mixed.txt\")\n        bin_path = str(tmp_path / \"mixed.bin\")\n\n        async def write_text():\n            async with aiofiles.open(text_path, \"w\") as f:\n                await f.write(\"text data\")\n\n        async def write_binary():\n            async with aiofiles.open(bin_path, \"wb\") as f:\n                await f.write(b\"binary data\")\n\n        await asyncio.gather(write_text(), write_binary())\n\n        with open(text_path, \"r\") as f:\n            assert f.read() == \"text data\"\n        with open(bin_path, \"rb\") as f:\n            assert f.read() == b\"binary data\"\n\n    async def test_gather_with_errors(self, tmp_path):\n        \"\"\"Test error handling in concurrent operations.\"\"\"\n        fpath = str(tmp_path / \"error_test.txt\")\n        async with aiofiles.open(fpath, \"w\") as f:\n            await f.write(\"ok\")\n\n        async def good_read():\n            async with aiofiles.open(fpath, \"r\") as f:\n                return await f.read()\n\n        async def bad_read():\n            async with aiofiles.open(\"/nonexistent\", \"r\") as f:\n                return await f.read()\n\n        results = await asyncio.gather(\n            good_read(),\n            bad_read(),\n            return_exceptions=True,\n        )\n        assert results[0] == \"ok\"\n        assert isinstance(results[1], FileNotFoundError)\n\n    async def test_semaphore_controlled(self, tmp_path):\n        \"\"\"Test using semaphore to control concurrency.\"\"\"\n        async def bounded_write(i, sem):\n            async with sem:\n                fpath = str(tmp_path / f\"sem{i}.txt\")\n                async with aiofiles.open(fpath, \"w\") as f:\n                    await f.write(f\"bounded {i}\")\n\n        sem = asyncio.Semaphore(2)\n        tasks = [asyncio.create_task(bounded_write(i, sem)) for i in range(10)]\n        await asyncio.gather(*tasks)\n\n        for i in range(10):\n            fpath = str(tmp_path / f\"sem{i}.txt\")\n            with open(fpath, \"r\") as f:\n                assert f.read() == f\"bounded {i}\"\n\n    async def test_task_group(self, tmp_path):\n        \"\"\"Test with asyncio.TaskGroup (if available).\"\"\"\n        fpath = str(tmp_path / \"tg_test.txt\")\n        async with aiofiles.open(fpath, \"w\") as f:\n            await f.write(\"TaskGroup test\\n\")\n\n        results = []\n\n        async def read_and_store():\n            async with aiofiles.open(fpath, \"r\") as f:\n                content = await f.read()\n                results.append(content)\n\n        # Use gather since TaskGroup may not be available in all Python 3.9+\n        await asyncio.gather(read_and_store(), read_and_store())\n        assert len(results) == 2\n        assert all(\"TaskGroup test\" in r for r in results)\nENDOFFILE"}
