[log] bash[433] stdout """Utility functions and decorators for building async file wrappers.
[log] bash[433] stdout Provides class decorators and helper functions used to construct the
[log] bash[433] stdout various asynchronous file wrapper classes in aiofiles. These decorators
[log] bash[433] stdout automatically wrap synchronous file operations so they execute in a
[log] bash[433] stdout thread pool executor without blocking the asyncio event loop.
[log] bash[433] stdout """
[log] bash[433] stdout import asyncio
[log] bash[433] stdout from functools import wraps
[log] bash[433] stdout from typing import Any, Callable
[log] bash[433] stdout # ---------------------------------------------------------------------------
[log] bash[433] stdout # Helper functions that generate methods / properties
[log] bash[433] stdout # ---------------------------------------------------------------------------
[log] bash[433] stdout def _make_delegate_method(attr_name: str) -> Callable:
[log] bash[433] stdout     """Create an async method that delegates a call to the underlying file
[log] bash[433] stdout     object via *self._loop.run_in_executor*.
[log] bash[433] stdout     Args:
[log] bash[433] stdout         attr_name: The name of the attribute (method) on the underlying
[log] bash[433] stdout             file object to delegate to.
[log] bash[433] stdout     Returns:
[log] bash[433] stdout         An async method suitable for assignment to the wrapper class.
[log] bash[433] stdout     """
[log] bash[433] stdout     async def method(self, *args, **kwargs):
[log] bash[433] stdout         loop = self._loop
[log] bash[433] stdout         func = getattr(self._file, attr_name)
[log] bash[433] stdout         return await loop.run_in_executor(self._executor, func, *args, **kwargs)
[log] bash[433] stdout     method.__name__ = attr_name
[log] bash[433] stdout     return method
[log] bash[433] stdout def _make_proxy_method(attr_name: str) -> Callable:
[log] bash[433] stdout     """Create a synchronous method that directly proxies a call to the
[log] bash[433] stdout     underlying file object.
[log] bash[433] stdout     Used for methods that return non-blocking information (e.g. *fileno*,
[log] bash[433] stdout     *readable*) and should **not** be awaited.
[log] bash[433] stdout     Args:
[log] bash[433] stdout         attr_name: The name of the attribute (method) on the underlying
[log] bash[433] stdout             file object to proxy.
[log] bash[433] stdout     Returns:
