th))\n        names = [e.name for e in entries]\n        assert \"a.txt\" in names\n        assert \"b.txt\" in names\n\n    async def test_scandir_is_file_is_dir(self, tmp_path):\n        \"\"\"Test scandir entry is_file and is_dir.\"\"\"\n        with open(str(tmp_path / \"f.txt\"), \"w\"):\n            pass\n        await aios.mkdir(str(tmp_path / \"subdir\"))\n        entries = await aios.scandir(str(tmp_path))\n        entry_map = {e.name: e for e in entries}\n        assert entry_map[\"f.txt\"].is_file()\n        assert entry_map[\"subdir\"].is_dir()\n\n\nclass TestAccess:\n    \"\"\"Test async access operations.\"\"\"\n\n    async def test_access_readable(self, sample_text_file):\n        \"\"\"Test access for read permission.\"\"\"\n        result = await aios.access(sample_text_file, os.R_OK)\n        assert result is True\n\n    async def test_access_writable(self, tmp_path):\n        \"\"\"Test access for write permission.\"\"\"\n        fpath = str(tmp_path / \"access.txt\")\n        with open(fpath, \"w\"):\n            pass\n        result = await aios.access(fpath, os.W_OK)\n        assert result is True\n\n    async def test_access_nonexistent(self):\n        \"\"\"Test access on nonexistent file.\"\"\"\n        result = await aios.access(\"/nonexistent_xyz\", os.F_OK)\n        assert result is False\n\n\nclass TestSymlink:\n    \"\"\"Test async symbolic link operations.\"\"\"\n\n    async def test_symlink(self, tmp_path):\n        \"\"\"Test creating a symbolic link.\"\"\"\n        target = str(tmp_path / \"target.txt\")\n        link = str(tmp_path / \"link.txt\")\n        with open(target, \"w\") as f:\n            f.write(\"content\")\n        await aios.symlink(target, link)\n        assert os.path.islink(link)\n\n    async def test_readlink(self, tmp_path):\n        \"\"\"Test reading a symbolic link.\"\"\"\n        target = str(tmp_path / \"target.txt\")\n        link = str(tmp_path / \"link.txt\")\n        with open(target, \"w\"):\n         