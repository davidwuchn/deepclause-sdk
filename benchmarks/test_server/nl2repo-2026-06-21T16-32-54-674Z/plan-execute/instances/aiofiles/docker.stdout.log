[AGENT] Tool call: run_bash {"arg1":"cat > tests/threadpool/test_open.py << 'ENDOFFILE'\n\"\"\"Tests for async file opening (aiofiles.open).\"\"\"\n\nimport asyncio\nimport pytest\nimport aiofiles\n\n\nclass TestAiofilesOpen:\n    \"\"\"Test the aiofiles.open() function.\"\"\"\n\n    async def test_open_text_read(self, sample_text_file):\n        \"\"\"Test opening and reading a text file.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            content = await f.read()\n        assert content == \"Line 1\\nLine 2\\nLine 3\\n\"\n\n    async def test_open_text_write(self, tmp_path):\n        \"\"\"Test opening and writing to a text file.\"\"\"\n        fpath = str(tmp_path / \"write_test.txt\")\n        async with aiofiles.open(fpath, \"w\") as f:\n            n = await f.write(\"Hello aiofiles\\n\")\n        assert n == 15\n        with open(fpath, \"r\") as f:\n            assert f.read() == \"Hello aiofiles\\n\"\n\n    async def test_open_binary_read(self, sample_binary_file):\n        \"\"\"Test opening and reading a binary file.\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\") as f:\n            data = await f.read()\n        assert data == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_open_binary_write(self, tmp_path):\n        \"\"\"Test opening and writing to a binary file.\"\"\"\n        fpath = str(tmp_path / \"write_test.bin\")\n        async with aiofiles.open(fpath, \"wb\") as f:\n            n = await f.write(b\"\\xde\\xad\\xbe\\xef\")\n        assert n == 4\n        with open(fpath, \"rb\") as f:\n            assert f.read() == b\"\\xde\\xad\\xbe\\xef\"\n\n    async def test_open_append(self, tmp_path):\n        \"\"\"Test append mode.\"\"\"\n        fpath = str(tmp_path / \"append_test.txt\")\n        with open(fpath, \"w\") as f:\n            f.write(\"First line\\n\")\n        async with aiofiles.open(fpath, \"a\") as f:\n            await f.write(\"Second line\\n\")\n        with open(fpath, \"r\") as f:\n            assert f.read() == \"First line\\nSecond line\\n\"\n\n    async def test_open_readplus(self, tmp_path):\n        \"\"\"Test read+write mode (r+).\"\"\"\n        fpath = str(tmp_path / \"rplus_test.txt\")\n        with open(fpath, \"w\") as f:\n            f.write(\"Original\")\n        async with aiofiles.open(fpath, \"r+\") as f:\n            content = await f.read()\n            assert content == \"Original\"\n            await f.write(\" Appended\")\n        with open(fpath, \"r\") as f:\n            assert f.read() == \"Original Appended\"\n\n    async def test_open_wbplus(self, tmp_path):\n        \"\"\"Test wb+ mode.\"\"\"\n        fpath = str(tmp_path / \"wbplus_test.bin\")\n        async with aiofiles.open(fpath, \"wb+\") as f:\n            await f.write(b\"binary data\")\n            await f.seek(0)\n            data = await f.read()\n        assert data == b\"binary data\"\n\n    async def test_open_encoding(self, tmp_path):\n        \"\"\"Test opening with specific encoding.\"\"\"\n        fpath = str(tmp_path / \"utf8_test.txt\")\n        async with aiofiles.open(fpath, \"w\", encoding=\"utf-8\") as f:\n            await f.write(\"Hello 世界\")\n        async with aiofiles.open(fpath, \"r\", encoding=\"utf-8\") as f:\n            content = await f.read()\n        assert content == \"Hello 世界\"\n\n    async def test_open_nonexistent_raises(self):\n        \"\"\"Test that opening a nonexistent file raises FileNotFoundError.\"\"\"\n        with pytest.raises(FileNotFoundError):\n            async with aiofiles.open(\"/nonexistent/path/file.txt\", \"r\"):\n                pass\n\n    async def test_open_buffering_zero(self, sample_binary_file):\n        \"\"\"Test opening with buffering=0 (raw FileIO).\"\"\"\n        async with aiofiles.open(sample_binary_file, \"rb\", buffering=0) as f:\n            # With buffering=0, we get AsyncFileIO\n            data = await f.read()\n        assert data == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_open_returns_context_manager(self, sample_text_file):\n        \"\"\"Test that aiofiles.open returns a context manager.\"\"\"\n        cm = aiofiles.open(sample_text_file, \"r\")\n        # Should be an AiofilesContextManager\n        assert hasattr(cm, \"__aenter__\")\n        assert hasattr(cm, \"__aexit__\")\n        # Also has __await__\n        assert hasattr(cm, \"__await__\")\n\n    async def test_open_file_closed_on_exit(self, sample_text_file):\n        \"\"\"Test that file is properly closed on context manager exit.\"\"\"\n        async with aiofiles.open(sample_text_file, \"r\") as f:\n            await f.read()\n            assert not f.closed\n        assert f.closed\n\n    async def test_open_close_on_exception(self, sample_text_file):\n        \"\"\"Test that file is closed even when an exception occurs.\"\"\"\n        try:\n            async with aiofiles.open(sample_text_file, \"r\") as f:\n                raise ValueError(\"test exception\")\n        except ValueError:\n            pass\n        assert f.closed\nENDOFFILE"}
