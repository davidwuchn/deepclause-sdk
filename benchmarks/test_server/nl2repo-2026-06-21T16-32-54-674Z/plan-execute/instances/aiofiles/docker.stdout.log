[log] bash[119] stdout         else:
[log] bash[119] stdout             func = getattr(self._file, attr_name)
[log] bash[119] stdout             return func(*args, **kwargs)
[log] bash[119] stdout     method.__name__ = attr_name
[log] bash[119] stdout     return method
[log] bash[119] stdout # ---------------------------------------------------------------------------
[log] bash[119] stdout # Class decorators
[log] bash[119] stdout # ---------------------------------------------------------------------------
[log] bash[119] stdout def delegate_to_executor(*attrs: str) -> Callable[[type], type]:
[log] bash[119] stdout     """Class decorator that replaces synchronous methods on *attrs* with
