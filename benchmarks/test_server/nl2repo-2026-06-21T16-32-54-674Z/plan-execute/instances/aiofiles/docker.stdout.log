    # preview = await f.peek(10)
    # Output: bytes object preview without moving file pointer

# Reading a raw binary file (FileIO)
async with aiofiles.open('test.bin', 'rb', buffering=0) as f:
    # readall() - only for FileIO/RawIOBase
