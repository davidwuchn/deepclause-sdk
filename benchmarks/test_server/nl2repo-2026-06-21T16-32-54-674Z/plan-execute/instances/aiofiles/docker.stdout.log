[log] bash[119] stdout     """
[log] bash[119] stdout     def cls_builder(cls):
[log] bash[119] stdout         for attr in attrs:
[log] bash[119] stdout             setattr(cls, attr, _make_delegate_method(attr))
[log] bash[119] stdout         return cls
[log] bash[119] stdout     return cls_builder
