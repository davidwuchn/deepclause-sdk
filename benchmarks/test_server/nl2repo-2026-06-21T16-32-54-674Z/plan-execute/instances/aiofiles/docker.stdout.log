data here\"\n\n    async def test_wrap_bytesio_write(self):\n        \"\"\"Test writing through wrapped binary file.\"\"\"\n        binary_file = io.BytesIO()\n        async_file = wrap(binary_file)\n        n = await async_file.write(b\"test\")\n        assert n == 4\n        binary_file.seek(0)\n        assert binary_file.read() == b\"test\"\n\n    async def test_wrap_fileio(self, sample_binary_file):\n        \"\"\"Test wrapping a FileIO object.\"\"\"\n        with io.FileIO(sample_binary_file, \"rb\") as raw:\n            async_file = wrap(raw)\n            data = await async_file.readall()\n        assert data == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_wrap_bufferedreader(self, sample_binary_file):\n        \"\"\"Test wrapping a BufferedReader.\"\"\"\n        with open(sample_binary_file, \"rb\") as raw:\n            buffered = io.BufferedReader(raw)\n            async_file = wrap(buffered)\n            data = await async_file.read()\n        assert data == b\"\\x00\\x01\\x02\\x03\\x04\\x05\"\n\n    async def test_wrap_bufferedwriter(self, tmp_path):\n        \"\"\"Test wrapping a BufferedWriter.\"\"\"\n        fpath = str(tmp_path / \"bufwrite.bin\")\n        raw = io.open(fpath, \"wb\", buffering=0)\n        buffered = io.BufferedWriter(raw)\n        async_file = wrap(buffered)\n        await async_file.write(b\"hello\")\n        await async_file.flush()\n        buffered.detach()\n        with open(fpath, \"rb\") as f:\n            assert f.read() == b\"hello\"\n\n    async def test_wrap_unsupported_raises(self):\n        \"\"\"Test wrapping unsupported type raises TypeError.\"\"\"\n        with pytest.raises(TypeError, match=\"Unsupported IO type\"):\n            wrap(42)\n\n\nclass TestWrapStdio:\n    \"\"\"Test wrapping standard I/O streams.\"\"\"\n\n    async def test_wrap_stdout(self):\n        \"\"\"Test wrapping stdout.\"\"\"\n        saved = io.stdout\n        io.stdout = io.StringIO()\n        try:\n            async_file = wrap(io.stdout)\n            await async_file.write(\"test output\")\n            io.stdout.seek(0)\n            assert io.stdout.read() == \"test output\"\n        finally:\n            io.stdout = saved\n\n    async def test_wrap_stdin(self):\n        \"\"\"Test wrapping stdin.\"\"\"\n        saved = io.stdin\n        io.stdin = io.StringIO(\"input data\\n\")\n        try:\n            async_file = wrap(io.stdin)\n            data = await async_file.read()\n            assert data == \"input data\\n\"\n        finally:\n            io.stdin = saved\n\n\nclass TestWrapProperties:\n    \"\"\"Test properties on wrapped objects.\"\"\"\n\n    async def test_wrapped_name(self, sample_text_file):\n        \"\"\"Test name property on wrapped file.\"\"\"\n        with open(sample_text_file, \"r\") as sync_file:\n            async_file = wrap(sync_file)\n            assert async_file.name == sample_text_file\n\n    async def test_wrapped_mode(self, sample_text_file):\n        \"\"\"Test mode property on wrapped file.\"\"\"\n        with open(sample_text_file, \"r\") as sync_file:\n            async_file = wrap(sync_file)\n            assert async_file.mode == \"r\"\n\n    async def test_wrapped_closed(self, sample_text_file):\n        \"\"\"Test closed property on wrapped file.\"\"\"\n        with open(sample_text_file, \"r\") as sync_file:\n            async_file = wrap(sync_file)\n            assert not async_file.closed\nENDOFFILE"}
