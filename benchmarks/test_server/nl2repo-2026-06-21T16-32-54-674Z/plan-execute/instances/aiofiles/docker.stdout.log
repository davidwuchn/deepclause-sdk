n    # Test remove\n    fpath3 = os.path.join(testdir, 'remove_me.txt')\n    real_os.write_text(fpath3, 'gone')\n    await aos.remove(fpath3)\n    print(f'remove: exists={real_os.path.exists(fpath3)}')\n    \n    # Test unlink\n    fpath4 = os.path.join(testdir, 'unlink_me.txt')\n    real_os.write_text(fpath4, 'gone')\n    await aos.unlink(fpath4)\n    print(f'unlink: exists={real_os.path.exists(fpath4)}')\n    \n    # Test rmdir\n    await aos.rmdir(os.path.join(testdir, 'single_dir'))\n    print(f'rmdir ok')\n    \n    # Test removedirs\n    await aos.removedirs(subdir)\n    print(f'removedirs ok: exists={real_os.path.exists(subdir)}')\n    \n    # Test symlink/readlink\n    target = os.path.join(testdir, 'target_file.txt')\n    link_path = os.path.join(testdir, 'mylink')\n    real_os.write_text(target, 'target content')\n    await aos.symlink(target, link_path)\n    resolved = await aos.readlink(link_path)\n    print(f'symlink/readlink: resolved={resolved}')\n    \n    # Test link (hardlink)\n    if hasattr(real_os, 'link'):\n        link2 = os.path.join(testdir, 'hardlink')\n        await aos.link(target, link2)\n        print(f'link: exists={real_os.path.exists(link2)}')\n    \n    # Test scandir\n    entries = [e.name for e in await aos.scandir(testdir)]\n    print(f'scandir: {entries}')\n    \n    # Test renames\n    old_deep = os.path.join(testdir, 'old', 'deep', 'file.txt')\n    new_deep = os.path.join(testdir, 'new', 'deep', 'file.txt')\n    real_os.makedirs(os.path.dirname(old_deep))\n    real_os.write_text(old_deep, 'deep content')\n    await aos.renames(old_deep, new_deep)\n    print(f'renames: exists={real_os.path.exists(new_deep)}')\n    \n    shutil.rmtree(testdir)\n    print()\n    print('ALL TESTS PASSED')\n\nasyncio.run(test())\n\"\n"}
