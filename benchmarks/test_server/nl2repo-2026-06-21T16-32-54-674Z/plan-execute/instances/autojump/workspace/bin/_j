#!/usr/bin/env bash
# _j - internal helper script for autojump
# This script is called by the shell functions (j, jc, jo, jco) to perform
# the actual directory lookup and change. It should NOT be called directly
# by the user; instead, use the shell functions provided by autojump.bash,
# autojump.zsh, etc.

# Locate the autojump binary
if [ -n "$AUTOJUMP_HOME" ] && [ -d "$AUTOJUMP_HOME" ]; then
    _AUTOJUMP_BIN="${AUTOJUMP_HOME}/bin/autojump"
elif [ -n "$AUTOJUMP_BIN" ]; then
    _AUTOJUMP_BIN="$AUTOJUMP_BIN"
elif [ -n "$AUTOJUMP" ] && [ -f "$AUTOJUMP" ]; then
    _AUTOJUMP_BIN="$(dirname "$AUTOJUMP")/autojump"
elif type -p autojump > /dev/null 2>&1; then
    _AUTOJUMP_BIN="$(type -p autojump)"
else
    _AUTOJUMP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
    if [ -f "$_AUTOJUMP_DIR/autojump" ]; then
        _AUTOJUMP_BIN="$_AUTOJUMP_DIR/autojump"
    else
        echo "autojump: error - cannot locate autojump binary." >&2
        return 1 2>/dev/null || exit 1
    fi
fi

# If --complete flag is given, delegate to autojump directly
if [ "$1" = "--complete" ]; then
    "$_AUTOJUMP_BIN" "$@"
    return $? 2>/dev/null || exit $?
fi

# Perform the jump
AUTOJUMP_OUTPUT=$("$_AUTOJUMP_BIN" "$@" 2>/dev/null)
_AUTOJUMP_STATUS=$?

if [ $_AUTOJUMP_STATUS -eq 0 ] && [ -n "$AUTOJUMP_OUTPUT" ]; then
    # Check if output is a tab menu entry
    if echo "$AUTOJUMP_OUTPUT" | grep -qE '^\s*\d+\s+'; then
        # Tab menu output – just print it
        printf '%s\n' "$AUTOJUMP_OUTPUT"
        return 0 2>/dev/null || exit 0
    fi
    echo "$AUTOJUMP_OUTPUT"
fi

return $_AUTOJUMP_STATUS 2>/dev/null || exit $_AUTOJUMP_STATUS
