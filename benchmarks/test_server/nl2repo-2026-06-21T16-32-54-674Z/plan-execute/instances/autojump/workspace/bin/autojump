#!/usr/bin/env bash
# autojump - executable wrapper script
# This script acts as the entry point for the autojump command-line tool.
# It locates and invokes the autojump Python module.

# Determine the directory where this script lives
AUTOJUMP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# Find the autojump Python module
if [ -f "$AUTOJUMP_DIR/autojump.py" ]; then
    AUTOJUMP_PY="$AUTOJUMP_DIR/autojump.py"
elif [ -f "/usr/lib/python3/dist-packages/bin/autojump.py" ]; then
    AUTOJUMP_PY="/usr/lib/python3/dist-packages/bin/autojump.py"
elif command -v python3 > /dev/null 2>&1; then
    # Try to find it via the Python path
    AUTOJUMP_PY="$(python3 -c '
import os, sys
# Try bin package in standard locations
for base in ["/usr/lib/python3/dist-packages", "/usr/local/lib/python3/dist-packages",
             "/opt/local/lib/python3/dist-packages"]:
    p = os.path.join(base, "bin", "autojump.py")
    if os.path.exists(p):
        print(p)
        sys.exit(0)
print("")' 2>/dev/null)"
fi

# Fallback: try `python` or `python3` with sys.path discovery
if [ -z "$AUTOJUMP_PY" ] || [ ! -f "$AUTOJUMP_PY" ]; then
    if command -v python3 > /dev/null 2>&1; then
        PYTHON_CMD=python3
    elif command -v python > /dev/null 2>&1; then
        PYTHON_CMD=python
    else
        echo "autojump: error - Python not found. Please install Python 2.6+ or 3.3+." >&2
        exit 1
    fi
    # Use -m to invoke the module
    $PYTHON_CMD -m bin.autojump "$@"
    exit $?
fi

# Determine which python to use
if command -v python3 > /dev/null 2>&1; then
    PYTHON_CMD=python3
elif command -v python > /dev/null 2>&1; then
    PYTHON_CMD=python
else
    echo "autojump: error - Python not found." >&2
    exit 1
fi

# Prepend the autojump directory to PYTHONPATH so we can find bin.autojump
AUTOJUMP_PY_DIR="$(dirname "$AUTOJUMP_PY")"
AUTOJUMP_PKG_DIR="$(dirname "$AUTOJUMP_PY_DIR")"
export PYTHONPATH="${AUTOJUMP_PKG_DIR}:${PYTHONPATH}"

exec $PYTHON_CMD "$AUTOJUMP_PY" "$@"
