tool(run_bash(Command, Output), "Run a shell command in the workspace. Use cat to read files, use heredocs to write files: cat > path/to/file.py << 'ENDOFFILE'\ncode here\nENDOFFILE\nUse mkdir -p before writing to new directories. Use ls to list directories.") :-
    exec(bash(command: Command), Output).

agent_main :-
    exec(bash(command: 'cat start.md'), SpecResult),
    get_dict(stdout, SpecResult, SpecContent),
    format(string(SysPrompt), "You are an expert Python developer. You MUST implement a complete library from the specification below.\n\nCRITICAL RULES:\n1. Start coding IMMEDIATELY. The full specification is below — do NOT re-read start.md.\n2. Use run_bash for EVERYTHING: write files with heredocs, run commands.\n3. To write a file: run_bash with: mkdir -p dirname && cat > filepath << 'ENDOFFILE'\n... file content ...\nENDOFFILE\n4. NEVER call write_file_content or read_file_content — they do not exist.\n5. After writing each file, verify it with cat or python -c 'import module'.\n6. Work autonomously. No user interaction. No web_search, news_search, url_fetch, or create_skill.\n7. If a task seems unclear, make reasonable assumptions and implement anyway.\n8. DO NOT spend more than 2 iterations reading. By iteration 3 you MUST be writing code.\n9. At the end of each task, briefly summarize what you did and what is left to do. This summary carries forward to the next task.\n\n--- BEGIN SPECIFICATION ---\n~w\n--- END SPECIFICATION ---", [SpecContent]),
    system(SysPrompt),
    task("Set up the project directory structure with all necessary subdirectories and __init__.py files for bin/, docs/, and tools/.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum1)),
    task("Create pyproject.toml to make the project installable with proper metadata and dependencies.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum2)),
    task("Implement bin/autojump_utils.py with utility functions including create_dir, encode_local, unico, print_local, has_uppercase, surround_quotes, is_python2, is_python3, is_linux, is_osx, is_windows, in_bash, is_autojump_sourced, get_pwd, sanitize, print_entry, move_file, get_tab_entry_info, print_tab_menu, first, second, last, and take.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum3)),
    task("Implement bin/autojump_data.py with Entry namedtuple, BACKUP_THRESHOLD constant, load function for reading database, save function for atomic writes with backup, dictify and entriefy conversion functions, load_backup function, and migrate_osx_xdg_data function.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum4)),
    task("Implement bin/autojump_match.py with match_anywhere function for matching patterns at any position, match_consecutive function for consecutive character matching at path end, and match_fuzzy function for edit-distance based fuzzy matching with threshold control.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum5)),
    task("Implement bin/autojump_argparse.py with constants SUPPRESS, OPTIONAL, ZERO_OR_MORE, ONE_OR_MORE, PARSER, REMAINDER, and _UNRECOGNIZED_ARGS_ATTR, plus helper functions _callable, _ensure_value, and _get_action_name.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum6)),
    task("Implement bin/autojump_argparse.py base classes including _AttributeHolder with __repr__ and _get_kwargs methods, Namespace class with attribute storage and equality methods, ArgumentError and ArgumentTypeError exception classes, and FileType class for file argument handling.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum7)),
    task("Implement bin/autojump_argparse.py Action base class and all action subclasses including _StoreAction, _StoreConstAction, _StoreTrueAction, _StoreFalseAction, _AppendAction, _AppendConstAction, _CountAction, _HelpAction, _VersionAction, and _SubParsersAction.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum8)),
    task("Implement bin/autojump_argparse.py HelpFormatter class with all formatting methods including _indent, _dedent, start_section, end_section, add_text, add_usage, add_argument, add_arguments, format_help, _format_action, _format_text, _split_lines, _fill_text, and _get_help_string.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum9)),
    task("Implement bin/autojump_argparse.py specialized formatters including RawDescriptionHelpFormatter, RawTextHelpFormatter, and ArgumentDefaultsHelpFormatter classes.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum10)),
    task("Implement bin/autojump_argparse.py container classes including _ActionsContainer with register, set_defaults, add_argument, add_argument_group, add_mutually_exclusive_group, _add_action, _remove_action, and conflict handling methods.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum11)),
    task("Implement bin/autojump_argparse.py group classes including _ArgumentGroup and _MutuallyExclusiveGroup with their respective _add_action and _remove_action methods.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum12)),
    task("Implement bin/autojump_argparse.py ArgumentParser class with full argument parsing capability including __init__, parse_args, parse_known_args, format_help, format_usage, print_help, error, exit, _parse_known_args, _parse_optional, _get_values, and _get_formatter methods.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum13)),
    task("Implement bin/autojump.py with constants VERSION, FUZZY_MATCH_THRESHOLD, TAB_ENTRIES_COUNT, TAB_SEPARATOR, and functions set_defaults, parse_arguments, add_path, decrease_path, detect_smartcase, find_matches, handle_tab_completion, purge_missing_paths, print_stats, and main.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum14)),
    task("Create install.py with constants SUPPORTED_SHELLS, functions cp, mkdir, modify_autojump_sh, modify_autojump_lua, show_post_installation_message, get_shell, parse_arguments, and main for installation handling.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum15)),
    task("Create uninstall.py with functions rm, rmdir, is_empty_dir, remove_custom_installation, remove_system_installation, remove_user_data, remove_user_installation, parse_arguments, and main for uninstallation handling.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum16)),
    task("Create shell integration scripts including autojump.bash, autojump.zsh, autojump.fish, and autojump.tcsh with j, jc, jo shell functions and tab completion support.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum17)),
    task("Create the autojump executable script and _j helper script in the bin directory, plus batch files autojump.bat, j.bat, jc.bat, jco.bat, and jo.bat for Windows support.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum18)),
    task("Create tools/autojump_ipython.py with the j() magic function for IPython directory jumping.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum19)),
    task("Create project documentation files including README.md, LICENSE, Makefile, tox.ini, .gitignore, .gitattributes, .travis.yml, AUTHORS, CHANGES.md, and documentation files in docs/.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum20)),
    task("Write comprehensive tests covering database load/save operations, all matching algorithms (anywhere, consecutive, fuzzy), utility functions, argument parsing, and the main autojump workflow.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum21)),
    task("Install the package in development mode and run the full test suite, fixing any failures until all tests pass.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum22)),
    task("Create pyproject.toml or setup.py so the project is installable with pip install -e. Store a summary in the output variable.", string(SumPyproj)),
    task("Install the package with pip install -e . and verify basic imports work. Store a summary in the output variable.", string(SumInstall)),
    task("Run the full test suite and fix any failures until all tests pass. Store a summary in the output variable.", string(SumTests)),
    answer("Done.").

agent_main :-
    answer("Failed.").
