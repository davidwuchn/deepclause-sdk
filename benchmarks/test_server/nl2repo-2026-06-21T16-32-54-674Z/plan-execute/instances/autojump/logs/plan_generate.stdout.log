[log] bash[68] stdout     def add_text(self, text) """Add text to the current section."""
[log] bash[68] stdout     def add_usage(self, usage, actions, groups, prefix=None) """Add usage information to the help."""
[log] bash[68] stdout     def add_argument(self, action) """Add argument help for a single action."""  
[log] bash[68] stdout     def add_arguments(self, actions) """Add argument help for multiple actions."""
[log] bash[68] stdout     def format_help(self) """Format and return the help text."""
[log] bash[68] stdout     def _join_parts(self, part_strings) """Join help text parts."""  
[log] bash[68] stdout     def _format_usage(self, usage, actions, groups, prefix) """Format usage information."""   
[log] bash[68] stdout     def _format_action(self, action) """Format a single action's help."""  
