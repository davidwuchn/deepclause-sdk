[log] bash[68] stdout     def _format_args(self, action, default_metavar) """Format argument strings.""" 
[log] bash[68] stdout     def _expand_help(self, action) """Expand help text for an action.""" 
[log] bash[68] stdout     def _iter_indented_subactions(self, action) """Iterate over indented subactions."""   
[log] bash[68] stdout     def _split_lines(self, text, width) """Split text into lines of specified width.""" 
[log] bash[68] stdout     def _fill_text(self, text, width, indent) """Fill text to specified width with indentation."""   
[log] bash[68] stdout     def _get_help_string(self, action) """Get help string for an action."""
[log] bash[68] stdout ```
