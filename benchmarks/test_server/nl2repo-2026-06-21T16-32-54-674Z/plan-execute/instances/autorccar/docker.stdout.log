[AGENT] Tool call: run_bash {"arg1":"cat > /workspace/computer/rc_driver.py << 'ENDOFFILE'\n\"\"\"\nAutoRCCar - RC Driver Main Module\n\nMain entry point for the autonomous driving program. Imports neural network\nmodel and control functions from model and rc_driver_helper modules.\n\"\"\"\n\nimport os\nimport sys\nimport socket\nimport socketserver\nimport threading\nimport time\n\nimport cv2\nimport numpy as np\n\nfrom model import NeuralNetwork, load_data\nfrom rc_driver_helper import RCControl, DistanceToCamera, ObjectDetection\n\n\nclass Server:\n    \"\"\"\n    Configure the connection parameters and port settings of the network server.\n\n    Args:\n        host (str): Server host address, e.g., \"192.168.1.100\".\n        port1 (int): Video stream server port, default 8000.\n        port2 (int): Sensor data server port, default 8002.\n    \"\"\"\n\n    def __init__(self, host, port1, port2):\n        self.host = host\n        self.port1 = port1\n        self.port2 = port2\n        self.video_server = None\n        self.sensor_server = None\n\n    def start(self):\n        \"\"\"Start both video stream and sensor data servers.\"\"\"\n        self.video_server = socketserver.TCPServer((self.host, self.port1), VideoStreamHandler)\n        self.sensor_server = socketserver.TCPServer((self.host, self.port2), SensorDataHandler)\n\n        video_thread = threading.Thread(target=self._serve_video)\n        sensor_thread = threading.Thread(target=self._serve_sensor)\n        video_thread.daemon = True\n        sensor_thread.daemon = True\n\n        video_thread.start()\n        sensor_thread.start()\n\n        print(f\"Video stream server started on {self.host}:{self.port1}\")\n        print(f\"Sensor data server started on {self.host}:{self.port2}\")\n\n        # Keep main thread alive\n        try:\n            while True:\n                time.sleep(1)\n        except KeyboardInterrupt:\n            print(\"Server stopped.\")\n\n    def _serve_video(self):\n        \"\"\"Serve video stream connections.\"\"\"\n        self.video_server.serve_forever()\n\n    def _serve_sensor(self):\n        \"\"\"Serve sensor data connections.\"\"\"\n        self.sensor_server.serve_forever()\n\n\nclass VideoStreamHandler(socketserver.StreamRequestHandler):\n    \"\"\"\n    Configure the parameters and threshold settings of the video stream processor.\n    \"\"\"\n    # Object height parameters (manually measured)\n    h1 = 5.5   # Stop sign height (cm)\n    h2 = 5.5   # Traffic light height (cm)\n\n    # Distance threshold configuration\n    d_sensor_thresh = 30      # Ultrasonic sensor stop threshold (cm)\n    d_stop_light_thresh = 25  # Stop sign and traffic light stop threshold (cm)\n\n    # Time control parameters\n    stop_start = 0\n    stop_finish = 0\n    stop_time = 0\n    drive_time_after_stop = 0\n\n    # Shared sensor data attribute\n    latest_sensor_data = None\n\n    def handle(self):\n        \"\"\"Handle incoming video stream connection.\"\"\"\n        nn = NeuralNetwork()\n        model_path = os.path.join(os.path.dirname(__file__), '..', 'saved_model', 'nn_model.xml')\n        if os.path.exists(model_path):\n            try:\n                nn.load_model(model_path)\n                print(\"Model loaded successfully.\")\n            except Exception as e:\n                print(f\"Warning: Could not load model: {e}\")\n\n        obj_detection = ObjectDetection()\n        d_to_camera = DistanceToCamera()\n        rc_car = RCControl(\"/dev/tty.usbmodem1421\")\n\n        stop_cascade = cv2.CascadeClassifier(\n            os.path.join(os.path.dirname(__file__), 'cascade_xml', 'stop_sign.xml'))\n        light_cascade = cv2.CascadeClassifier(\n            os.path.join(os.path.dirname(__file__), 'cascade_xml', 'traffic_light.xml'))\n\n        stream_bytes = b' '\n        stop_flag = False\n        stop_sign_active = False\n\n        while True:\n            try:\n                stream_bytes += self.rfile.read(1024)\n            except Exception:\n                break\n\n            first = stream_bytes.find(b'\\xff\\xd8')\n            last = stream_bytes.find(b'\\xff\\xd9')\n\n            if first != -1 and last != -1:\n                jpg = stream_bytes[first:last + 2]\n                stream_bytes = stream_bytes[last + 2:]\n\n                gray = cv2.imdecode(np.frombuffer(jpg, dtype=np.uint8), cv2.IMREAD_GRAYSCALE)\n                image = cv2.imdecode(np.frombuffer(jpg, dtype=np.uint8), cv2.IMREAD_COLOR)\n\n                if gray is None or image is None:\n                    continue\n\n                # Lower half of the image (ROI)\n                height, width = gray.shape\n                roi = gray[int(height / 2):height, :]\n\n                # Reshape for neural network\n                image_array = roi.reshape(1, int(height / 2) * width).astype(np.float32)\n\n                # Object detection\n                v_param1 = obj_detection.detect(stop_cascade, gray, image)\n                v_param2 = obj_detection.detect(light_cascade, gray, image)\n\n                # Distance measurement\n                if v_param1 > 0 or v_param2 > 0:\n                    d1 = d_to_camera.calculate(v_param1, self.h1, 300, image)\n                    d2 = d_to_camera.calculate(v_param2, self.h2, 100, image)\n                    self.d_stop_sign = d1\n                    self.d_light = d2\n                else:\n                    self.d_stop_sign = self.d_stop_light_thresh\n                    self.d_light = self.d_stop_light_thresh\n\n                sensor_data = self.latest_sensor_data\n\n                # Autonomous driving decision logic\n                if sensor_data and int(sensor_data) < self.d_sensor_thresh:\n                    print(\"Stop, obstacle in front\")\n                    rc_car.stop()\n                    self.latest_sensor_data = None\n\n                elif (0 < self.d_stop_sign < self.d_stop_light_thresh and\n                      stop_sign_active):\n                    print(\"Stop sign ahead\")\n                    rc_car.stop()\n\n                    if not stop_flag:\n                        self.stop_start = cv2.getTickCount()\n                        stop_flag = True\n                    self.stop_finish = cv2.getTickCount()\n                    self.stop_time = (self.stop_finish - self.stop_start) / cv2.getTickFrequency()\n                    print(\"Stop time: %.2fs\" % self.stop_time)\n\n                    if self.stop_time > 5:\n                        print(\"Waited for 5 seconds\")\n                        stop_flag = False\n                        stop_sign_active = False\n                elif 0 < self.d_stop_sign < self.d_stop_light_thresh:\n                    stop_sign_active = True\n\n                elif 0 < self.d_light < self.d_stop_light_thresh:\n                    if obj_detection.red_light:\n                        print(\"Red light\")\n                        rc_car.stop()\n                    elif obj_detection.green_light:\n                        print(\"Green light\")\n                        pass\n                    elif obj_detection.yellow_light:\n                        print(\"Yellow light flashing\")\n                        pass\n\n                    self.d_light = self.d_stop_light_thresh\n                    obj_detection.red_light = False\n                    obj_detection.green_light = False\n                    obj_detection.yellow_light = False\n\n                else:\n                    if hasattr(nn, 'mlpc') and nn.mlpc is not None:\n                        prediction = nn.predict(image_array)\n                        rc_car.steer(prediction[0])\n                    self.stop_start = cv2.getTickCount()\n                    self.d_stop_sign = self.d_stop_light_thresh\n\n\nclass SensorDataHandler(socketserver.BaseRequestHandler):\n    \"\"\"\n    Handle ultrasonic sensor data received via TCP connection.\n    \"\"\"\n\n    def handle(self):\n        \"\"\"Receive and process sensor data.\"\"\"\n        while True:\n            try:\n                data = self.request.recv(1024)\n                if not data:\n                    break\n                sensor_value = int(data.decode().strip())\n                VideoStreamHandler.latest_sensor_data = sensor_value\n                print(f\"Sensor data received: {sensor_value}cm\")\n            except (ValueError, UnicodeDecodeError):\n                pass\n            except Exception:\n                break\n\n\nif __name__ == '__main__':\n    h, p1, p2 = \"192.168.1.100\", 8000, 8002\n\n    ts = Server(h, p1, p2)\n    ts.start()\nENDOFFILE\necho \"rc_driver.py written successfully\""}
