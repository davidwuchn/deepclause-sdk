[log] bash[1642] stdout def load_data(input_size, path):
[log] bash[1642] stdout     """
[log] bash[1642] stdout     Load training data from npz files and split into training/validation sets.
[log] bash[1642] stdout     Args:
[log] bash[1642] stdout         input_size (int): The size of the input image (number of pixels).
[log] bash[1642] stdout         path (str): Path to training data files, supporting glob pattern matching.
[log] bash[1642] stdout     Returns:
[log] bash[1642] stdout         tuple: (X_train, X_test, y_train, y_test) - Training and validation data.
[log] bash[1642] stdout     """
[log] bash[1642] stdout     files = sorted(glob.glob(path))
[log] bash[1642] stdout     if not files:
[log] bash[1642] stdout         raise FileNotFoundError(f"No training data files found matching: {path}")
[log] bash[1642] stdout     X_list = []
[log] bash[1642] stdout     y_list = []
[log] bash[1642] stdout     for f in files:
[log] bash[1642] stdout         try:
[log] bash[1642] stdout             data = np.load(f)
[log] bash[1642] stdout             image_data = data['image'].astype(np.float32)
[log] bash[1642] stdout             label_data = data['label'].astype(np.float32)
[log] bash[1642] stdout         except (KeyError, Exception) as e:
[log] bash[1642] stdout             print(f"Warning: Skipping malformed file {f}: {e}")
[log] bash[1642] stdout             continue
[log] bash[1642] stdout         # Normalize to [0, 1]
[log] bash[1642] stdout         if image_data.max() > 1.0:
[log] bash[1642] stdout             image_data = image_data / 255.0
[log] bash[1642] stdout         # Handle input size mismatch
[log] bash[1642] stdout         current_size = image_data.shape[1] if image_data.ndim > 1 else image_data.size
[log] bash[1642] stdout         if current_size < input_size:
[log] bash[1642] stdout             pad = np.zeros((image_data.shape[0], input_size - current_size), dtype=np.float32)
[log] bash[1642] stdout             image_data = np.hstack([image_data, pad])
[log] bash[1642] stdout         elif current_size > input_size:
[log] bash[1642] stdout             image_data = image_data[:, :input_size]
[log] bash[1642] stdout         # Convert integer labels to one-hot encoding
[log] bash[1642] stdout         if label_data.shape[1] == 1:
[log] bash[1642] stdout             int_labels = label_data[:, 0].astype(int)
[log] bash[1642] stdout             one_hot = np.zeros((label_data.shape[0], 4), dtype=np.float32)
[log] bash[1642] stdout             for i, label in enumerate(int_labels):
[log] bash[1642] stdout                 if 0 <= label < 4:
[log] bash[1642] stdout                     one_hot[i, label] = 1.0
[log] bash[1642] stdout             label_data = one_hot
[log] bash[1642] stdout         X_list.append(image_data)
[log] bash[1642] stdout         y_list.append(label_data)
[log] bash[1642] stdout     X = np.vstack(X_list)
[log] bash[1642] stdout     y = np.vstack(y_list)
[log] bash[1642] stdout     # Shuffle data
[log] bash[1642] stdout     indices = np.random.permutation(X.shape[0])
[log] bash[1642] stdout     X = X[indices]
[log] bash[1642] stdout     y = y[indices]
[log] bash[1642] stdout     # Split 80/20 train/validation
[log] bash[1642] stdout     split = int(0.8 * X.shape[0])
[log] bash[1642] stdout     X_train, X_test = X[:split], X[split:]
[log] bash[1642] stdout     y_train, y_test = y[:split], y[split:]
[log] bash[1642] stdout     return X_train, X_test, y_train, y_test
[log] bash[1642] stdout class NeuralNetwork:
[log] bash[1642] stdout     """
[log] bash[1642] stdout     A neural network model based on OpenCV for autonomous driving decision prediction.
[log] bash[1642] stdout     Uses OpenCV's ANN_MLP with Sigmoid activation and back-propagation training.
