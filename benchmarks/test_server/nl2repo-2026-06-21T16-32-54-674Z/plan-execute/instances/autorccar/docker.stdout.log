[log] bash[1642] stdout         elif layer_sizes.dtype != np.int32:
[log] bash[1642] stdout             layer_sizes = layer_sizes.astype(np.int32)
[log] bash[1642] stdout         self.mlpc = cv2.ml.ANN_MLP_create()
[log] bash[1642] stdout         self.mlpc.setLayerSizes(layer_sizes)
[log] bash[1642] stdout         self.mlpc.setActivationFunction(cv2.ml.ANN_MLP_SIGMOID_SYM)
[log] bash[1642] stdout         self.mlpc.setTrainMethod(cv2.ml.ANN_MLP_BACKPROP, 0.001, 0.1)
[log] bash[1642] stdout         self.mlpc.setTermCriteria((cv2.TERM_CRITERIA_COUNT | cv2.TERM_CRITERIA_EPS, 100, 1e-6))
[log] bash[1642] stdout     def train(self, X, y):
[log] bash[1642] stdout         """
[log] bash[1642] stdout         Train the neural network model.
[log] bash[1642] stdout         Args:
[log] bash[1642] stdout             X (np.ndarray): Training features, shape (n_samples, n_features).
[log] bash[1642] stdout             y (np.ndarray): Training labels, shape (n_samples, n_classes), one-hot encoded.
[log] bash[1642] stdout         Raises:
[log] bash[1642] stdout             RuntimeError: If create() has not been called.
