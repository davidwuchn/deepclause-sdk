[log] bash[163] stdout         """
[log] bash[163] stdout         if self.mlpc is None:
[log] bash[163] stdout             raise RuntimeError("Neural network not created or not loaded.")
[log] bash[163] stdout         if X.dtype != np.float32:
[log] bash[163] stdout             X = X.astype(np.float32)
[log] bash[163] stdout         if y.dtype != np.float32:
[log] bash[163] stdout             y = y.astype(np.float32)
[log] bash[163] stdout         # Get predictions
[log] bash[163] stdout         _, predictions = self.mlpc.predict(X)
[log] bash[163] stdout         # Calculate accuracy by comparing argmax of predictions and labels
[log] bash[163] stdout         predicted_labels = np.argmax(predictions, axis=1)
[log] bash[163] stdout         true_labels = np.argmax(y, axis=1)
[log] bash[163] stdout         accuracy = np.mean(predicted_labels == true_labels)
[log] bash[163] stdout         return float(accuracy)
