ural network predictions\nwithout object detection or sensor fusion.\n\"\"\"\n\nimport os\nimport sys\nimport socket\nimport socketserver\nimport threading\nimport time\n\nimport cv2\nimport numpy as np\n\nfrom model import NeuralNetwork\nfrom rc_driver_helper import RCControl\n\n\nclass NNServer:\n    \"\"\"Server for neural network only driving mode.\"\"\"\n\n    def __init__(self, host, port):\n        self.host = host\n        self.port = port\n\n    def start(self):\n        \"\"\"Start the NN-only video stream server.\"\"\"\n        server = socketserver.TCPServer((self.host, self.port), NNVideoHandler)\n        print(f\"NN-only server started on {self.host}:{self.port}\")\n        server.serve_forever()\n\n\nclass NNVideoHandler(socketserver.StreamRequestHandler):\n    \"\"\"Handle video stream with NN-only predictions.\"\"\"\n\n    def handle(self):\n        nn = NeuralNetwork()\n        model_path = os.path.join(os.path.dirname(__file__), '..', 'saved_model', 'nn_model.xml')\n        if os.path.exists(model_path):\n            nn.load_model(model_path)\n\n        rc_car = RCControl(\"/dev/tty.usbmodem1421\")\n        stream_bytes = b' '\n\n        while True:\n            try:\n                stream_bytes += self.rfile.read(1024)\n            except Exception:\n                break\n\n            first = stream_bytes.find(b'\\xff\\xd8')\n            last = stream_bytes.find(b'\\xff\\xd9')\n\n            if first != -1 and last != -1:\n                jpg = stream_bytes[first:last + 2]\n                stream_bytes = stream_bytes[last + 2:]\n\n                image = cv2.imdecode(np.frombuffer(jpg, dtype=np.uint8), cv2.IMREAD_COLOR)\n                gray = cv2.imdecode(np.frombuffer(jpg, dtype=np.uint8), cv2.IMREAD_GRAYSCALE)\n\n                if gray is None:\n                    continue\n\n                height, width = gray.shape\n                roi = gray[int(height / 2):height, :]\n                image_array = roi.reshape(1, int(height / 2) * width).astype(np.float32)\n\n                prediction = nn.predict(image_array)\n                rc_car.steer(prediction[0])\n\n\nif __name__ == '__main__':\n    h, p = \"192.168.1.100\", 8000\n    ns = NNServer(h, p)\n    ns.start()\nENDOFFILE\n\ncat > /workspace/computer/picam_calibration.py << 'ENDOFFILE'\n\"\"\"\nAutoRCCar - Pi Camera Calibration Module\n\nCalibrates the Raspberry Pi camera using chessboard patterns.\n\"\"\"\n\nimport os\nimport glob\nimport numpy as np\nimport cv2\n\n\ndef calibrate_camera(chess_board_path, output_path):\n    \"\"\"\n    Calibrate the camera using chessboard images.\n\n    Args:\n        chess_board_path (str): Path to chessboard calibration images.\n        output_path (str): Path to save calibration results.\n    \"\"\"\n    # Prepare object points\n    obj_points = []\n    img_points = []\n    objp = np.zeros((6 * 8, 3), np.float32)\n    objp[:, :2] = np.mgrid[0:8, 0:6].T.reshape(-1, 2)\n\n    images = sorted(glob.glob(os.path.join(chess_board_path, '*.jpg')))\n    print(f\"Found {len(images)} calibration images\")\n\n    for img_path in images:\n        img = cv2.imread(img_path)\n        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n\n        ret, corners = cv2.findChessboardCorners(gray, (8, 6), None)\n        if ret:\n            obj_points.append(objp)\n            corners2 = cv2.cornerSubPix(gray, corners, (11, 11), (-1, -1),\n                                        (cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER, 30, 0.001))\n            img_points.append(corners2)\n            print(f\"Calibration corners found in {os.path.basename(img_path)}\")\n\n    if len(obj_points) < 3:\n        print(\"Error: Not enough calibration images with detected corners\")\n        return None\n\n    # Perform calibration\n    ret, camera_matrix, dist_coeffs, rvecs, tvecs = cv2.calibrateCamera(\n        obj_points, img_points, gray.shape[::-1], None, None)\n\n    print(f\"Calibration complete. Re-projection error: {ret}\")\n    print(f\"Camera matrix:\\n{camera_matrix}\")\n    print(f\"Distortion coefficients: {dist_coeffs}\")\n\n    # Save calibration data\n    if output_path:\n        os.makedirs(os.path.dirname(output_path) if os.path.dirname(output_path) else '.', exist_ok=True)\n        np.savez(output_path, camera_matrix=camera_matrix, dist_coeffs=dist_coeffs)\n        print(f\"Calibration saved to {output_path}\")\n\n    return camera_matrix, dist_coeffs\n\n\nif __name__ == '__main__':\n    chess_path = os.path.join(os.path.dirname(__file__), 'chess_board')\n    output_path = os.path.join(os.path.dirname(__file__), '..', 'saved_model', 'camera_calibration.npz')\n    calibrate_camera(chess_path, output_path)\nENDOFFILE\necho \"model_training.py, rc_driver_nn_only.py, picam_calibration.py written\""}
