[log] bash[1642] stdout         if self.mlpc is None:
[log] bash[1642] stdout             raise RuntimeError("Model not created. Call create() before training.")
[log] bash[1642] stdout         if X.dtype != np.float32:
[log] bash[1642] stdout             X = X.astype(np.float32)
[log] bash[1642] stdout         if y.dtype != np.float32:
[log] bash[1642] stdout             y = y.astype(np.float32)
[log] bash[1642] stdout         self.mlpc.train(X, cv2.ml.ROW_SAMPLE, y)
[log] bash[1642] stdout     def evaluate(self, X, y):
[log] bash[1642] stdout         """
[log] bash[1642] stdout         Evaluate model accuracy on test data.
[log] bash[1642] stdout         Args:
[log] bash[1642] stdout             X (np.ndarray): Test features.
[log] bash[1642] stdout             y (np.ndarray): Test labels (one-hot encoded).
[log] bash[1642] stdout         Returns:
[log] bash[1642] stdout             float: Model accuracy between 0 and 1.
[log] bash[1642] stdout         Raises:
[log] bash[1642] stdout             RuntimeError: If create() has not been called.
[log] bash[1642] stdout         """
[log] bash[1642] stdout         if self.mlpc is None:
[log] bash[1642] stdout             raise RuntimeError("Model not created. Call create() before evaluation.")
[log] bash[1642] stdout         if X.dtype != np.float32:
[log] bash[1642] stdout             X = X.astype(np.float32)
[log] bash[1642] stdout         _, predictions = self.mlpc.predict(X)
[log] bash[1642] stdout         pred_classes = np.argmax(predictions, axis=1)
[log] bash[1642] stdout         true_classes = np.argmax(y, axis=1)
[log] bash[1642] stdout         accuracy = np.mean(pred_classes == true_classes)
[log] bash[1642] stdout         return float(accuracy)
[log] bash[1642] stdout     def predict(self, X):
[log] bash[1642] stdout         """
