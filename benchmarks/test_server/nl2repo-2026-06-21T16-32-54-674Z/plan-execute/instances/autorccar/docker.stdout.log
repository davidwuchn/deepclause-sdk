    self.stop_time = (self.stop_finish - self.stop_start) / cv2.getTickFrequency()
    print("Stop time: %.2fs" % self.stop_time)
    
    # 5 seconds later, continue driving
    if self.stop_time > 5:
        print("Waited for 5 seconds")
        stop_flag = False
