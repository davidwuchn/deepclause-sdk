[log] bash[1642] stdout     def create(self, layer_sizes):
[log] bash[1642] stdout         """
[log] bash[1642] stdout         Create the neural network with specified layer architecture.
[log] bash[1642] stdout         Args:
[log] bash[1642] stdout             layer_sizes (np.ndarray or list): Number of nodes per layer,
[log] bash[1642] stdout                 e.g., [76800, 32, 4] for input->hidden->output.
[log] bash[1642] stdout         """
[log] bash[1642] stdout         if not isinstance(layer_sizes, np.ndarray):
