[AGENT] Tool call: run_bash {"arg1":"cd /workspace && cat > computer/model.py << 'ENDOFFILE'\n\"\"\"\nAutoRCCar - Neural Network Model Module\n\nProvides a neural network model based on OpenCV's MLP for autonomous driving\ndecision prediction. Supports image data collection, model training, prediction,\nevaluation, and persistence.\n\nModel architecture: fully connected network 76800->32->4\nActivation: Sigmoid\nTraining: Back-propagation\n\"\"\"\n\nimport os\nimport glob\nimport numpy as np\nimport cv2\n\n\ndef load_data(input_size, path):\n    \"\"\"\n    Load training data from npz files and split into training/validation sets.\n\n    Args:\n        input_size (int): The size of the input image (number of pixels).\n        path (str): Path to training data files, supporting glob pattern matching.\n\n    Returns:\n        tuple: (X_train, X_test, y_train, y_test) - Training and validation data.\n    \"\"\"\n    files = sorted(glob.glob(path))\n    if not files:\n        raise FileNotFoundError(f\"No training data files found matching: {path}\")\n\n    X_list = []\n    y_list = []\n\n    for f in files:\n        try:\n            data = np.load(f)\n            image_data = data['image'].astype(np.float32)\n            label_data = data['label'].astype(np.float32)\n        except (KeyError, Exception) as e:\n            print(f\"Warning: Skipping malformed file {f}: {e}\")\n            continue\n\n        # Normalize to [0, 1]\n        if image_data.max() > 1.0:\n            image_data = image_data / 255.0\n\n        # Handle input size mismatch\n        current_size = image_data.shape[1] if image_data.ndim > 1 else image_data.size\n        if current_size < input_size:\n            pad = np.zeros((image_data.shape[0], input_size - current_size), dtype=np.float32)\n            image_data = np.hstack([image_data, pad])\n        elif current_size > input_size:\n            image_data = image_data[:, :input_size]\n\n        # Convert integer labels to one-hot encoding\n        if label_data.shape[1] == 1:\n            int_labels = label_data[:, 0].astype(int)\n            one_hot = np.zeros((label_data.shape[0], 4), dtype=np.float32)\n            for i, label in enumerate(int_labels):\n                if 0 <= label < 4:\n                    one_hot[i, label] = 1.0\n            label_data = one_hot\n\n        X_list.append(image_data)\n        y_list.append(label_data)\n\n    X = np.vstack(X_list)\n    y = np.vstack(y_list)\n\n    # Shuffle data\n    indices = np.random.permutation(X.shape[0])\n    X = X[indices]\n    y = y[indices]\n\n    # Split 80/20 train/validation\n    split = int(0.8 * X.shape[0])\n    X_train, X_test = X[:split], X[split:]\n    y_train, y_test = y[:split], y[split:]\n\n    return X_train, X_test, y_train, y_test\n\n\nclass NeuralNetwork:\n    \"\"\"\n    A neural network model based on OpenCV for autonomous driving decision prediction.\n\n    Uses OpenCV's ANN_MLP with Sigmoid activation and back-propagation training.\n    \"\"\"\n\n    def __init__(self):\n        \"\"\"Initialize the NeuralNetwork with no model.\"\"\"\n        self.mlpc = None\n\n    def create(self, layer_sizes):\n        \"\"\"\n        Create the neural network with specified layer architecture.\n\n        Args:\n            layer_sizes (np.ndarray or list): Number of nodes per layer,\n                e.g., [76800, 32, 4] for input->hidden->output.\n        \"\"\"\n        if not isinstance(layer_sizes, np.ndarray):\n            layer_sizes = np.array(layer_sizes, dtype=np.int32)\n        elif layer_sizes.dtype != np.int32:\n            layer_sizes = layer_sizes.astype(np.int32)\n\n        self.mlpc = cv2.ml.ANN_MLP_create()\n        self.mlpc.setLayerSizes(layer_sizes)\n        self.mlpc.setActivationFunction(cv2.ml.ANN_MLP_SIGMOID_SYM)\n        self.mlpc.setTrainMethod(cv2.ml.ANN_MLP_BACKPROP, 0.001, 0.1)\n        self.mlpc.setTermCriteria((cv2.TERM_CRITERIA_COUNT | cv2.TERM_CRITERIA_EPS, 100, 1e-6))\n\n    def train(self, X, y):\n        \"\"\"\n        Train the neural network model.\n\n        Args:\n            X (np.ndarray): Training features, shape (n_samples, n_features).\n            y (np.ndarray): Training labels, shape (n_samples, n_classes), one-hot encoded.\n\n        Raises:\n            RuntimeError: If create() has not been called.\n        \"\"\"\n        if self.mlpc is None:\n            raise RuntimeError(\"Model not created. Call create() before training.\")\n\n        if X.dtype != np.float32:\n            X = X.astype(np.float32)\n        if y.dtype != np.float32:\n            y = y.astype(np.float32)\n\n        self.mlpc.train(X, cv2.ml.ROW_SAMPLE, y)\n\n    def evaluate(self, X, y):\n        \"\"\"\n        Evaluate model accuracy on test data.\n\n        Args:\n            X (np.ndarray): Test features.\n            y (np.ndarray): Test labels (one-hot encoded).\n\n        Returns:\n            float: Model accuracy between 0 and 1.\n\n        Raises:\n            RuntimeError: If create() has not been called.\n        \"\"\"\n        if self.mlpc is None:\n            raise RuntimeError(\"Model not created. Call create() before evaluation.\")\n\n        if X.dtype != np.float32:\n            X = X.astype(np.float32)\n\n        _, predictions = self.mlpc.predict(X)\n        pred_classes = np.argmax(predictions, axis=1)\n        true_classes = np.argmax(y, axis=1)\n\n        accuracy = np.mean(pred_classes == true_classes)\n        return float(accuracy)\n\n    def predict(self, X):\n        \"\"\"\n        Make predictions on input data.\n\n        Args:\n            X (np.ndarray): Feature data to predict, shape (n_samples, n_features).\n\n        Returns:\n            np.ndarray: Predicted class labels (0=left, 1=right, 2=forward, 3=stop).\n\n        Raises:\n            RuntimeError: If create() has not been called.\n        \"\"\"\n        if self.mlpc is None:\n            raise RuntimeError(\"Model not created. Call create() before prediction.\")\n\n        if X.dtype != np.float32:\n            X = X.astype(np.float32)\n\n        if X.ndim == 1:\n            X = X.reshape(1, -1)\n\n        _, result = self.mlpc.predict(X)\n        return np.argmax(result, axis=1)\n\n    def save_model(self, path):\n        \"\"\"\n        Save the trained model to disk.\n\n        Args:\n            path (str): File path to save the model (XML format).\n\n        Raises:\n            RuntimeError: If create() has not been called.\n        \"\"\"\n        if self.mlpc is None:\n            raise RuntimeError(\"Model not created. Call create() before saving.\")\n\n        parent_dir = os.path.dirname(path)\n        if parent_dir:\n            os.makedirs(parent_dir, exist_ok=True)\n\n        self.mlpc.save(path)\n\n    def load_model(self, path):\n        \"\"\"\n        Load a trained model from disk.\n\n        Args:\n            path (str): File path of the saved model.\n\n        Raises:\n            FileNotFoundError: If the model file does not exist.\n        \"\"\"\n        if not os.path.exists(path):\n            raise FileNotFoundError(f\"Model file not found: {path}\")\n\n        self.mlpc = cv2.ml.ANN_MLP_load(path)\nENDOFFILE\necho \"model.py fixed\""}
