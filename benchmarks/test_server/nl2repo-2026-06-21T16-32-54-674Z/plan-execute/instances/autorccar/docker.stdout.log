```python
class VideoStreamHandler(socketserver.StreamRequestHandler):
    # Object height parameters (manually measured)
    h1 = 5.5  # Stop sign height (cm)
    h2 = 5.5  # Traffic light height (cm)
    
    # Distance threshold configuration
