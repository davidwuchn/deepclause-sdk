[log] bash[1073] stdout     def __init__(self):
[log] bash[1073] stdout         """Initialise camera calibration parameters."""
[log] bash[1073] stdout         # camera params (obtained through manual measurement and calibration)
[log] bash[1073] stdout         self.alpha = 8.0 * math.pi / 180    # camera viewing angle (radians)
[log] bash[1073] stdout         self.v0 = 119.865631204             # camera matrix parameter v0
[log] bash[1073] stdout         self.ay = 332.262498472             # camera matrix parameter ay
[log] bash[1073] stdout     def calculate(self, v, h, x_shift, image):
[log] bash[1073] stdout         """Compute and display the distance to a target object.
[log] bash[1073] stdout         Args:
[log] bash[1073] stdout             v (float): Y-coordinate of the target base in the image.
[log] bash[1073] stdout             h (float): Actual height of the target object (cm).
[log] bash[1073] stdout             x_shift (int): X-axis offset for overlay text placement.
[log] bash[1073] stdout             image (np.ndarray): Colour image for distance overlay drawing.
[log] bash[1073] stdout         Returns:
[log] bash[1073] stdout             float: Computed distance in centimetres (positive) or negative
[log] bash[1073] stdout                    if the geometry does not yield a valid distance.
[log] bash[1073] stdout         """
[log] bash[1073] stdout         # compute and return the distance from the target point to the camera
[log] bash[1073] stdout         d = h / math.tan(self.alpha + math.atan((v - self.v0) / self.ay))
[log] bash[1073] stdout         if d > 0:
[log] bash[1073] stdout             cv2.putText(image, "%.1fcm" % d,
[log] bash[1073] stdout                         (image.shape[1] - x_shift, image.shape[0] - 20),
[log] bash[1073] stdout                         cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)
[log] bash[1073] stdout         return d
