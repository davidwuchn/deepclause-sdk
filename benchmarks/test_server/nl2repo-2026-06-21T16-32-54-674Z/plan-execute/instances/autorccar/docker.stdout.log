[log] bash[1453] stdout class DistanceToCamera:
[log] bash[1453] stdout     """Calculate the distance from a detected object to the camera.
[log] bash[1453] stdout     Uses camera intrinsic parameters and triangulation to compute
[log] bash[1453] stdout     real-world distance in centimetres from the image-plane y
[log] bash[1453] stdout     coordinate of the target base.
[log] bash[1453] stdout     """
[log] bash[1453] stdout     def __init__(self):
[log] bash[1453] stdout         """Initialise camera calibration parameters."""
[log] bash[1453] stdout         # camera params (obtained through manual measurement and calibration)
[log] bash[1453] stdout         self.alpha = 8.0 * math.pi / 180    # camera viewing angle (radians)
[log] bash[1453] stdout         self.v0 = 119.865631204             # camera matrix parameter v0
[log] bash[1453] stdout         self.ay = 332.262498472             # camera matrix parameter ay
[log] bash[1453] stdout     def calculate(self, v, h, x_shift, image):
[log] bash[1453] stdout         """Compute and display the distance to a target object.
[log] bash[1453] stdout         Args:
[log] bash[1453] stdout             v (float): Y-coordinate of the target base in the image.
[log] bash[1453] stdout             h (float): Actual height of the target object (cm).
[log] bash[1453] stdout             x_shift (int): X-axis offset for overlay text placement.
[log] bash[1453] stdout             image (np.ndarray): Colour image for distance overlay drawing.
[log] bash[1453] stdout         Returns:
[log] bash[1453] stdout             float: Computed distance in centimetres (positive) or negative
[log] bash[1453] stdout                    if the geometry does not yield a valid distance.
[log] bash[1453] stdout         """
[log] bash[1453] stdout         # compute and return the distance from the target point to the camera
[log] bash[1453] stdout         d = h / math.tan(self.alpha + math.atan((v - self.v0) / self.ay))
[log] bash[1453] stdout         if d > 0:
[log] bash[1453] stdout             cv2.putText(image, "%.1fcm" % d,
[log] bash[1453] stdout                         (image.shape[1] - x_shift, image.shape[0] - 20),
[log] bash[1453] stdout                         cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)
[log] bash[1453] stdout         return d
