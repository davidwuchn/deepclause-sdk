[log] bash[1097] stdout             except ValueError:
[log] bash[1097] stdout                 pass
[log] bash[1097] stdout             print(f"Sensor data received: {sensor_val}")
[log] bash[1097] stdout class VideoStreamHandler(socketserver.StreamRequestHandler):
