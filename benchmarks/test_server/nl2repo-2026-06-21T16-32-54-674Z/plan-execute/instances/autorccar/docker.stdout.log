[log] bash[179] stdout         """
[log] bash[179] stdout         self.mlpc = None
[log] bash[179] stdout     def create(self, layer_sizes: np.ndarray) -> None:
[log] bash[179] stdout         """
[log] bash[179] stdout         Create a neural network with the specified layer architecture.
[log] bash[179] stdout         Parameters:
[log] bash[179] stdout             layer_sizes (np.ndarray): The number of nodes in each layer of
[log] bash[179] stdout                                       the neural network, e.g., [76800, 32, 4].
[log] bash[179] stdout         """
[log] bash[179] stdout         if not isinstance(layer_sizes, np.ndarray):
[log] bash[179] stdout             layer_sizes = np.array(layer_sizes, dtype=np.int32)
[log] bash[179] stdout         # Create the MLP model
[log] bash[179] stdout         self.mlpc = cv2.ml.ANN_MLP_create()
[log] bash[179] stdout         # Set layer sizes
[log] bash[179] stdout         self.mlpc.setLayerSizes(layer_sizes)
[log] bash[179] stdout         # Configure the training method: BACKPROP with learning rate=0.001, momentum=0.1
[log] bash[179] stdout         # param1 = backpropWeightScale (learning rate), param2 = backpropMomentumScale
[log] bash[179] stdout         self.mlpc.setTrainMethod(cv2.ml.ANN_MLP_BACKPROP, param1=0.001, param2=0.1)
[log] bash[179] stdout         # Set Sigmoid activation function (symmetric, slope=1.0, asymmetric coefficient=1.0)
[log] bash[179] stdout         self.mlpc.setActivationFunction(cv2.ml.ANN_MLP_SIGMOID_SYM, param1=1.0, param2=1.0)
[log] bash[179] stdout         # Set the number of iterations and termination criteria
[log] bash[179] stdout         self.mlpc.setTermCriteria((cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER, 100, 1e-6))
[log] bash[179] stdout     def train(self, X: np.ndarray, y: np.ndarray) -> None:
[log] bash[179] stdout         """
[log] bash[179] stdout         Train the neural network model using the provided data.
[log] bash[179] stdout         Parameters:
[log] bash[179] stdout             X (np.ndarray): Training feature data, shape (n_samples, n_features).
[log] bash[179] stdout             y (np.ndarray): Training label data (one-hot encoded), shape (n_samples, n_classes).
[log] bash[179] stdout         """
[log] bash[179] stdout         if self.mlpc is None:
[log] bash[179] stdout             raise RuntimeError("Neural network not created. Call create() first.")
[log] bash[179] stdout         if X.dtype != np.float32:
[log] bash[179] stdout             X = X.astype(np.float32)
[log] bash[179] stdout         if y.dtype != np.float32:
[log] bash[179] stdout             y = y.astype(np.float32)
[log] bash[179] stdout         # Train the model
[log] bash[179] stdout         self.mlpc.train(X, cv2.ml.ROW_SAMPLE, y)
[log] bash[179] stdout     def evaluate(self, X: np.ndarray, y: np.ndarray) -> float:
[log] bash[179] stdout         """
[log] bash[179] stdout         Evaluate the model accuracy on the provided data.
[log] bash[179] stdout         Parameters:
[log] bash[179] stdout             X (np.ndarray): Test feature data.
[log] bash[179] stdout             y (np.ndarray): Test label data (one-hot encoded).
[log] bash[179] stdout         Returns:
[log] bash[179] stdout             float: The model accuracy (a value between 0 and 1).
[log] bash[179] stdout         """
[log] bash[179] stdout         if self.mlpc is None:
[log] bash[179] stdout             raise RuntimeError("Neural network not created or not loaded.")
[log] bash[179] stdout         if X.dtype != np.float32:
[log] bash[179] stdout             X = X.astype(np.float32)
[log] bash[179] stdout         if y.dtype != np.float32:
[log] bash[179] stdout             y = y.astype(np.float32)
[log] bash[179] stdout         # Get predictions
[log] bash[179] stdout         _, predictions = self.mlpc.predict(X)
[log] bash[179] stdout         # Calculate accuracy by comparing argmax of predictions and labels
[log] bash[179] stdout         predicted_labels = np.argmax(predictions, axis=1)
[log] bash[179] stdout         true_labels = np.argmax(y, axis=1)
[log] bash[179] stdout         accuracy = np.mean(predicted_labels == true_labels)
[log] bash[179] stdout         return float(accuracy)
[log] bash[179] stdout     def predict(self, X: np.ndarray) -> np.ndarray:
[log] bash[179] stdout         """
[log] bash[179] stdout         Make predictions using the trained model.
[log] bash[179] stdout         Parameters:
[log] bash[179] stdout             X (np.ndarray): Feature data to be predicted.
[log] bash[179] stdout         Returns:
[log] bash[179] stdout             np.ndarray: Array of predicted class labels.
[log] bash[179] stdout                         0: Left turn, 1: Right turn, 2: Forward, 3: Stop
[log] bash[179] stdout         """
[log] bash[179] stdout         if self.mlpc is None:
[log] bash[179] stdout             raise RuntimeError("Neural network not created or not loaded.")
[log] bash[179] stdout         if X.dtype != np.float32:
[log] bash[179] stdout             X = X.astype(np.float32)
[log] bash[179] stdout         # Ensure input is 2D
[log] bash[179] stdout         if X.ndim == 1:
[log] bash[179] stdout             X = X.reshape(1, -1)
[log] bash[179] stdout         # Get predictions
[log] bash[179] stdout         _, result = self.mlpc.predict(X)
[log] bash[179] stdout         # Return the predicted class labels
[log] bash[179] stdout         predictions = np.argmax(result, axis=1)
[log] bash[179] stdout         return predictions
