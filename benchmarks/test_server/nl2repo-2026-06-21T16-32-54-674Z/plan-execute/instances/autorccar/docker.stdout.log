[log] bash[1643] stdout class DistanceToCamera:
[log] bash[1643] stdout     """
[log] bash[1643] stdout     Calculate the distance from the target object to the camera based on
[log] bash[1643] stdout     camera intrinsic parameters using triangulation principle.
[log] bash[1643] stdout     """
[log] bash[1643] stdout     def __init__(self):
[log] bash[1643] stdout         """Initialize camera calibration parameters."""
[log] bash[1643] stdout         self.alpha = 8.0 * math.pi / 180  # Camera viewing angle (radians)
[log] bash[1643] stdout         self.v0 = 119.865631204           # Camera matrix parameter v0
[log] bash[1643] stdout         self.ay = 332.262498472           # Camera matrix parameter ay
[log] bash[1643] stdout     def calculate(self, v, h, x_shift, image):
[log] bash[1643] stdout         """
[log] bash[1643] stdout         Calculate distance from target to camera.
[log] bash[1643] stdout         Args:
[log] bash[1643] stdout             v (float): Vertical coordinate of target in image.
[log] bash[1643] stdout             h (float): Actual height of target object (cm).
[log] bash[1643] stdout             x_shift (int): X-axis offset for text display.
[log] bash[1643] stdout             image (np.ndarray): Image array for displaying distance.
[log] bash[1643] stdout         Returns:
[log] bash[1643] stdout             float: Calculated distance in centimeters.
[log] bash[1643] stdout         """
[log] bash[1643] stdout         d = h / math.tan(self.alpha + math.atan((v - self.v0) / self.ay))
[log] bash[1643] stdout         if d > 0:
[log] bash[1643] stdout             cv2.putText(image, "%.1fcm" % d,
[log] bash[1643] stdout                         (image.shape[1] - x_shift, image.shape[0] - 20),
[log] bash[1643] stdout                         cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)
[log] bash[1643] stdout         return d
[log] bash[1643] stdout class ObjectDetection:
[log] bash[1643] stdout     """
[log] bash[1643] stdout     Detect stop signs and traffic lights using cascade classifiers.
[log] bash[1643] stdout     """
[log] bash[1643] stdout     def __init__(self):
[log] bash[1643] stdout         """Initialize traffic light status flags."""
[log] bash[1643] stdout         self.red_light = False
[log] bash[1643] stdout         self.green_light = False
[log] bash[1643] stdout         self.yellow_light = False
[log] bash[1643] stdout     def detect(self, cascade_classifier, gray_image, image):
[log] bash[1643] stdout         """
[log] bash[1643] stdout         Detect objects using a cascade classifier.
[log] bash[1643] stdout         Args:
[log] bash[1643] stdout             cascade_classifier: OpenCV cascade classifier object.
[log] bash[1643] stdout             gray_image (np.ndarray): Grayscale image.
[log] bash[1643] stdout             image (np.ndarray): Color image for drawing results.
[log] bash[1643] stdout         Returns:
[log] bash[1643] stdout             int: Y-coordinate of bottom of detected object, 0 if none found.
[log] bash[1643] stdout         """
[log] bash[1643] stdout         v = 0
[log] bash[1643] stdout         if cascade_classifier.empty():
[log] bash[1643] stdout             return v
[log] bash[1643] stdout         cascade_obj = cascade_classifier.detectMultiScale(
[log] bash[1643] stdout             gray_image,
[log] bash[1643] stdout             scaleFactor=1.1,
[log] bash[1643] stdout             minNeighbors=5,
[log] bash[1643] stdout             minSize=(30, 30))
[log] bash[1643] stdout         for (x_pos, y_pos, width, height) in cascade_obj:
[log] bash[1643] stdout             cv2.rectangle(image, (x_pos + 5, y_pos + 5),
[log] bash[1643] stdout                           (x_pos + width - 5, y_pos + height - 5),
[log] bash[1643] stdout                           (255, 255, 255), 2)
[log] bash[1643] stdout             v = y_pos + height - 5
[log] bash[1643] stdout             # Stop sign detection
[log] bash[1643] stdout             if width / height == 1:
[log] bash[1643] stdout                 cv2.putText(image, 'STOP', (x_pos, y_pos - 10),
[log] bash[1643] stdout                             cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2)
[log] bash[1643] stdout             else:
[log] bash[1643] stdout                 # Traffic light detection
[log] bash[1643] stdout                 roi = gray_image[y_pos + 10:y_pos + height - 10,
[log] bash[1643] stdout                                  x_pos + 10:x_pos + width - 10]
[log] bash[1643] stdout                 mask = cv2.GaussianBlur(roi, (25, 25), 0)
[log] bash[1643] stdout                 (minVal, maxVal, minLoc, maxLoc) = cv2.minMaxLoc(mask)
[log] bash[1643] stdout                 threshold = 20
[log] bash[1643] stdout                 if maxVal - minVal > threshold:
[log] bash[1643] stdout                     cv2.circle(roi, maxLoc, 5, (255, 0, 0), 2)
[log] bash[1643] stdout                     # Red light
[log] bash[1643] stdout                     if (1.0 / 8 * (height - 30) < maxLoc[1] <
[log] bash[1643] stdout                             4.0 / 8 * (height - 30)):
[log] bash[1643] stdout                         cv2.putText(image, 'Red', (x_pos + 5, y_pos - 5),
[log] bash[1643] stdout                                     cv2.FONT_HERSHEY_SIMPLEX, 0.5,
[log] bash[1643] stdout                                     (0, 0, 255), 2)
[log] bash[1643] stdout                         self.red_light = True
[log] bash[1643] stdout                     # Green light
[log] bash[1643] stdout                     elif (5.5 / 8 * (height - 30) < maxLoc[1] <
[log] bash[1643] stdout                           height - 30):
[log] bash[1643] stdout                         cv2.putText(image, 'Green', (x_pos + 5, y_pos - 10),
[log] bash[1643] stdout                                     cv2.FONT_HERSHEY_SIMPLEX, 0.5,
[log] bash[1643] stdout                                     (0, 255, 0), 2)
[log] bash[1643] stdout                         self.green_light = True
[log] bash[1643] stdout                     # Yellow light
[log] bash[1643] stdout                     else:
[log] bash[1643] stdout                         cv2.putText(image, 'Yellow', (x_pos + 5, y_pos - 15),
[log] bash[1643] stdout                                     cv2.FONT_HERSHEY_SIMPLEX, 0.5,
[log] bash[1643] stdout                                     (0, 255, 255), 2)
[log] bash[1643] stdout                         self.yellow_light = True
[log] bash[1643] stdout         return v
