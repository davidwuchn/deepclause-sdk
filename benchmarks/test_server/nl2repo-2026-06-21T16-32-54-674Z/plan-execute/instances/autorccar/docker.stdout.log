[AGENT] Tool call: run_bash {"arg1":"cat > /workspace/computer/rc_driver_helper.py << 'ENDOFFILE'\n\"\"\"\nAutoRCCar - RC Driver Helper Module\n\nProvides hardware control, distance calculation, and object detection classes\nfor the autonomous RC car system.\n\"\"\"\n\nimport math\nimport cv2\n\n\nclass RCControl:\n    \"\"\"\n    Control the movement of the RC car through the serial port.\n\n    Control Command Mapping:\n        prediction == 0: Left turn  (send chr(7))\n        prediction == 1: Right turn (send chr(6))\n        prediction == 2: Forward    (send chr(1))\n        other:            Stop       (send chr(0))\n    \"\"\"\n\n    def __init__(self, serial_port):\n        \"\"\"\n        Initialize the RC car controller.\n\n        Args:\n            serial_port (str): Path to serial port device, e.g., \"/dev/tty.usbmodem1421\".\n        \"\"\"\n        self.serial_port = serial_port\n\n    def steer(self, prediction):\n        \"\"\"\n        Send steering command to the RC car.\n\n        Args:\n            prediction (int): The predicted action label.\n                0: Left turn, 1: Right turn, 2: Forward, other: Stop.\n        \"\"\"\n        if prediction == 2:\n            self.serial_port.write(chr(1).encode())\n            print(\"Forward\")\n        elif prediction == 0:\n            self.serial_port.write(chr(7).encode())\n            print(\"Left\")\n        elif prediction == 1:\n            self.serial_port.write(chr(6).encode())\n            print(\"Right\")\n        else:\n            self.stop()\n\n    def stop(self):\n        \"\"\"Send emergency stop command to the RC car.\"\"\"\n        self.serial_port.write(chr(0).encode())\n        print(\"Stop\")\n\n\nclass DistanceToCamera:\n    \"\"\"\n    Calculate the distance from the target object to the camera based on\n    camera intrinsic parameters using triangulation principle.\n    \"\"\"\n\n    def __init__(self):\n        \"\"\"Initialize camera calibration parameters.\"\"\"\n        self.alpha = 8.0 * math.pi / 180  # Camera viewing angle (radians)\n        self.v0 = 119.865631204           # Camera matrix parameter v0\n        self.ay = 332.262498472           # Camera matrix parameter ay\n\n    def calculate(self, v, h, x_shift, image):\n        \"\"\"\n        Calculate distance from target to camera.\n\n        Args:\n            v (float): Vertical coordinate of target in image.\n            h (float): Actual height of target object (cm).\n            x_shift (int): X-axis offset for text display.\n            image (np.ndarray): Image array for displaying distance.\n\n        Returns:\n            float: Calculated distance in centimeters.\n        \"\"\"\n        d = h / math.tan(self.alpha + math.atan((v - self.v0) / self.ay))\n        if d > 0:\n            cv2.putText(image, \"%.1fcm\" % d,\n                        (image.shape[1] - x_shift, image.shape[0] - 20),\n                        cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)\n        return d\n\n\nclass ObjectDetection:\n    \"\"\"\n    Detect stop signs and traffic lights using cascade classifiers.\n    \"\"\"\n\n    def __init__(self):\n        \"\"\"Initialize traffic light status flags.\"\"\"\n        self.red_light = False\n        self.green_light = False\n        self.yellow_light = False\n\n    def detect(self, cascade_classifier, gray_image, image):\n        \"\"\"\n        Detect objects using a cascade classifier.\n\n        Args:\n            cascade_classifier: OpenCV cascade classifier object.\n            gray_image (np.ndarray): Grayscale image.\n            image (np.ndarray): Color image for drawing results.\n\n        Returns:\n            int: Y-coordinate of bottom of detected object, 0 if none found.\n        \"\"\"\n        v = 0\n        if cascade_classifier.empty():\n            return v\n\n        cascade_obj = cascade_classifier.detectMultiScale(\n            gray_image,\n            scaleFactor=1.1,\n            minNeighbors=5,\n            minSize=(30, 30))\n\n        for (x_pos, y_pos, width, height) in cascade_obj:\n            cv2.rectangle(image, (x_pos + 5, y_pos + 5),\n                          (x_pos + width - 5, y_pos + height - 5),\n                          (255, 255, 255), 2)\n            v = y_pos + height - 5\n\n            # Stop sign detection\n            if width / height == 1:\n                cv2.putText(image, 'STOP', (x_pos, y_pos - 10),\n                            cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2)\n            else:\n                # Traffic light detection\n                roi = gray_image[y_pos + 10:y_pos + height - 10,\n                                 x_pos + 10:x_pos + width - 10]\n                mask = cv2.GaussianBlur(roi, (25, 25), 0)\n                (minVal, maxVal, minLoc, maxLoc) = cv2.minMaxLoc(mask)\n\n                threshold = 20\n                if maxVal - minVal > threshold:\n                    cv2.circle(roi, maxLoc, 5, (255, 0, 0), 2)\n\n                    # Red light\n                    if (1.0 / 8 * (height - 30) < maxLoc[1] <\n                            4.0 / 8 * (height - 30)):\n                        cv2.putText(image, 'Red', (x_pos + 5, y_pos - 5),\n                                    cv2.FONT_HERSHEY_SIMPLEX, 0.5,\n                                    (0, 0, 255), 2)\n                        self.red_light = True\n                    # Green light\n                    elif (5.5 / 8 * (height - 30) < maxLoc[1] <\n                          height - 30):\n                        cv2.putText(image, 'Green', (x_pos + 5, y_pos - 10),\n                                    cv2.FONT_HERSHEY_SIMPLEX, 0.5,\n                                    (0, 255, 0), 2)\n                        self.green_light = True\n                    # Yellow light\n                    else:\n                        cv2.putText(image, 'Yellow', (x_pos + 5, y_pos - 15),\n                                    cv2.FONT_HERSHEY_SIMPLEX, 0.5,\n                                    (0, 255, 255), 2)\n                        self.yellow_light = True\n\n        return v\nENDOFFILE\necho \"rc_driver_helper.py written successfully\""}
