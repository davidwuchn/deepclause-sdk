[AGENT] Tool call: run_bash {"arg1":"cat > /workspace/computer/collect_training_data.py << 'ENDOFFILE'\n\"\"\"\nAutoRCCar - Training Data Collection Module\n\nCollects training data by recording video frames and keyboard commands\nfor supervised learning of driving decisions.\n\"\"\"\n\nimport os\nimport sys\nimport socket\nimport glob\nimport numpy as np\nimport cv2\nimport serial\nimport pygame\nfrom pygame.locals import K_UP, K_DOWN, K_LEFT, K_RIGHT, K_x, K_q\n\n\nclass CollectTrainingData:\n    \"\"\"\n    Configure the network and serial port parameters of the training data collector.\n    \"\"\"\n\n    def __init__(self, host, port, serial_port, input_size):\n        \"\"\"\n        Initialize the training data collector.\n\n        Args:\n            host (str): Host address of the data collection server.\n            port (int): Port of the data collection server.\n            serial_port (str): Path to Arduino serial port device.\n            input_size (int): Size of the input image (number of pixels).\n        \"\"\"\n        self.host = host\n        self.port = port\n        self.serial_port = serial_port\n        self.input_size = input_size\n\n        self.server_socket = socket.socket()\n        self.server_socket.bind((host, port))\n        self.server_socket.listen(0)\n\n        self.ser = serial.Serial(serial_port, 115200, timeout=1)\n\n        # Label matrix configuration (4x4 identity for one-hot encoding)\n        self.k = np.zeros((4, 4), 'float')\n        for i in range(4):\n            self.k[i, i] = 1\n\n        # Data collection attributes\n        self.data_counter = 0\n        self.data_dir = os.path.join(os.path.dirname(__file__), '..', 'training_data')\n        os.makedirs(self.data_dir, exist_ok=True)\n\n        self.current_label = 2  # Default: forward\n        self.stream_bytes = b' '\n        self.width = None\n        self.height = None\n\n    def collect(self):\n        \"\"\"Start the data collection loop.\"\"\"\n        pygame.init()\n\n        conn, client_address = self.server_socket.accept()\n        print(f\"Connected to {client_address}\")\n\n        stream_bytes = b' '\n\n        while True:\n            # Process pygame events\n            for event in pygame.event.get():\n                if event.type == pygame.QUIT:\n                    self.ser.write(chr(0).encode())\n                    conn.close()\n                    pygame.quit()\n                    return\n                if event.type == pygame.KEYDOWN:\n                    if event.key == K_x or event.key == K_q:\n                        self.ser.write(chr(0).encode())\n                        conn.close()\n                        pygame.quit()\n                        return\n\n            # Check keyboard state\n            keys = pygame.key.get_pressed()\n            if keys[K_LEFT]:\n                self.current_label = 0\n                self.ser.write(chr(7).encode())\n            elif keys[K_RIGHT]:\n                self.current_label = 1\n                self.ser.write(chr(6).encode())\n            elif keys[K_UP]:\n                self.current_label = 2\n                self.ser.write(chr(1).encode())\n            elif keys[K_DOWN]:\n                self.current_label = 3\n                self.ser.write(chr(2).encode())\n            else:\n                self.ser.write(chr(0).encode())\n\n            # Receive and decode frame\n            stream_bytes += conn.recv(1024)\n            first = stream_bytes.find(b'\\xff\\xd8')\n            last = stream_bytes.find(b'\\xff\\xd9')\n\n            if first != -1 and last != -1:\n                jpg = stream_bytes[first:last + 2]\n                stream_bytes = stream_bytes[last + 2:]\n\n                image = cv2.imdecode(np.frombuffer(jpg, dtype=np.uint8), cv2.IMREAD_COLOR)\n                gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\n\n                if gray is None:\n                    continue\n\n                self.height, self.width = gray.shape\n\n                # Extract ROI (lower half)\n                roi = gray[int(self.height / 2):self.height, :]\n                roi_flat = roi.flatten().astype(np.float32) / 255.0\n\n                # Pad or truncate to input_size\n                if len(roi_flat) < self.input_size:\n                    roi_flat = np.concatenate([roi_flat, np.zeros(self.input_size - len(roi_flat), dtype=np.float32)])\n                elif len(roi_flat) > self.input_size:\n                    roi_flat = roi_flat[:self.input_size]\n\n                # Save data\n                label = self.k[self.current_label]\n                filename = os.path.join(self.data_dir, f\"frame{self.data_counter:04d}.npz\")\n                np.savez(filename, image=roi_flat.reshape(1, self.input_size), label=label.reshape(1, 4))\n                self.data_counter += 1\n\n                print(f\"Collected frame {self.data_counter}\")\n\n\nif __name__ == '__main__':\n    h, p = \"192.168.1.100\", 8000\n    sp = \"/dev/tty.usbmodem1421\"\n    s = 120 * 320  # vector size, half of the image\n\n    ctd = CollectTrainingData(h, p, sp, s)\n    ctd.collect()\nENDOFFILE\necho \"collect_training_data.py written\""}
