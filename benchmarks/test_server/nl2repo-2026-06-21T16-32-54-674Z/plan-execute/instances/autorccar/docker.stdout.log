[log] bash[163] stdout         """
[log] bash[163] stdout         if self.mlpc is None:
[log] bash[163] stdout             raise RuntimeError("Neural network not created or not loaded.")
[log] bash[163] stdout         if X.dtype != np.float32:
[log] bash[163] stdout             X = X.astype(np.float32)
[log] bash[163] stdout         # Ensure input is 2D
[log] bash[163] stdout         if X.ndim == 1:
