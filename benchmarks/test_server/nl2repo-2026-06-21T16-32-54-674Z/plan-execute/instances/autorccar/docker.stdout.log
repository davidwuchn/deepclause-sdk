[log] bash[1643] stdout     def steer(self, prediction):
[log] bash[1643] stdout         """
[log] bash[1643] stdout         Send steering command to the RC car.
[log] bash[1643] stdout         Args:
[log] bash[1643] stdout             prediction (int): The predicted action label.
[log] bash[1643] stdout                 0: Left turn, 1: Right turn, 2: Forward, other: Stop.
[log] bash[1643] stdout         """
[log] bash[1643] stdout         if prediction == 2:
[log] bash[1643] stdout             self.serial_port.write(chr(1).encode())
[log] bash[1643] stdout             print("Forward")
[log] bash[1643] stdout         elif prediction == 0:
[log] bash[1643] stdout             self.serial_port.write(chr(7).encode())
[log] bash[1643] stdout             print("Left")
[log] bash[1643] stdout         elif prediction == 1:
[log] bash[1643] stdout             self.serial_port.write(chr(6).encode())
[log] bash[1643] stdout             print("Right")
