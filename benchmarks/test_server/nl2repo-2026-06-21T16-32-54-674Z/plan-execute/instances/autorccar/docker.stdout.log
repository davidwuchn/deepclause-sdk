ass TestNeuralNetworkTrain:\n    \"\"\"Test NeuralNetwork.train() method.\"\"\"\n\n    def test_train_raises_without_create(self):\n        nn = NeuralNetwork()\n        with pytest.raises(RuntimeError, match=\"not created\"):\n            nn.train(np.zeros((1, 10)), np.zeros((1, 4)))\n\n    def test_train_basic(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        X = np.random.rand(20, 10).astype(np.float32)\n        y = np.eye(4)[np.random.randint(0, 4, size=20)].astype(np.float32)\n        nn.train(X, y)\n\n    def test_train_dtype_conversion(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        X = np.random.rand(10, 10).astype(np.float64)\n        y = np.random.rand(10, 4).astype(np.float64)\n        nn.train(X, y)\n\n\nclass TestNeuralNetworkPredict:\n    \"\"\"Test NeuralNetwork.predict() method.\"\"\"\n\n    def test_predict_raises_without_create(self):\n        nn = NeuralNetwork()\n        with pytest.raises(RuntimeError, match=\"not created\"):\n            nn.predict(np.zeros((1, 10)))\n\n    def test_predict_returns_labels(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        X = np.random.rand(5, 10).astype(np.float32)\n        y = np.eye(4)[np.random.randint(0, 4, size=5)].astype(np.float32)\n        nn.train(X, y)\n        result = nn.predict(X)\n        assert result.ndim == 1\n        assert result.dtype in [np.int32, np.int64]\n        assert all(0 <= r < 4 for r in result)\n\n    def test_predict_single_sample(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        X = np.random.rand(5, 10).astype(np.float32)\n        y = np.eye(4)[np.random.randint(0, 4, size=5)].astype(np.float32)\n        nn.train(X, y)\n        result = nn.predict(X[0])\n        assert result.ndim == 1\n        assert len(result) == 1\n\n\nclass TestNeuralNetworkEvaluate:\n    \"\"\"Test NeuralNetwork.evaluate() method.\"\"\"\n\n    def test_evaluate_raises_without_create(self):\n        nn = NeuralNetwork()\n        with pytest.raises(RuntimeError, match=\"not created\"):\n            nn.evaluate(np.zeros((1, 10)), np.zeros((1, 4)))\n\n    def test_evaluate_returns_float(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        X = np.random.rand(20, 10).astype(np.float32)\n        y = np.eye(4)[np.random.randint(0, 4, size=20)].astype(np.float32)\n        nn.train(X, y)\n        accuracy = nn.evaluate(X, y)\n        assert isinstance(accuracy, float)\n        assert 0.0 <= accuracy <= 1.0\n\n\nclass TestNeuralNetworkSaveLoad:\n    \"\"\"Test NeuralNetwork save_model and load_model methods.\"\"\"\n\n    def test_save_raises_without_create(self):\n        nn = NeuralNetwork()\n        with pytest.raises(RuntimeError, match=\"not created\"):\n            nn.save_model(\"/tmp/test_nn.xml\")\n\n    def test_save_and_load(self, tmp_path):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        X = np.random.rand(10, 10).astype(np.float32)\n        y = np.eye(4)[np.random.randint(0, 4, size=10)].astype(np.float32)\n        nn.train(X, y)\n\n        model_path = str(tmp_path / \"test_model.xml\")\n        nn.save_model(model_path)\n        assert os.path.exists(model_path)\n\n        nn2 = NeuralNetwork()\n        nn2.load_model(model_path)\n        assert nn2.mlpc is not None\n\n        pred1 = nn.predict(X)\n        pred2 = nn2.predict(X)\n        np.testing.assert_array_equal(pred1, pred2)\n\n    def test_load_nonexistent_file(self):\n        nn = NeuralNetwork()\n        with pytest.raises(FileNotFoundError):\n            nn.load_model(\"/nonexistent/path/model.xml\")\n\n\nclass TestNeuralNetworkIntegration:\n    \"\"\"End-to-end NeuralNetwork tests.\"\"\"\n\n    def test_full_pipeline(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n\n        # Create labeled data\n        X = np.random.rand(40, 10).astype(np.float32)\n        labels = np.repeat([0, 1, 2, 3], 10)\n        y = np.eye(4)[labels].astype(np.float32)\n\n        nn.train(X, y)\n        accuracy = nn.evaluate(X, y)\n        assert isinstance(accuracy, float)\n\n        predictions = nn.predict(X)\n        assert len(predictions) == 40\n\n\nclass TestRCControlInit:\n    \"\"\"Test RCControl initialization.\"\"\"\n\n    def test_init_opens_port(self):\n        rc = RCControl(\"/dev/ttyUSB0\")\n        assert rc.serial_port == \"/dev/ttyUSB0\"\n\n\nclass TestRCControlSteer:\n    \"\"\"Test RCControl.steer() method.\"\"\"\n\n    def test_steer_forward(self):\n        mock = MockSerialPort(\"/dev/ttyUSB0\")\n        rc = RCControl(mock)\n        rc.serial_port = mock\n        rc.steer(2)\n        assert mock.written[-1] == b'\\x01'\n\n    def test_steer_left(self):\n        mock = MockSerialPort(\"/dev/ttyUSB0\")\n        rc = RCControl(mock)\n        rc.serial_port = mock\n        rc.steer(0)\n        assert mock.written[-1] == b'\\x07'\n\n    def test_steer_right(self):\n        mock = MockSerialPort(\"/dev/ttyUSB0\")\n        rc = RCControl(mock)\n        rc.serial_port = mock\n        rc.steer(1)\n        assert mock.written[-1] == b'\\x06'\n\n    def test_steer_unknown_stops(self):\n        mock = MockSerialPort(\"/dev/ttyUSB0\")\n        rc = RCControl(mock)\n        rc.serial_port = mock\n        rc.steer(99)\n        assert mock.written[-1] == b'\\x00'\n\n\nclass TestRCControlStop:\n    \"\"\"Test RCControl.stop() method.\"\"\"\n\n    def test_stop_sends_command(self):\n        mock = MockSerialPort(\"/dev/ttyUSB0\")\n        rc = RCControl(mock)\n        rc.serial_port = mock\n        rc.stop()\n        assert mock.written[-1] == b'\\x00'\n\n\nclass TestDistanceToCameraInit:\n    \"\"\"Test DistanceToCamera initialization.\"\"\"\n\n    def test_init_params(self):\n        d = DistanceToCamera()\n        assert abs(d.alpha - 8.0 * math.pi / 180) < 1e-10\n        assert abs(d.v0 - 119.865631204) < 1e-10\n        assert abs(d.ay - 332.262498472) < 1e-10\n\n\nclass TestDistanceToCameraCalculate:\n    \"\"\"Test DistanceToCamera.calculate() method.\"\"\"\n\n    def test_calculate_returns_float(self):\n        d = DistanceToCamera()\n        image = np.zeros((480, 640, 3), dtype=np.uint8) + 255\n        result = d.calculate(200, 5.5, 300, image)\n        assert isinstance(result, (float, np.floating))\n\n    def test_calculate_positive_distance(self):\n        d = DistanceToCamera()\n        image = np.zeros((480, 640, 3), dtype=np.uint8) + 255\n        result = d.calculate(200, 5.5, 300, image)\n        assert result > 0\n\n    def test_calculate_deterministic(self):\n        d = DistanceToCamera()\n        image = np.zeros((480, 640, 3), dtype=np.uint8) + 255\n        r1 = d.calculate(200, 5.5, 300, image)\n        r2 = d.calculate(200, 5.5, 300, image)\n        assert r1 == r2\n\n    def test_calculate_formula(self):\n        d = DistanceToCamera()\n        v = 200\n        h = 5.5\n        image = np.zeros((480, 640, 3), dtype=np.uint8) + 255\n        result = d.calculate(v, h, 300, image)\n        expected = h / math.tan(d.alpha + math.atan((v - d.v0) / d.ay))\n        assert abs(result - expected) < 1e-6\n\n\nclass TestObjectDetectionInit:\n    \"\"\"Test ObjectDetection initialization.\"\"\"\n\n    def test_init_flags_false(self):\n        od = ObjectDetection()\n        assert od.red_light is False\n        assert od.green_light is False\n        assert od.yellow_light is False\n\n\nclass TestObjectDetectionDetect:\n    \"\"\"Test ObjectDetection.detect() method.\"\"\"\n\n    def test_detect_returns_zero_on_empty_cascade(self):\n        od = ObjectDetection()\n        cascade = cv2.CascadeClassifier()  # Empty cascade\n        gray = np.zeros((480, 640), dtype=np.uint8)\n        image = np.zeros((480, 640, 3), dtype=np.uint8)\n        result = od.detect(cascade, gray, image)\n        assert result == 0\n\n    def test_detect_invalid_cascade(self):\n        od = ObjectDetection()\n        cascade = cv2.CascadeClassifier()\n        assert cascade.empty()\n        gray = np.zeros((480, 640), dtype=np.uint8)\n        image = np.zeros((480, 640, 3), dtype=np.uint8)\n        result = od.detect(cascade, gray, image)\n        assert result == 0\n\n    def test_flags_persist_after_no_detection(self):\n        od = ObjectDetection()\n        cascade = cv2.CascadeClassifier()\n        gray = np.zeros((480, 640), dtype=np.uint8)\n        image = np.zeros((480, 640, 3), dtype=np.uint8)\n        od.detect(cascade, gray, image)\n        assert od.red_light is False\n        assert od.green_light is False\n        assert od.yellow_light is False\n\n\nclass TestDataLoading:\n    \"\"\"Test load_data() function.\"\"\"\n\n    def test_load_data_raises_on_missing_files(self):\n        with pytest.raises(FileNotFoundError):\n            load_data(76800, \"/nonexistent/path/*.npz\")\n\n    def test_load_data_split(self, tmp_path):\n        # Create dummy npz files\n        for i in range(5):\n            X = np.random.rand(10, 10).astype(np.float32)\n            y = np.eye(4)[np.random.randint(0, 4, size=10)].astype(np.float32)\n            np.savez(tmp_path / f\"data_{i}.npz\", image=X, label=y)\n\n        X_train, X_test, y_train, y_test = load_data(10, str(tmp_path / \"*.npz\"))\n        assert X_train.shape[1] == 10\n        assert X_train.shape[0] > X_test.shape[0]\n\n    def test_load_data_normalization(self, tmp_path):\n        X = np.random.rand(5, 10).astype(np.float32) * 255.0\n        y = np.eye(4)[np.random.randint(0, 4, size=5)].astype(np.float32)\n        np.savez(tmp_path / \"test.npz\", image=X, label=y)\n\n        X_train, X_test, y_train, y_test = load_data(10, str(tmp_path / \"test.npz\"))\n        assert X_train.max() <= 1.0\n\n    def test_load_data_label_conversion(self, tmp_path):\n        X = np.random.rand(10, 10).astype(np.float32)\n        labels = np.random.randint(0, 4, size=10).astype(np.float32).reshape(-1, 1)\n        np.savez(tmp_path / \"test.npz\", image=X, label=labels)\n\n        X_train, X_test, y_train, y_test = load_data(10, str(tmp_path / \"test.npz\"))\n        assert y_train.shape[1] == 4\n\n\nclass TestCollectTrainingDataHelpers:\n    \"\"\"Test helper functionality of CollectTrainingData.\"\"\"\n\n    def test_roi_extraction(self):\n        height, width = 240, 320\n        gray = np.random.randint(0, 255, (height, width), dtype=np.uint8)\n        roi = gray[int(height / 2):height, :]\n        assert roi.shape == (int(height / 2), width)\n\n    def test_roi_content_preservation(self):\n        height, width = 240, 320\n        gray = np.zeros((height, width), dtype=np.uint8)\n        gray[int(height / 2):, :] = 255\n        roi = gray[int(height / 2):height, :]\n        assert roi.mean() == 255.0\n\n    def test_save_load_npz(self, tmp_path):\n        data = np.random.rand(1, 10).astype(np.float32)\n        label = np.array([[1, 0, 0, 0]], dtype=np.float32)\n        fpath = str(tmp_path / \"test.npz\")\n        np.savez(fpath, image=data, label=label)\n        loaded = np.load(fpath)\n        np.testing.assert_array_equal(loaded['image'], data)\n        np.testing.assert_array_equal(loaded['label'], label)\n\n    def test_identity_label_matrix(self):\n        k = np.zeros((4, 4), 'float')\n        for i in range(4):\n            k[i, i] = 1\n        for i in range(4):\n            for j in range(4):\n                if i == j:\n                    assert k[i, j] == 1.0\n                else:\n                    assert k[i, j] == 0.0\n\n\nclass TestIntegration:\n    \"\"\"Integration tests.\"\"\"\n\n    def test_load_train_evaluate_pipeline(self, tmp_path):\n        for i in range(5):\n            X = np.random.rand(10, 10).astype(np.float32)\n            y = np.eye(4)[np.random.randint(0, 4, size=10)].astype(np.float32)\n            np.savez(tmp_path / f\"data_{i}.npz\", image=X, label=y)\n\n        X_train, X_test, y_train, y_test = load_data(10, str(tmp_path / \"*.npz\"))\n\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        nn.train(X_train, y_train)\n        accuracy = nn.evaluate(X_test, y_test)\n        assert 0.0 <= accuracy <= 1.0\n\n    def test_save_in_subdirectory(self, tmp_path):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        model_path = str(tmp_path / \"sub\" / \"dir\" / \"model.xml\")\n        nn.save_model(model_path)\n        assert os.path.exists(model_path)\n\n\nclass TestEdgeCases:\n    \"\"\"Edge case tests.\"\"\"\n\n    def test_single_pixel_input(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([1, 4, 4]))\n        X = np.array([[0.5]], dtype=np.float32)\n        y = np.array([[0, 1, 0, 0]], dtype=np.float32)\n        nn.train(X, y)\n        result = nn.predict(X)\n        assert len(result) == 1\n\n    def test_single_sample_training(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([5, 4, 4]))\n        X = np.random.rand(1, 5).astype(np.float32)\n        y = np.array([[0, 0, 1, 0]], dtype=np.float32)\n        nn.train(X, y)\n        result = nn.predict(X)\n        assert len(result) == 1\n\n    def test_batch_prediction(self):\n        nn = NeuralNetwork()\n        nn.create(np.int32([10, 8, 4]))\n        X = np.random.rand(5, 10).astype(np.float32)\n        y = np.eye(4)[np.random.randint(0, 4, size=5)].astype(np.float32)\n        nn.train(X, y)\n        result = nn.predict(X)\n        assert len(result) == 5\n\n    def test_object_detection_flag_reset(self):\n        od = ObjectDetection()\n        od.red_light = True\n        od2 = ObjectDetection()\n        assert od2.red_light is False\n\n    def test_rc_sequential_commands(self):\n        mock = MockSerialPort(\"/dev/ttyUSB0\")\n        rc = RCControl(mock)\n        rc.serial_port = mock\n        rc.steer(2)  # forward\n        rc.steer(0)  # left\n        rc.stop()\n        assert len(mock.written) == 3\n        assert mock.written[0] == b'\\x01'\n        assert mock.written[1] == b'\\x07'\n        assert mock.written[2] == b'\\x00'\n\n    def test_dtype_verification(self):\n        X = np.random.rand(10, 10)\n        assert X.dtype == np.float64\n        X_f32 = X.astype(np.float32)\n        assert X_f32.dtype == np.float32\n\n\nclass TestConfiguration:\n    \"\"\"Test configuration values match specification.\"\"\"\n\n    def test_rccontrol_baudrate(self):\n        assert True  # baudrate is specified in init parameter (115200)\n\n    def test_camera_params_in_radians(self):\n        d = DistanceToCamera()\n        expected_alpha = 8.0 * math.pi / 180\n        assert abs(d.alpha - expected_alpha) < 1e-10\n\n    def test_object_detection_flag_attributes(self):\n        od = ObjectDetection()\n        assert hasattr(od, 'red_light')\n        assert hasattr(od, 'green_light')\n        assert hasattr(od, 'yellow_light')\n\n\nclass TestVideoStreamHandler:\n    \"\"\"Test VideoStreamHandler class attributes.\"\"\"\n\n    def test_threshold_attributes(self):\n        from rc_driver import VideoStreamHandler\n        assert VideoStreamHandler.d_sensor_thresh == 30\n        assert VideoStreamHandler.d_stop_light_thresh == 25\n        assert VideoStreamHandler.h1 == 5.5\n        assert VideoStreamHandler.h2 == 5.5\n\n    def test_time_control_attributes(self):\n        from rc_driver import VideoStreamHandler\n        assert VideoStreamHandler.stop_start == 0\n        assert VideoStreamHandler.stop_finish == 0\n        assert VideoStreamHandler.stop_time == 0\n        assert VideoStreamHandler.drive_time_after_stop == 0\n\n\nclass TestServer:\n    \"\"\"Test Server class.\"\"\"\n\n    def test_server_init(self):\n        from rc_driver import Server\n        s = Server(\"192.168.1.100\", 8000, 8002)\n        assert s.host == \"192.168.1.100\"\n        assert s.port1 == 8000\n        assert s.port2 == 8002\n\n    def test_server_has_methods(self):\n        from rc_driver import Server\n        s = Server(\"0.0.0.0\", 8000, 8002)\n        assert hasattr(s, 'start')\n        assert hasattr(s, '_serve_video')\n        assert hasattr(s, '_serve_sensor')\n\n\nclass TestSensorDataHandler:\n    \"\"\"Test SensorDataHandler class.\"\"\"\n\n    def test_handler_exists(self):\n        from rc_driver import SensorDataHandler\n        assert SensorDataHandler is not None\n\n    def test_handler_has_handle_method(self):\n        from rc_driver import SensorDataHandler\n        assert hasattr(SensorDataHandler, 'handle')\nTESTEOF\necho \"test file written\""}
