[log] bash[1642] stdout         """
[log] bash[1642] stdout         if self.mlpc is None:
[log] bash[1642] stdout             raise RuntimeError("Model not created. Call create() before prediction.")
[log] bash[1642] stdout         if X.dtype != np.float32:
[log] bash[1642] stdout             X = X.astype(np.float32)
[log] bash[1642] stdout         if X.ndim == 1:
[log] bash[1642] stdout             X = X.reshape(1, -1)
