[log] bash[163] stdout         # Create the MLP model
[log] bash[163] stdout         self.mlpc = cv2.ml.ANN_MLP_create()
[log] bash[163] stdout         # Set layer sizes
[log] bash[163] stdout         self.mlpc.setLayerSizes(layer_sizes)
[log] bash[163] stdout         # Configure the training method: BACKPROP with learning rate=0.001, momentum=0.1
[log] bash[163] stdout         # param1 = backpropWeightScale (learning rate), param2 = backpropMomentumScale
[log] bash[163] stdout         self.mlpc.setTrainMethod(cv2.ml.ANN_MLP_BACKPROP, param1=0.001, param2=0.1)
[log] bash[163] stdout         # Set Sigmoid activation function (symmetric, slope=1.0, asymmetric coefficient=1.0)
[log] bash[163] stdout         self.mlpc.setActivationFunction(cv2.ml.ANN_MLP_SIGMOID_SYM, param1=1.0, param2=1.0)
[log] bash[163] stdout         # Set the number of iterations and termination criteria
[log] bash[163] stdout         self.mlpc.setTermCriteria((cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER, 100, 1e-6))
[log] bash[163] stdout     def train(self, X: np.ndarray, y: np.ndarray) -> None:
[log] bash[163] stdout         """
[log] bash[163] stdout         Train the neural network model using the provided data.
[log] bash[163] stdout         Parameters:
