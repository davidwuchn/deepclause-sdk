[log] bash[68] stdout # UPX unpacking processing
[log] bash[68] stdout def unpack_upx(file_path: str) -> bool:
[log] bash[68] stdout     """
[log] bash[68] stdout     Try to unpack a UPX-compressed file
[log] bash[68] stdout     Input: File path
[log] bash[68] stdout     Output: Whether the unpacking was successful
[log] bash[68] stdout     """
[log] bash[68] stdout     try:
[log] bash[68] stdout         subprocess.check_output(['./upx', '-q', '-d', file_path], stderr=subprocess.STDOUT)
[log] bash[68] stdout         return True
[log] bash[68] stdout     except subprocess.CalledProcessError:
[log] bash[68] stdout         return False
[log] bash[68] stdout # Unpacking test
