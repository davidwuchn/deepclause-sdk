[log] bash[68] stdout     }
[log] bash[68] stdout     
[log] bash[68] stdout     needs_alert = table.save_matches(binary_info, analyzer_version)
[log] bash[68] stdout     return record, needs_alert
[log] bash[68] stdout # Storage example
