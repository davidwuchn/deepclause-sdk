[log] bash[68] stdout             match.rule_name: {
[log] bash[68] stdout                 'RuleFile': match.rule_namespace,
[log] bash[68] stdout                 'RuleName': match.rule_name,
[log] bash[68] stdout                 'Meta': match.rule_metadata
[log] bash[68] stdout             } for match in binary_info.yara_matches
[log] bash[68] stdout         },
[log] bash[68] stdout         'FileInfo': {
[log] bash[68] stdout             'MD5': binary_info.computed_md5,
[log] bash[68] stdout             'S3Location': binary_info.s3_identifier,
