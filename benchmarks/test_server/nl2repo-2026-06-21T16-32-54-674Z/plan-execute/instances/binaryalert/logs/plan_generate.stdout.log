[log] bash[68] stdout # Save matching results
[log] bash[68] stdout def save_matches(binary_info: BinaryInfo, analyzer_version: int, table_name: str) -> Tuple[Dict[str, Any], bool]:
[log] bash[68] stdout     """
[log] bash[68] stdout     Save analysis results to DynamoDB
[log] bash[68] stdout     Input: Binary information, analyzer version, table name
[log] bash[68] stdout     Output: Stored record
[log] bash[68] stdout     """
[log] bash[68] stdout     table = DynamoMatchTable(table_name)
[log] bash[68] stdout     
[log] bash[68] stdout     record = {
[log] bash[68] stdout         'SHA256': binary_info.computed_sha,
[log] bash[68] stdout         'AnalyzerVersion': analyzer_version,
