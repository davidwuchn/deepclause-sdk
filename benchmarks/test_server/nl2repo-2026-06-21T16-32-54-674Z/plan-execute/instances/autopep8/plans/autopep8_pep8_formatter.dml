tool(run_bash(Command, Output), "Run a shell command in the workspace. Use cat to read files, use heredocs to write files: cat > path/to/file.py << 'ENDOFFILE'\ncode here\nENDOFFILE\nUse mkdir -p before writing to new directories. Use ls to list directories.") :-
    exec(bash(command: Command), Output).

agent_main :-
    exec(bash(command: 'cat start.md'), SpecResult),
    get_dict(stdout, SpecResult, SpecContent),
    format(string(SysPrompt), "You are an expert Python developer. You MUST implement a complete library from the specification below.\n\nCRITICAL RULES:\n1. Start coding IMMEDIATELY. The full specification is below — do NOT re-read start.md.\n2. Use run_bash for EVERYTHING: write files with heredocs, run commands.\n3. To write a file: run_bash with: mkdir -p dirname && cat > filepath << 'ENDOFFILE'\n... file content ...\nENDOFFILE\n4. NEVER call write_file_content or read_file_content — they do not exist.\n5. After writing each file, verify it with cat or python -c 'import module'.\n6. Work autonomously. No user interaction. No web_search, news_search, url_fetch, or create_skill.\n7. If a task seems unclear, make reasonable assumptions and implement anyway.\n8. DO NOT spend more than 2 iterations reading. By iteration 3 you MUST be writing code.\n9. At the end of each task, briefly summarize what you did and what is left to do. This summary carries forward to the next task.\n\n--- BEGIN SPECIFICATION ---\n~w\n--- END SPECIFICATION ---", [SpecContent]),
    system(SysPrompt),
    task("Set up the project directory structure with all necessary files including autopep8.py, update_readme.py, and supporting documentation files.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum1)),
    task("Create pyproject.toml with project metadata, dependencies including pycodestyle and tomli, and entry points for the command-line interface.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum2)),
    task("Implement core constants, regular expressions, and utility helper functions such as get_item, mutual_startswith, code_match, and split_and_strip_non_empty_lines in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum3)),
    task("Implement file encoding detection and I/O functions including detect_encoding, open_with_encoding, readlines_from_file, and find_newline in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum4)),
    task("Implement tokenization utilities including the Token namedtuple, CachedTokenizer class, _find_logical, _get_logical, and join_logical_line functions in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum5)),
    task("Implement line shortening functions including get_fixed_long_line, shorten_line, _shorten_line, and _shorten_line_at_tokens in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum6)),
    task("Implement the Atom class with reflow method and type checking methods in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum7)),
    task("Implement the Container base class and its subclasses Tuple, List, DictOrSet, ListComprehension, and IfExpression in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum8)),
    task("Implement the ReformattedLines class with all line management and formatting methods in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum9)),
    task("Implement the Reindenter class for indentation normalization and the reindent function in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum10)),
    task("Implement the FixPEP8 class constructor and core methods including fix and _fix_source in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum11)),
    task("Implement indentation fix methods in FixPEP8 class including fix_e112, fix_e113, fix_e116, fix_e117, fix_e125, and fix_e131 in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum12)),
    task("Implement whitespace fix methods in FixPEP8 class including fix_e201, fix_e224, fix_e225, fix_e231, fix_e251, fix_e262, and fix_e271 in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum13)),
    task("Implement blank line and import fix methods in FixPEP8 class including fix_e301, fix_e302, fix_e303, fix_e304, fix_e305, fix_e401, and fix_e402 in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum14)),
    task("Implement long line fix methods in FixPEP8 class including fix_e502, fix_long_line, fix_long_line_logically, and fix_long_line_physically in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum15)),
    task("Implement syntax fix methods in FixPEP8 class including fix_e701, fix_e702, fix_e704, fix_e711, fix_e712, fix_e713, fix_e714, fix_e721, fix_e722, and fix_e731 in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum16)),
    task("Implement warning fix methods in FixPEP8 class including fix_w291, fix_w391, fix_w503, fix_w504, and fix_w605 in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum17)),
    task("Implement the main fixing orchestration functions including fix_code, fix_lines, fix_file, apply_global_fixes, and get_module_imports_on_top_of_file in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum18)),
    task("Implement the command-line interface including create_parser, parse_args, read_config, read_pyproject_toml, and main functions in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum19)),
    task("Implement multi-file processing functions including fix_multiple_files, find_files, match_file, is_python_file, and _fix_file in autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum20)),
    task("Implement the update_readme.py module with split_readme, indent, help_message, check, and main functions.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum21)),
    task("Create basic tests covering fix_code functionality, file encoding detection, whitespace fixing, and command-line interface in test_autopep8.py.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum22)),
    task("Run the full test suite and fix any failures until all tests pass.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum23)),
    task("Create pyproject.toml or setup.py so the project is installable with pip install -e. Store a summary in the output variable.", string(SumPyproj)),
    task("Install the package with pip install -e . and verify basic imports work. Store a summary in the output variable.", string(SumInstall)),
    task("Run the full test suite and fix any failures until all tests pass. Store a summary in the output variable.", string(SumTests)),
    answer("Done.").

agent_main :-
    answer("Failed.").
