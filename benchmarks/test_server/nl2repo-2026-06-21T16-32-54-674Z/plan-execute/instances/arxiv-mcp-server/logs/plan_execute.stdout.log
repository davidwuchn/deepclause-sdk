[log] bash[705] stdout """Prompt manager for ArXiv MCP Server.
[log] bash[705] stdout Registers and retrieves available prompts by name, providing a centralized
[log] bash[705] stdout prompt registry for the MCP server.
[log] bash[705] stdout """
[log] bash[705] stdout from __future__ import annotations
[log] bash[705] stdout from typing import Any, Callable, Dict, List, Optional
[log] bash[705] stdout from mcp.types import Prompt, PromptArgument
[log] bash[705] stdout __all__ = ["PromptManager", "prompt_manager"]
[log] bash[705] stdout class PromptManager:
[log] bash[705] stdout     """Manages registration and retrieval of available prompts.
[log] bash[705] stdout     Each registered prompt has a name, description, optional argument
[log] bash[705] stdout     definitions, and a render function that produces the prompt text
[log] bash[705] stdout     from supplied arguments.
[log] bash[705] stdout     """
[log] bash[705] stdout     def __init__(self) -> None:
[log] bash[705] stdout         self._prompts: Dict[str, Prompt] = {}
[log] bash[705] stdout         self._renderers: Dict[str, Callable[[Dict[str, str]], str]] = {}
[log] bash[705] stdout         self._required_args: Dict[str, List[str]] = {}
[log] bash[705] stdout     # ------------------------------------------------------------------
[log] bash[705] stdout     # Registration
[log] bash[705] stdout     # ------------------------------------------------------------------
[log] bash[705] stdout     def register(
[log] bash[705] stdout         self,
[log] bash[705] stdout         name: str,
[log] bash[705] stdout         *,
[log] bash[705] stdout         description: str,
[log] bash[705] stdout         arguments: Optional[List[PromptArgument]] = None,
[log] bash[705] stdout         render: Callable[[Dict[str, str]], str],
[log] bash[705] stdout         required_args: Optional[List[str]] = None,
[log] bash[705] stdout     ) -> None:
[log] bash[705] stdout         """Register a prompt with the manager.
[log] bash[705] stdout         Args:
[log] bash[705] stdout             name: Unique prompt identifier (e.g. ``"deep-paper-analysis"``).
[log] bash[705] stdout             description: Human-readable description of the prompt.
[log] bash[705] stdout             arguments: Optional list of :class:`mcp.types.PromptArgument`
[log] bash[705] stdout                 objects that describe expected input parameters.
[log] bash[705] stdout             render: Callable that takes a dict of string arguments and
[log] bash[705] stdout                 returns the fully rendered prompt text.
[log] bash[705] stdout             required_args: Optional list of argument names that must be
[log] bash[705] stdout                 present when the prompt is retrieved.
[log] bash[705] stdout         """
[log] bash[705] stdout         self._prompts[name] = Prompt(
[log] bash[705] stdout             name=name,
[log] bash[705] stdout             description=description,
[log] bash[705] stdout             arguments=arguments if arguments is not None else [],
[log] bash[705] stdout         )
[log] bash[705] stdout         self._renderers[name] = render
[log] bash[705] stdout         self._required_args[name] = required_args or []
[log] bash[705] stdout     # ------------------------------------------------------------------
[log] bash[705] stdout     # Retrieval
[log] bash[705] stdout     # ------------------------------------------------------------------
[log] bash[705] stdout     def list_prompts(self) -> List[Prompt]:
[log] bash[705] stdout         """Return all registered :class:`mcp.types.Prompt` objects."""
[log] bash[705] stdout         return list(self._prompts.values())
[log] bash[705] stdout     def get_prompt_definition(self, name: str) -> Optional[Prompt]:
[log] bash[705] stdout         """Return the registered prompt definition, or ``None`` if not found."""
[log] bash[705] stdout         return self._prompts.get(name)
[log] bash[705] stdout     def get_required_args(self, name: str) -> List[str]:
[log] bash[705] stdout         """Return the list of required argument names for *name*."""
[log] bash[705] stdout         return self._required_args.get(name, [])
[log] bash[705] stdout     def render(self, name: str, arguments: Dict[str, str]) -> str:
[log] bash[705] stdout         """Render a registered prompt with the supplied *arguments*.
[log] bash[705] stdout         Raises:
[log] bash[705] stdout             ValueError: If the prompt is not registered.
[log] bash[705] stdout         """
[log] bash[705] stdout         render_fn = self._renderers.get(name)
[log] bash[705] stdout         if render_fn is None:
[log] bash[705] stdout             raise ValueError(f"Prompt not found: {name}")
[log] bash[705] stdout         return render_fn(arguments)
[log] bash[705] stdout     # ------------------------------------------------------------------
[log] bash[705] stdout     # Convenience
[log] bash[705] stdout     # ------------------------------------------------------------------
[log] bash[705] stdout     def has_prompt(self, name: str) -> bool:
[log] bash[705] stdout         """Return ``True`` if *name* is registered."""
[log] bash[705] stdout         return name in self._prompts
[log] bash[705] stdout     @property
[log] bash[705] stdout     def prompt_names(self) -> List[str]:
[log] bash[705] stdout         """Return sorted list of registered prompt names."""
[log] bash[705] stdout         return sorted(self._prompts.keys())
[log] bash[705] stdout # ---------------------------------------------------------------------------
[log] bash[705] stdout # Module-level singleton – import once and use everywhere
[log] bash[705] stdout # ---------------------------------------------------------------------------
[log] bash[705] stdout prompt_manager = PromptManager()
