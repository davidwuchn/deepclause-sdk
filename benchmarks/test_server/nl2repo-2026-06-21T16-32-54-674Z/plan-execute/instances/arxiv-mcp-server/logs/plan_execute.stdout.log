[log] bash[309] stdout     Returns
[log] bash[309] stdout     -------
[log] bash[309] stdout     List[types.TextContent]
[log] bash[309] stdout         A single-element list whose ``text`` field contains the JSON-serialised
[log] bash[309] stdout         search results.
[log] bash[309] stdout     """
[log] bash[309] stdout     query: str = arguments.get("query", "")
[log] bash[309] stdout     max_results: int = arguments.get("max_results", 10)
[log] bash[309] stdout     date_from: Optional[str] = arguments.get("date_from")
[log] bash[309] stdout     date_to: Optional[str] = arguments.get("date_to")
[log] bash[309] stdout     categories: Optional[List[str]] = arguments.get("categories")
[log] bash[309] stdout     # Clamp max_results to configured limit
[log] bash[309] stdout     if max_results > settings.MAX_RESULTS:
