[log] bash[701] stdout """Search tool for ArXiv MCP Server."""
[log] bash[701] stdout import json
[log] bash[701] stdout from datetime import datetime
[log] bash[701] stdout from typing import Any, Dict, List, Optional
[log] bash[701] stdout import arxiv
[log] bash[701] stdout from mcp.types import TextContent as types_TextContent
[log] bash[701] stdout from arxiv_mcp_server.config import settings
[log] bash[701] stdout # Field specifiers supported by arXiv
[log] bash[701] stdout FIELD_SPECIFIERS = {"all:", "ti:", "abs:", "au:", "cat:", "co:", "r:", "j:", "rn:", "yr:", "id:", "or:"}
[log] bash[701] stdout def _has_field_specifier(query: str) -> bool:
[log] bash[701] stdout     """Check if the query already contains a field specifier."""
[log] bash[701] stdout     for specifier in FIELD_SPECIFIERS:
[log] bash[701] stdout         if query.startswith(specifier):
[log] bash[701] stdout             return True
[log] bash[701] stdout     return False
[log] bash[701] stdout def _build_query(query: str, categories: Optional[List[str]] = None) -> str:
[log] bash[701] stdout     """Build the arXiv search query with field specifiers and optional category filter.
[log] bash[701] stdout     If the query does not already start with a field specifier, wrap it with `all:`
[log] bash[701] stdout     so that arXiv searches across all fields, improving relevance.  If categories
[log] bash[701] stdout     are provided, append a `cat:` filter for each category.
[log] bash[701] stdout     """
[log] bash[701] stdout     # If no field specifier is present, default to searching all fields
[log] bash[701] stdout     if not _has_field_specifier(query):
[log] bash[701] stdout         query = f"all:{query}"
[log] bash[701] stdout     parts = [query]
[log] bash[701] stdout     if categories:
[log] bash[701] stdout         for cat in categories:
[log] bash[701] stdout             parts.append(f"cat:{cat}")
[log] bash[701] stdout     return " AND ".join(parts)
[log] bash[701] stdout def _validate_date(date_str: str, field_name: str) -> str:
[log] bash[701] stdout     """Validate and normalize a date string to 'YYYYMMDD' format expected by arxiv API.
[log] bash[701] stdout     Raises ValueError with a descriptive message on invalid input.
[log] bash[701] stdout     """
[log] bash[701] stdout     for fmt in ("%Y-%m-%d", "%Y%m%d", "%Y/%m/%d"):
[log] bash[701] stdout         try:
[log] bash[701] stdout             return datetime.strptime(date_str, fmt).strftime("%Y%m%d")
[log] bash[701] stdout         except ValueError:
[log] bash[701] stdout             continue
[log] bash[701] stdout     raise ValueError(
[log] bash[701] stdout         f"Invalid date format for '{field_name}': '{date_str}'. "
[log] bash[701] stdout         f"Use ISO format (YYYY-MM-DD)."
[log] bash[701] stdout     )
[log] bash[701] stdout def _format_paper(paper: arxiv.Result) -> Dict[str, Any]:
[log] bash[701] stdout     """Convert an arxiv.Result into a plain dict for JSON serialization."""
[log] bash[701] stdout     return {
[log] bash[701] stdout         "id": paper.entry_id.split("/")[-1],
[log] bash[701] stdout         "title": paper.title,
[log] bash[701] stdout         "authors": paper.authors,
[log] bash[701] stdout         "abstract": paper.summary,
[log] bash[701] stdout         "categories": list(paper.categories),
[log] bash[701] stdout         "published": paper.published.isoformat() if paper.published else None,
[log] bash[701] stdout         "url": paper.pdf_url,
[log] bash[701] stdout         "resource_uri": f"arxiv://{paper.entry_id.split('/')[-1]}",
[log] bash[701] stdout     }
[log] bash[701] stdout async def handle_search(arguments: Dict[str, Any]) -> List[types_TextContent]:
[log] bash[701] stdout     """Handle paper search requests.
[log] bash[701] stdout     Parameters
[log] bash[701] stdout     ----------
[log] bash[701] stdout     arguments : dict
[log] bash[701] stdout         - query (str): The search query string.
[log] bash[701] stdout         - max_results (int, optional): Maximum number of results (default: 10).
[log] bash[701] stdout         - date_from (str, optional): Start date in ISO format (YYYY-MM-DD).
[log] bash[701] stdout         - date_to (str, optional): End date in ISO format (YYYY-MM-DD).
[log] bash[701] stdout         - categories (List[str], optional): Category filters (e.g. ["cs.AI", "cs.LG"]).
[log] bash[701] stdout     Returns
[log] bash[701] stdout     -------
[log] bash[701] stdout     List[types.TextContent]
[log] bash[701] stdout         A single-element list whose ``text`` field contains the JSON-serialised
[log] bash[701] stdout         search results.
[log] bash[701] stdout     """
[log] bash[701] stdout     query: str = arguments.get("query", "")
[log] bash[701] stdout     max_results: int = arguments.get("max_results", 10)
[log] bash[701] stdout     date_from: Optional[str] = arguments.get("date_from")
[log] bash[701] stdout     date_to: Optional[str] = arguments.get("date_to")
[log] bash[701] stdout     categories: Optional[List[str]] = arguments.get("categories")
[log] bash[701] stdout     # Clamp max_results to configured limit
[log] bash[701] stdout     if max_results > settings.MAX_RESULTS:
[log] bash[701] stdout         max_results = settings.MAX_RESULTS
[log] bash[701] stdout     # --- Date validation ---------------------------------------------------
[log] bash[701] stdout     if date_from:
[log] bash[701] stdout         try:
[log] bash[701] stdout             date_from = _validate_date(date_from, "date_from")
[log] bash[701] stdout         except ValueError as exc:
[log] bash[701] stdout             return [
[log] bash[701] stdout                 types_TextContent(
[log] bash[701] stdout                     type="text",
[log] bash[701] stdout                     text=f"Error: Invalid date format for date_from: {exc.args[0]}",
[log] bash[701] stdout                 )
[log] bash[701] stdout             ]
[log] bash[701] stdout     if date_to:
