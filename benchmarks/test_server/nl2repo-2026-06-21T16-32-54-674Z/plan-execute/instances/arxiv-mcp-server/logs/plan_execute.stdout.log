[log] bash[353] stdout """Papers resource module for ArXiv MCP Server.
[log] bash[353] stdout Provides paper resources through the MCP protocol, enabling AI assistants
[log] bash[353] stdout to list and read downloaded academic papers as structured resources.
[log] bash[353] stdout """
[log] bash[353] stdout from pathlib import Path
[log] bash[353] stdout from typing import Iterable, List
[log] bash[353] stdout from mcp.server.lowlevel.helper_types import ReadResourceContents
[log] bash[353] stdout from mcp.types import (
[log] bash[353] stdout     Resource,
[log] bash[353] stdout     TextResourceContents,
[log] bash[353] stdout )
[log] bash[353] stdout from arxiv_mcp_server.config import settings
[log] bash[353] stdout def _storage_path() -> Path:
[log] bash[353] stdout     """Return the resolved storage path for downloaded papers."""
[log] bash[353] stdout     return Path(settings.STORAGE_PATH).resolve()
[log] bash[353] stdout def list_papers() -> List[Resource]:
[log] bash[353] stdout     """List all locally available paper resources.
[log] bash[353] stdout     Scans the storage directory for ``.md`` files and returns a list of
[log] bash[353] stdout     :class:`mcp.types.Resource` objects, one per found paper.
[log] bash[353] stdout     Returns
[log] bash[353] stdout     -------
[log] bash[353] stdout     list[Resource]
[log] bash[353] stdout         A list of MCP Resource objects describing each downloaded paper.
[log] bash[353] stdout     """
[log] bash[353] stdout     papers_dir = _storage_path()
[log] bash[353] stdout     resources: List[Resource] = []
[log] bash[353] stdout     if not papers_dir.exists():
[log] bash[353] stdout         return resources
[log] bash[353] stdout     for md_path in sorted(papers_dir.glob("*.md")):
[log] bash[353] stdout         paper_id = md_path.stem
[log] bash[353] stdout         resource_uri = f"arxiv://{paper_id}"
[log] bash[353] stdout         # Try to extract a title from the first line (Markdown heading)
[log] bash[353] stdout         title = paper_id
[log] bash[353] stdout         try:
[log] bash[353] stdout             first_line = md_path.read_text(encoding="utf-8").splitlines()[0]
[log] bash[353] stdout             if first_line.startswith("# "):
[log] bash[353] stdout                 title = first_line.lstrip("# ").strip()
[log] bash[353] stdout             elif first_line.strip():
[log] bash[353] stdout                 title = first_line.strip()
[log] bash[353] stdout         except (IndexError, OSError):
[log] bash[353] stdout             pass
[log] bash[353] stdout         resources.append(
[log] bash[353] stdout             Resource(
[log] bash[353] stdout                 uri=resource_uri,
[log] bash[353] stdout                 name=paper_id,
[log] bash[353] stdout                 title=title,
[log] bash[353] stdout                 description=f"Downloaded arXiv paper: {paper_id}",
[log] bash[353] stdout                 mimeType="text/markdown",
[log] bash[353] stdout             )
[log] bash[353] stdout         )
[log] bash[353] stdout     return resources
[log] bash[353] stdout async def read_paper_resource(uri: str) -> Iterable[ReadResourceContents]:
[log] bash[353] stdout     """Read the content of a single paper resource.
[log] bash[353] stdout     Parameters
[log] bash[353] stdout     ----------
[log] bash[353] stdout     uri : str
[log] bash[353] stdout         The resource URI in the form ``arxiv://<paper_id>``.
[log] bash[353] stdout     Returns
[log] bash[353] stdout     -------
[log] bash[353] stdout     Iterable[ReadResourceContents]
[log] bash[353] stdout         An iterable containing exactly one :class:`ReadResourceContents`
[log] bash[353] stdout         with the Markdown text of the paper.
[log] bash[353] stdout     Raises
[log] bash[353] stdout     ------
[log] bash[353] stdout     ValueError
[log] bash[353] stdout         If the URI scheme is not ``arxiv://``.
[log] bash[353] stdout     FileNotFoundError
[log] bash[353] stdout         If the requested paper file does not exist in local storage.
[log] bash[353] stdout     """
[log] bash[353] stdout     # Parse the URI
[log] bash[353] stdout     if not uri.startswith("arxiv://"):
[log] bash[353] stdout         raise ValueError(f"Unsupported resource URI scheme: {uri}")
[log] bash[353] stdout     paper_id = uri[len("arxiv://") :]
[log] bash[353] stdout     if not paper_id:
[log] bash[353] stdout         raise ValueError("Empty paper_id in resource URI")
[log] bash[353] stdout     md_path = _storage_path() / f"{paper_id}.md"
[log] bash[353] stdout     if not md_path.exists():
[log] bash[353] stdout         raise FileNotFoundError(
[log] bash[353] stdout             f"Paper '{paper_id}' not found in local storage at {md_path}"
[log] bash[353] stdout         )
[log] bash[353] stdout     content = md_path.read_text(encoding="utf-8")
[log] bash[353] stdout     return [
[log] bash[353] stdout         ReadResourceContents(
[log] bash[353] stdout             content=content,
[log] bash[353] stdout             mime_type="text/markdown",
[log] bash[353] stdout         )
