# Date range search
async def test_search_with_dates():
    result = await handle_search({
        "query": "test query",
        "date_from": "2022-01-01",
        "date_to": "2024-01-01",
        "max_results": 1
    })
    
    content = json.loads(result[0].text)
    assert content["total_results"] == 1
    assert len(content["papers"]) == 1

# Invalid date handling
