[log] bash[229] stdout     Raises ValueError with a descriptive message on invalid input.
[log] bash[229] stdout     """
[log] bash[229] stdout     for fmt in ("%Y-%m-%d", "%Y%m%d", "%Y/%m/%d"):
[log] bash[229] stdout         try:
[log] bash[229] stdout             return datetime.strptime(date_str, fmt).strftime("%Y%m%d")
[log] bash[229] stdout         except ValueError:
[log] bash[229] stdout             continue
[log] bash[229] stdout     raise ValueError(
[log] bash[229] stdout         f"Invalid date format for '{field_name}': '{date_str}'. "
[log] bash[229] stdout         f"Use ISO format (YYYY-MM-DD)."
[log] bash[229] stdout     )
