[log] bash[229] stdout         "resource_uri": f"arxiv://{paper.entry_id.split('/')[-1]}",
[log] bash[229] stdout     }
[log] bash[229] stdout async def handle_search(arguments: Dict[str, Any]) -> List[types_TextContent]:
[log] bash[229] stdout     """Handle paper search requests.
[log] bash[229] stdout     Parameters
[log] bash[229] stdout     ----------
[log] bash[229] stdout     arguments : dict
[log] bash[229] stdout         - query (str): The search query string.
[log] bash[229] stdout         - max_results (int, optional): Maximum number of results (default: 10).
[log] bash[229] stdout         - date_from (str, optional): Start date in ISO format (YYYY-MM-DD).
[log] bash[229] stdout         - date_to (str, optional): End date in ISO format (YYYY-MM-DD).
[log] bash[229] stdout         - categories (List[str], optional): Category filters (e.g. ["cs.AI", "cs.LG"]).
[log] bash[229] stdout     Returns
[log] bash[229] stdout     -------
[log] bash[229] stdout     List[types.TextContent]
[log] bash[229] stdout         A single-element list whose ``text`` field contains the JSON-serialised
[log] bash[229] stdout         search results.
[log] bash[229] stdout     """
[log] bash[229] stdout     query: str = arguments.get("query", "")
[log] bash[229] stdout     max_results: int = arguments.get("max_results", 10)
[log] bash[229] stdout     date_from: Optional[str] = arguments.get("date_from")
[log] bash[229] stdout     date_to: Optional[str] = arguments.get("date_to")
[log] bash[229] stdout     categories: Optional[List[str]] = arguments.get("categories")
[log] bash[229] stdout     # Clamp max_results to configured limit
[log] bash[229] stdout     if max_results > settings.MAX_RESULTS:
