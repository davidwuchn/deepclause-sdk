[log] bash[364] stdout         render: Callable[[Dict[str, str]], str],
[log] bash[364] stdout         required_args: Optional[List[str]] = None,
[log] bash[364] stdout     ) -> None:
[log] bash[364] stdout         """Register a prompt with the manager.
[log] bash[364] stdout         Args:
[log] bash[364] stdout             name: Unique prompt identifier (e.g. ``"deep-paper-analysis"``).
[log] bash[364] stdout             description: Human-readable description of the prompt.
[log] bash[364] stdout             arguments: Optional list of :class:`mcp.types.PromptArgument`
[log] bash[364] stdout                 objects that describe expected input parameters.
[log] bash[364] stdout             render: Callable that takes a dict of string arguments and
[log] bash[364] stdout                 returns the fully rendered prompt text.
[log] bash[364] stdout             required_args: Optional list of argument names that must be
[log] bash[364] stdout                 present when the prompt is retrieved.
[log] bash[364] stdout         """
[log] bash[364] stdout         self._prompts[name] = Prompt(
[log] bash[364] stdout             name=name,
[log] bash[364] stdout             description=description,
[log] bash[364] stdout             arguments=arguments if arguments is not None else [],
[log] bash[364] stdout         )
[log] bash[364] stdout         self._renderers[name] = render
[log] bash[364] stdout         self._required_args[name] = required_args or []
[log] bash[364] stdout     # ------------------------------------------------------------------
[log] bash[364] stdout     # Retrieval
[log] bash[364] stdout     # ------------------------------------------------------------------
[log] bash[364] stdout     def list_prompts(self) -> List[Prompt]:
[log] bash[364] stdout         """Return all registered :class:`mcp.types.Prompt` objects."""
[log] bash[364] stdout         return list(self._prompts.values())
[log] bash[364] stdout     def get_prompt_definition(self, name: str) -> Optional[Prompt]:
[log] bash[364] stdout         """Return the registered prompt definition, or ``None`` if not found."""
[log] bash[364] stdout         return self._prompts.get(name)
[log] bash[364] stdout     def get_required_args(self, name: str) -> List[str]:
[log] bash[364] stdout         """Return the list of required argument names for *name*."""
[log] bash[364] stdout         return self._required_args.get(name, [])
[log] bash[364] stdout     def render(self, name: str, arguments: Dict[str, str]) -> str:
[log] bash[364] stdout         """Render a registered prompt with the supplied *arguments*.
[log] bash[364] stdout         Raises:
[log] bash[364] stdout             ValueError: If the prompt is not registered.
[log] bash[364] stdout         """
[log] bash[364] stdout         render_fn = self._renderers.get(name)
[log] bash[364] stdout         if render_fn is None:
[log] bash[364] stdout             raise ValueError(f"Prompt not found: {name}")
[log] bash[364] stdout         return render_fn(arguments)
[log] bash[364] stdout     # ------------------------------------------------------------------
[log] bash[364] stdout     # Convenience
[log] bash[364] stdout     # ------------------------------------------------------------------
[log] bash[364] stdout     def has_prompt(self, name: str) -> bool:
