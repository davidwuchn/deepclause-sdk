[log] bash[703] stdout def _extract_paper_metadata(md_path: Path) -> Dict[str, Any]:
[log] bash[703] stdout     """Extract basic metadata from a Markdown paper file.
[log] bash[703] stdout     Attempts to pull title from the first ``# heading`` line and returns
[log] bash[703] stdout     whatever structural hints are available.
[log] bash[703] stdout     """
[log] bash[703] stdout     meta: Dict[str, Any] = {
[log] bash[703] stdout         "id": md_path.stem,
[log] bash[703] stdout         "file_path": str(md_path.resolve()),
[log] bash[703] stdout         "resource_uri": f"file://{md_path.resolve()}",
[log] bash[703] stdout         "size_bytes": md_path.stat().st_size,
[log] bash[703] stdout     }
[log] bash[703] stdout     try:
[log] bash[703] stdout         text = md_path.read_text(encoding="utf-8")
[log] bash[703] stdout         # Try to grab the title from the first heading line
[log] bash[703] stdout         for line in text.splitlines():
[log] bash[703] stdout             stripped = line.strip()
[log] bash[703] stdout             if stripped.startswith("# "):
[log] bash[703] stdout                 meta["title"] = stripped[2:].strip()
[log] bash[703] stdout                 break
[log] bash[703] stdout             elif stripped and not stripped.startswith("#"):
[log] bash[703] stdout                 # First non-empty, non-heading line as fallback
[log] bash[703] stdout                 meta["first_line"] = stripped[:120]
[log] bash[703] stdout                 break
[log] bash[703] stdout         # Count approximate page-length
[log] bash[703] stdout         meta["lines"] = text.count("\n") + 1
[log] bash[703] stdout         meta["characters"] = len(text)
[log] bash[703] stdout     except Exception:
[log] bash[703] stdout         pass
[log] bash[703] stdout     return meta
