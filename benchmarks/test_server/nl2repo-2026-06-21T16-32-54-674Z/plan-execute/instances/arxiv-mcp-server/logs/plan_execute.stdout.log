urces.papers.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            res = list_papers()\n        assert res[0].title == \"noid\"  # fallback\n\n\nclass TestResourceReadPaper:\n    @pytest.mark.asyncio\n    async def test_valid_uri(self, tmp_path, mocker):\n        content = \"# Paper\\n\\nBody text.\"\n        (tmp_path / \"test.md\").write_text(content, encoding=\"utf-8\")\n        with mocker.patch(\"arxiv_mcp_server.resources.papers.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            result = await read_paper_resource(\"arxiv://test\")\n        items = list(result)\n        assert len(items) == 1\n        item = items[0]\n        assert isinstance(item, ReadResourceContents)\n        assert item.content == content\n        assert item.mime_type == \"text/markdown\"\n\n    @pytest.mark.asyncio\n    async def test_invalid_uri_scheme(self):\n        with pytest.raises(ValueError, match=\"Unsupported resource URI scheme\"):\n            await read_paper_resource(\"http://example.com\")\n\n    @pytest.mark.asyncio\n    async def test_empty_paper_id(self):\n        with pytest.raises(ValueError, match=\"Empty paper_id\"):\n            await read_paper_resource(\"arxiv://\")\n\n    @pytest.mark.asyncio\n    async def test_missing_paper(self, tmp_path, mocker):\n        with mocker.patch(\"arxiv_mcp_server.resources.papers.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            with pytest.raises(FileNotFoundError, match=\"not found in local storage\"):\n                await read_paper_resource(\"arxiv://nope\")\nENDOFFILE"}
