[log] bash[709] stdout     return Path(settings.STORAGE_PATH).resolve()
[log] bash[709] stdout def list_papers() -> List[Resource]:
[log] bash[709] stdout     """List all locally available paper resources.
[log] bash[709] stdout     Scans the storage directory for ``.md`` files and returns a list of
[log] bash[709] stdout     :class:`mcp.types.Resource` objects, one per found paper.
[log] bash[709] stdout     Returns
[log] bash[709] stdout     -------
[log] bash[709] stdout     list[Resource]
[log] bash[709] stdout         A list of MCP Resource objects describing each downloaded paper.
[log] bash[709] stdout     """
[log] bash[709] stdout     papers_dir = _storage_path()
[log] bash[709] stdout     resources: List[Resource] = []
[log] bash[709] stdout     if not papers_dir.exists():
[log] bash[709] stdout         return resources
[log] bash[709] stdout     for md_path in sorted(papers_dir.glob("*.md")):
[log] bash[709] stdout         paper_id = md_path.stem
[log] bash[709] stdout         resource_uri = f"arxiv://{paper_id}"
[log] bash[709] stdout         # Try to extract a title from the first line (Markdown heading)
[log] bash[709] stdout         title = paper_id
[log] bash[709] stdout         try:
[log] bash[709] stdout             first_line = md_path.read_text(encoding="utf-8").splitlines()[0]
[log] bash[709] stdout             if first_line.startswith("# "):
[log] bash[709] stdout                 title = first_line.lstrip("# ").strip()
[log] bash[709] stdout             elif first_line.strip():
[log] bash[709] stdout                 title = first_line.strip()
[log] bash[709] stdout         except (IndexError, OSError):
[log] bash[709] stdout             pass
[log] bash[709] stdout         resources.append(
[log] bash[709] stdout             Resource(
[log] bash[709] stdout                 uri=resource_uri,
[log] bash[709] stdout                 name=paper_id,
[log] bash[709] stdout                 title=title,
[log] bash[709] stdout                 description=f"Downloaded arXiv paper: {paper_id}",
[log] bash[709] stdout                 mimeType="text/markdown",
[log] bash[709] stdout             )
[log] bash[709] stdout         )
[log] bash[709] stdout     return resources
[log] bash[709] stdout async def read_paper_resource(uri: str) -> Iterable[ReadResourceContents]:
[log] bash[709] stdout     """Read the content of a single paper resource.
[log] bash[709] stdout     Parameters
[log] bash[709] stdout     ----------
[log] bash[709] stdout     uri : str
[log] bash[709] stdout         The resource URI in the form ``arxiv://<paper_id>``.
[log] bash[709] stdout     Returns
[log] bash[709] stdout     -------
[log] bash[709] stdout     Iterable[ReadResourceContents]
[log] bash[709] stdout         An iterable containing exactly one :class:`ReadResourceContents`
[log] bash[709] stdout         with the Markdown text of the paper.
[log] bash[709] stdout     Raises
[log] bash[709] stdout     ------
[log] bash[709] stdout     ValueError
[log] bash[709] stdout         If the URI scheme is not ``arxiv://``.
[log] bash[709] stdout     FileNotFoundError
[log] bash[709] stdout         If the requested paper file does not exist in local storage.
[log] bash[709] stdout     """
[log] bash[709] stdout     # Parse the URI
[log] bash[709] stdout     if not uri.startswith("arxiv://"):
[log] bash[709] stdout         raise ValueError(f"Unsupported resource URI scheme: {uri}")
[log] bash[709] stdout     paper_id = uri[len("arxiv://") :]
[log] bash[709] stdout     if not paper_id:
[log] bash[709] stdout         raise ValueError("Empty paper_id in resource URI")
[log] bash[709] stdout     md_path = _storage_path() / f"{paper_id}.md"
[log] bash[709] stdout     if not md_path.exists():
[log] bash[709] stdout         raise FileNotFoundError(
[log] bash[709] stdout             f"Paper '{paper_id}' not found in local storage at {md_path}"
[log] bash[709] stdout         )
[log] bash[709] stdout     content = md_path.read_text(encoding="utf-8")
[log] bash[709] stdout     return [
[log] bash[709] stdout         ReadResourceContents(
[log] bash[709] stdout             content=content,
[log] bash[709] stdout             mime_type="text/markdown",
[log] bash[709] stdout         )
[log] bash[709] stdout     ]
