------------------------------------------------------------\n\nclass TestGetPaperPath:\n    def test_default_suffix(self):\n        path = get_paper_path(\"2103.12345\")\n        assert path.name == \"2103.12345.md\"\n        assert path.suffix == \".md\"\n\n    def test_explicit_pdf_suffix(self):\n        path = get_paper_path(\"2103.12345\", \".pdf\")\n        assert path.name == \"2103.12345.pdf\"\n        assert path.suffix == \".pdf\"\n\n    def test_returns_path_obj(self):\n        assert isinstance(get_paper_path(\"x\"), Path)\n\n    def test_in_storage_dir(self):\n        from arxiv_mcp_server.config import settings\n        path = get_paper_path(\"x\")\n        assert str(path.parent) == str(settings.STORAGE_PATH)\n\n    def test_creates_storage_dir(self, tmp_path, mocker):\n        new_dir = tmp_path / \"new_storage\"\n        mocker.patch.object(\n            Path, \"resolve\", side_effect=lambda self: Path(str(self)) if str(self) != str(tmp_path) else new_dir.parent.resolve()\n        )\n        # We test via Settings' STORAGE_PATH override\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = new_dir\n            p = get_paper_path(\"test\")\n            assert new_dir.exists()\n            assert p == new_dir / \"test.md\"\n\n\n# ---------------------------------------------------------------------------\n# handle_download — existing paper\n# ---------------------------------------------------------------------------\n\nclass TestHandleDownloadExisting:\n    @pytest.mark.asyncio\n    async def test_existing_md_returns_success(self, tmp_path, mocker):\n        \"\"\"If a .md file exists, download returns 'success' immediately.\"\"\"\n        md_file = tmp_path / \"test.md\"\n        md_file.write_text(\"# Test\\nContent\", encoding=\"utf-8\")\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            result = await handle_download({\"paper_id\": \"test\"})\n            data = json.loads(result[0].text)\n            assert data[\"status\"] == \"success\"\n            assert \"already available\" in data[\"message\"]\n            assert \"resource_uri\" in data\n\n    @pytest.mark.asyncio\n    async def test_existing_paper_via_check_status(self, tmp_path, mocker):\n        md_file = tmp_path / \"test.md\"\n        md_file.write_text(\"# Test\\nContent\", encoding=\"utf-8\")\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            result = await handle_download({\"paper_id\": \"test\", \"check_status\": True})\n            data = json.loads(result[0].text)\n            assert data[\"status\"] == \"success\"\n            assert \"ready\" in data[\"message\"].lower() or \"Paper is ready\" == data[\"message\"]\n\n\n# ---------------------------------------------------------------------------\n# handle_download — nonexistent paper\n# ---------------------------------------------------------------------------\n\nclass TestHandleDownloadNonexistent:\n    @pytest.mark.asyncio\n    async def test_paper_not_found(self, tmp_path, mocker):\n        \"\"\"Paper not on arXiv → error status.\"\"\"\n        mock_client = MagicMock()\n        mock_client.results.return_value = iter([])  # StopIteration\n\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            with patch(\"arxiv.Client\", return_value=mock_client):\n                result = await handle_download({\"paper_id\": \"invalid.12345\"})\n                data = json.loads(result[0].text)\n                assert data[\"status\"] == \"error\"\n                assert \"not found on arXiv\" in data[\"message\"]\n\n    @pytest.mark.asyncio\n    async def test_arxiv_client_raises(self, tmp_path, mocker):\n        \"\"\"Network error during fetch → error status.\"\"\"\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            with patch(\"arxiv.Client\", side_effect=Exception(\"network error\")):\n                result = await handle_download({\"paper_id\": \"2103.12345\"})\n                data = json.loads(result[0].text)\n                assert data[\"status\"] == \"error\"\n                assert \"Failed to fetch paper metadata\" in data[\"message\"]\n\n\n# ---------------------------------------------------------------------------\n# handle_download — status-only checks\n# ---------------------------------------------------------------------------\n\nclass TestHandleDownloadCheckStatus:\n    @pytest.mark.asyncio\n    async def test_unknown_status(self, tmp_path, mocker):\n        \"\"\"No file, no status entry → unknown.\"\"\"\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            # Clear conversion_statuses to be safe\n            conversion_statuses.clear()\n            result = await handle_download({\"paper_id\": \"no-such.12345\", \"check_status\": True})\n            data = json.loads(result[0].text)\n            assert data[\"status\"] == \"unknown\"\n            assert \"No download or conversion\" in data[\"message\"]\n\n    @pytest.mark.asyncio\n    async def test_in_progress_status(self, tmp_path, mocker):\n        \"\"\"Entry in conversion_statuses → returns it.\"\"\"\n        conversion_statuses.clear()\n        conversion_statuses[\"test.123\"] = ConversionStatus(\n            paper_id=\"test.123\",\n            status=\"converting\",\n            started_at=datetime(2024, 6, 1, 10, 0, 0),\n        )\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            result = await handle_download({\"paper_id\": \"test.123\", \"check_status\": True})\n            data = json.loads(result[0].text)\n            assert data[\"status\"] == \"converting\"\n            assert data[\"started_at\"] == \"2024-06-01T10:00:00\"\n            del conversion_statuses[\"test.123\"]\n\n\n# ---------------------------------------------------------------------------\n# handle_download — full download lifecycle (mocked)\n# ---------------------------------------------------------------------------\n\nclass TestHandleDownloadFullLifecycle:\n    @pytest.mark.asyncio\n    async def test_successful_download_and_convert(self, tmp_path, mocker):\n        \"\"\"End-to-end: download PDF, convert to MD, return success.\"\"\"\n        mock_client = MagicMock()\n        mock_paper = MagicMock()\n        mock_paper.pdf_url = \"https://arxiv.org/pdf/test.123.pdf\"\n        mock_client.results.return_value = iter([mock_paper])\n\n        # Patch urllib urlretrieve\n        mock_urllib = MagicMock()\n        mocker.patch(\"arxiv_mcp_server.tools.download.urllib\")\n        mocker.patch(\"arxiv_mcp_server.tools.download.urllib.request.urlretrieve\")\n\n        # Patch pymupdf4llm.to_markdown\n        mocker.patch(\"pymupdf4llm.to_markdown\", return_value=\"# Converted\\nBody\")\n\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            with patch(\"arxiv.Client\", return_value=mock_client):\n                result = await handle_download({\"paper_id\": \"test.123\"})\n                data = json.loads(result[0].text)\n                assert data[\"status\"] == \"success\"\n                assert \"downloaded and converted\" in data[\"message\"]\n                assert \"resource_uri\" in data\n                assert (tmp_path / \"test.123.md\").exists()\n                assert (tmp_path / \"test.123.md\").read_text().startswith(\"# Converted\")\n\n    @pytest.mark.asyncio\n    async def test_download_failure(self, tmp_path, mocker):\n        \"\"\"Download raises → error status.\"\"\"\n        mock_client = MagicMock()\n        mock_paper = MagicMock()\n        mock_paper.pdf_url = \"https://arxiv.org/pdf/test.123.pdf\"\n        mock_client.results.return_value = iter([mock_paper])\n\n        mocker.patch(\"arxiv_mcp_server.tools.download.urllib\")\n        mocker.patch(\n            \"arxiv_mcp_server.tools.download.urllib.request.urlretrieve\",\n            side_effect=OSError(\"disk full\"),\n        )\n\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            with patch(\"arxiv.Client\", return_value=mock_client):\n                result = await handle_download({\"paper_id\": \"test.123\"})\n                data = json.loads(result[0].text)\n                assert data[\"status\"] == \"error\"\n                assert \"Download failed\" in data[\"message\"]\n\n    @pytest.mark.asyncio\n    async def test_conversion_failure(self, tmp_path, mocker):\n        \"\"\"Conversion raises → error status.\"\"\"\n        mock_client = MagicMock()\n        mock_paper = MagicMock()\n        mock_paper.pdf_url = \"https://arxiv.org/pdf/test.123.pdf\"\n        mock_client.results.return_value = iter([mock_paper])\n\n        mocker.patch(\"arxiv_mcp_server.tools.download.urllib\")\n        mocker.patch(\"arxiv_mcp_server.tools.download.urllib.request.urlretrieve\")\n        mocker.patch(\"pymupdf4llm.to_markdown\", side_effect=ValueError(\"bad pdf\"))\n\n        with patch(\"arxiv_mcp_server.tools.download.settings\") as mock_settings:\n            mock_settings.STORAGE_PATH = tmp_path\n            mock_settings.BATCH_SIZE = 10\n            with patch(\"arxiv.Client\", return_value=mock_client):\n                result = await handle_download({\"paper_id\": \"test.123\"})\n                data = json.loads(result[0].text)\n                assert data[\"status\"] == \"error\"\n                assert \"Conversion failed\" in data[\"message\"]\nENDOFFILE"}
