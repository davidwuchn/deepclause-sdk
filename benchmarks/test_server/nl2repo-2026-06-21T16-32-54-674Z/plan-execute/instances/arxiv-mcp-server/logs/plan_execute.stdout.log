[log] bash[229] stdout                     text=f"Error: Invalid date format for date_to: {exc.args[0]}",
[log] bash[229] stdout                 )
[log] bash[229] stdout             ]
[log] bash[229] stdout     # --- Build the search query --------------------------------------------
[log] bash[229] stdout     search_query = _build_query(query, categories)
[log] bash[229] stdout     # --- Execute the arXiv search ------------------------------------------
[log] bash[229] stdout     try:
[log] bash[229] stdout         search = arxiv.Search(
