[log] bash[309] stdout # Field specifiers supported by arXiv
[log] bash[309] stdout FIELD_SPECIFIERS = {"all:", "ti:", "abs:", "au:", "cat:", "co:", "r:", "j:", "rn:", "yr:", "id:", "or:"}
