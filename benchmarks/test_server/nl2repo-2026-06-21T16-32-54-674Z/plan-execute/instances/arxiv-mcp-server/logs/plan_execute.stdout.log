ALYSIS_PROMPT\n        assert \"results-analysis\" in PAPER_ANALYSIS_PROMPT\n\n\nclass TestPromptManager:\n    def test_register_and_list(self):\n        pm = PromptManager()\n        assert pm.list_prompts() == []\n        pm.register(\n            name=\"test\",\n            description=\"A test prompt\",\n            render=lambda args: f\"Hello {args['name']}\",\n        )\n        prompts = pm.list_prompts()\n        assert len(prompts) == 1\n        assert prompts[0].name == \"test\"\n\n    def test_get_required_args(self):\n        pm = PromptManager()\n        pm.register(\n            name=\"t\",\n            description=\"d\",\n            render=lambda a: a[\"x\"],\n            required_args=[\"x\"],\n        )\n        assert pm.get_required_args(\"t\") == [\"x\"]\n        assert pm.get_required_args(\"missing\") == []\n\n    def test_render(self):\n        pm = PromptManager()\n        pm.register(\n            name=\"greet\",\n            description=\"Greets someone\",\n            render=lambda a: f\"Hi {a['name']}\",\n        )\n        assert pm.render(\"greet\", {\"name\": \"World\"}) == \"Hi World\"\n\n    def test_render_unknown_raises(self):\n        pm = PromptManager()\n        with pytest.raises(ValueError, match=\"Prompt not found\"):\n            pm.render(\"nope\", {})\n\n    def test_has_prompt(self):\n        pm = PromptManager()\n        assert pm.has_prompt(\"x\") is False\n        pm.register(name=\"x\", description=\"d\", render=lambda a: \"ok\")\n        assert pm.has_prompt(\"x\") is True\n\n    def test_prompt_names_sorted(self):\n        pm = PromptManager()\n        pm.register(name=\"b\", description=\"d\", render=lambda a: \"b\")\n        pm.register(name=\"a\", description=\"d\", render=lambda a: \"a\")\n        assert pm.prompt_names == [\"a\", \"b\"]\n\n    def test_get_prompt_definition(self):\n        pm = PromptManager()\n        pm.register(name=\"x\", description=\"desc\", render=lambda a: \"x\")\n        p = pm.get_prompt_definition(\"x\")\n        assert isinstance(p, Prompt)\n        assert p.name == \"x\"\n        assert p.description == \"desc\"\n\n    def test_get_prompt_definition_missing(self):\n        pm = PromptManager()\n        assert pm.get_prompt_definition(\"nope\") is None\n\n\nclass TestBuiltinPrompts:\n    def test_deep_paper_analysis_registered(self):\n        assert prompt_manager.has_prompt(\"deep-paper-analysis\")\n\n    def test_list_prompts_returns_deep_paper_analysis(self):\n        prompts = prompt_manager.list_prompts()\n        names = [p.name for p in prompts]\n        assert \"deep-paper-analysis\" in names\n\n    def test_deep_paper_analysis_has_required_args(self):\n        assert prompt_manager.get_required_args(\"deep-paper-analysis\") == [\"paper_id\"]\n\n\nclass TestListPromptsHandler:\n    @pytest.mark.asyncio\n    async def test_returns_list(self):\n        result = await list_prompts()\n        assert isinstance(result, list)\n\n    @pytest.mark.asyncio\n    async def test_contains_deep_paper_analysis(self):\n        result = await list_prompts()\n        names = [p.name for p in result]\n        assert \"deep-paper-analysis\" in names\n\n    @pytest.mark.asyncio\n    async def test_prompt_objects_have_description(self):\n        result = await list_prompts()\n        for p in result:\n            assert isinstance(p, Prompt)\n            assert p.description is not None and len(p.description) > 0\n\n\nclass TestGetPromptHandler:\n    @pytest.mark.asyncio\n    async def test_valid_prompt(self):\n        result = await get_prompt(\"deep-paper-analysis\", {\"paper_id\": \"2401.00123\"})\n        assert isinstance(result, GetPromptResult)\n        assert len(result.messages) == 1\n        msg = result.messages[0]\n        assert msg.role == \"user\"\n        assert isinstance(msg.content, TextContent)\n        assert \"2401.00123\" in msg.content.text\n\n    @pytest.mark.asyncio\n    async def test_invalid_name_raises(self):\n        with pytest.raises(ValueError, match=\"Prompt not found\"):\n            await get_prompt(\"invalid-prompt\", {\"paper_id\": \"x\"})\n\n    @pytest.mark.asyncio\n    async def test_none_arguments_raises(self):\n        with pytest.raises(ValueError, match=\"No arguments provided\"):\n            await get_prompt(\"deep-paper-analysis\", None)\n\n    @pytest.mark.asyncio\n    async def test_empty_arguments_raises(self):\n        with pytest.raises(ValueError, match=\"No arguments provided\"):\n            await get_prompt(\"deep-paper-analysis\", {})\n\n    @pytest.mark.asyncio\n    async def test_missing_required_argument_raises(self):\n        with pytest.raises(ValueError, match=\"Missing required argument\"):\n            await get_prompt(\"deep-paper-analysis\", {\"other_arg\": \"value\"})\n\n    @pytest.mark.asyncio\n    async def test_result_has_description(self):\n        result = await get_prompt(\"deep-paper-analysis\", {\"paper_id\": \"x\"})\n        assert result.description is not None\n        assert len(result.description) > 0\n\n    @pytest.mark.asyncio\n    async def test_session_id_accepted(self):\n        result = await get_prompt(\n            \"deep-paper-analysis\",\n            {\"paper_id\": \"2401.00123\"},\n            session_id=\"sess-123\",\n        )\n        assert isinstance(result, GetPromptResult)\n        assert \"2401.00123\" in result.messages[0].content.text\nENDOFFILE"}
