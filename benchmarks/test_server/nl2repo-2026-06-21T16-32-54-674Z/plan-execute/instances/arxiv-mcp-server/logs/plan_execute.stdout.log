    "status": "success",
    "message": "Paper is ready",
    "resource_uri": "file:///path/to/paper.md"
}

# Converting status response
{
    "status": "converting",
    "started_at": "2024-01-15T10:30:00",
    "completed_at": null,
    "error": null,
    "message": "Paper conversion converting"
}
