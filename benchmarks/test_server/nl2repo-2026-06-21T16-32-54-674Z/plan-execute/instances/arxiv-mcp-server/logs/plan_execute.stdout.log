      assert 'Prompt not found' in str(e)\n\n    # Test error: no arguments\n    try:\n        await get_prompt('deep-paper-analysis', None)\n        assert False, 'Should have raised'\n    except ValueError as e:\n        print('14. No arguments error:', e)\n        assert 'No arguments provided' in str(e)\n\n    # Test error: empty arguments\n    try:\n        await get_prompt('deep-paper-analysis', {})\n        assert False, 'Should have raised'\n    except ValueError as e:\n        print('15. Empty arguments error:', e)\n        assert 'No arguments provided' in str(e)\n\n    # Test error: missing required argument\n    try:\n        await get_prompt('deep-paper-analysis', {'other': 'val'})\n        assert False, 'Should have raised'\n    except ValueError as e:\n        print('16. Missing required arg error:', e)\n        assert 'Missing required argument' in str(e)\n\n    print('ALL TESTS PASSED')\n\nasyncio.run(main())\n\"\n"}
