etadata(self, tmp_path):\n        md_file = tmp_path / \"1234.md\"\n        md_file.write_text(\"# My Paper\\n\\nSome content here.\\nMore text.\\n\", encoding=\"utf-8\")\n        meta = _extract_paper_metadata(md_file)\n        assert meta[\"id\"] == \"1234\"\n        assert meta[\"title\"] == \"My Paper\"\n        assert meta[\"resource_uri\"] == f\"file://{md_file.resolve()}\"\n        assert meta[\"size_bytes\"] > 0\n\n    def test_no_heading_uses_first_line(self, tmp_path):\n        md_file = tmp_path / \"1234.md\"\n        md_file.write_text(\"Just plain text\\nNo heading.\\n\", encoding=\"utf-8\")\n        meta = _extract_paper_metadata(md_file)\n        assert \"title\" not in meta\n        assert meta.get(\"first_line\") == \"Just plain text\"\n\n    def test_counts_lines_and_chars(self, tmp_path):\n        md_file = tmp_path / \"1234.md\"\n        md_file.write_text(\"line1\\nline2\\nline3\\n\", encoding=\"utf-8\")\n        meta = _extract_paper_metadata(md_file)\n        assert meta[\"lines\"] == 4  # 3 lines + trailing newline\n        assert meta[\"characters\"] == 17\n\n    def test_nonexistent_file_does_not_crash(self, tmp_path):\n        md_file = tmp_path / \"missing.md\"\n        # Should not raise even if file doesn't exist (except in stat())\n        with pytest.raises(FileNotFoundError):\n            _extract_paper_metadata(md_file)\n\n\nclass TestHandleListPapers:\n    @pytest.mark.asyncio\n    async def test_empty(self, tmp_path, mocker):\n        with mocker.patch(\"arxiv_mcp_server.tools.list_papers.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            result = await handle_list_papers()\n            data = json.loads(result[0].text)\n            assert data[\"total_papers\"] == 0\n            assert data[\"papers\"] == []\n            assert \"storage_path\" in data\n\n    @pytest.mark.asyncio\n    async def test_with_papers(self, tmp_path, mocker):\n        (tmp_path / \"paper1.md\").write_text(\"# Paper One\\nContent\", encoding=\"utf-8\")\n        (tmp_path / \"paper2.md\").write_text(\"# Paper Two\\nMore content\", encoding=\"utf-8\")\n        with mocker.patch(\"arxiv_mcp_server.tools.list_papers.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            result = await handle_list_papers()\n            data = json.loads(result[0].text)\n            assert data[\"total_papers\"] == 2\n            assert len(data[\"papers\"]) == 2\n            # papers are sorted by id\n            assert data[\"papers\"][0][\"id\"] == \"paper1\"\n            assert data[\"papers\"][1][\"id\"] == \"paper2\"\n            # metadata check\n            assert data[\"papers\"][0][\"title\"] == \"Paper One\"\n\n    @pytest.mark.asyncio\n    async def test_with_none_arguments(self, tmp_path, mocker):\n        with mocker.patch(\"arxiv_mcp_server.tools.list_papers.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            result = await handle_list_papers(None)\n            data = json.loads(result[0].text)\n            assert data[\"total_papers\"] == 0\nENDOFFILE"}
