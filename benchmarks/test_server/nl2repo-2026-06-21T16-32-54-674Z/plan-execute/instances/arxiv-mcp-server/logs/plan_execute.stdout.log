[log] bash[359] stdout def list_papers() -> List[str]:
[log] bash[359] stdout     """Scan local storage and return a list of paper IDs (stems of .md files)."""
[log] bash[359] stdout     storage_path = Path(settings.STORAGE_PATH)
[log] bash[359] stdout     if not storage_path.exists():
[log] bash[359] stdout         return []
[log] bash[359] stdout     return sorted([p.stem for p in storage_path.glob("*.md")])
[log] bash[359] stdout def _extract_paper_metadata(md_path: Path) -> Dict[str, Any]:
[log] bash[359] stdout     """Extract basic metadata from a Markdown paper file.
[log] bash[359] stdout     Attempts to pull title from the first ``# heading`` line and returns
[log] bash[359] stdout     whatever structural hints are available.
[log] bash[359] stdout     """
[log] bash[359] stdout     meta: Dict[str, Any] = {
[log] bash[359] stdout         "id": md_path.stem,
[log] bash[359] stdout         "file_path": str(md_path.resolve()),
[log] bash[359] stdout         "resource_uri": f"file://{md_path.resolve()}",
[log] bash[359] stdout         "size_bytes": md_path.stat().st_size,
[log] bash[359] stdout     }
[log] bash[359] stdout     try:
[log] bash[359] stdout         text = md_path.read_text(encoding="utf-8")
[log] bash[359] stdout         # Try to grab the title from the first heading line
[log] bash[359] stdout         for line in text.splitlines():
[log] bash[359] stdout             stripped = line.strip()
[log] bash[359] stdout             if stripped.startswith("# "):
[log] bash[359] stdout                 meta["title"] = stripped[2:].strip()
[log] bash[359] stdout                 break
[log] bash[359] stdout             elif stripped and not stripped.startswith("#"):
[log] bash[359] stdout                 # First non-empty, non-heading line as fallback
[log] bash[359] stdout                 meta["first_line"] = stripped[:120]
[log] bash[359] stdout                 break
[log] bash[359] stdout         # Count approximate page-length
[log] bash[359] stdout         meta["lines"] = text.count("\n") + 1
[log] bash[359] stdout         meta["characters"] = len(text)
[log] bash[359] stdout     except Exception:
[log] bash[359] stdout         pass
[log] bash[359] stdout     return meta
