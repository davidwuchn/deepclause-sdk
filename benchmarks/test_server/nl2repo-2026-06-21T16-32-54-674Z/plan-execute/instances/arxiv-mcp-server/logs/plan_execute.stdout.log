cp_server.tools.download.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            ms.BATCH_SIZE = 10\n        # Now mock Path.read_text at the module level\n        with mocker.patch.object(\n            type(md_file), \"read_text\", side_effect=OSError(\"permission denied\")\n        ):\n            result = await handle_read_paper({\"paper_id\": \"broken\"})\n            data = json.loads(result[0].text)\n            assert data[\"status\"] == \"error\"\n            assert \"Failed to read\" in data[\"message\"]\n\n    @pytest.mark.asyncio\n    async def test_read_returns_single_text_content(self, tmp_path, mocker):\n        \"\"\"The result list must have exactly one TextContent item.\"\"\"\n        (tmp_path / \"ok.md\").write_text(\"content\", encoding=\"utf-8\")\n        with mocker.patch(\"arxiv_mcp_server.tools.download.settings\") as ms:\n            ms.STORAGE_PATH = tmp_path\n            ms.BATCH_SIZE = 10\n            result = await handle_read_paper({\"paper_id\": \"ok\"})\n            assert len(result) == 1\n            assert result[0].type == \"text\"\nENDOFFILE"}
