e as title, got {pc.title}\"\nprint(\"PASS: non-heading first line used as title\")\n\n# ---- Test 6: read_paper_resource success ----\nasync def test_read():\n    contents = await read_paper_resource(\"arxiv://2401.00123\")\n    items = list(contents)\n    assert len(items) == 1\n    item = items[0]\n    assert item.content == \"Attention Is All You Need\\n\\nThe Transformer model.\"\n    assert item.mime_type == \"text/markdown\"\n    print(\"PASS: read_paper_resource returns correct content\")\n\nasyncio.run(test_read())\n\n# ---- Test 7: read_paper_resource bad scheme ----\nasync def test_bad_scheme():\n    try:\n        await read_paper_resource(\"http://example.com/paper\")\n        assert False, \"Should have raised ValueError\"\n    except ValueError as e:\n        assert \"Unsupported resource URI scheme\" in str(e)\n        print(f\"PASS: ValueError for bad scheme: {e}\")\nasyncio.run(test_bad_scheme())\n\n# ---- Test 8: read_paper_resource empty paper_id ----\nasync def test_empty_id():\n    try:\n        await read_paper_resource(\"arxiv://\")\n        assert False, \"Should have raised ValueError\"\n    except ValueError as e:\n        assert \"Empty paper_id\" in str(e)\n        print(f\"PASS: ValueError for empty paper_id: {e}\")\nasyncio.run(test_empty_id())\n\n# ---- Test 9: read_paper_resource not found ----\nasync def test_not_found():\n    try:\n        await read_paper_resource(\"arxiv://9999.99999\")\n        assert False, \"Should have raised FileNotFoundError\"\n    except FileNotFoundError as e:\n        assert \"not found in local storage\" in str(e)\n        print(f\"PASS: FileNotFoundError for missing paper: {e}\")\nasyncio.run(test_not_found())\n\n# ---- Test 10: _storage_path consistency ----\nsp = _storage_path()\nassert sp == Path(settings.STORAGE_PATH).resolve()\nprint(\"PASS: _storage_path matches settings.STORAGE_PATH\")\n\nprint(\"\\n=== ALL 10 TESTS PASSED ===\")\nPYEOF"}
