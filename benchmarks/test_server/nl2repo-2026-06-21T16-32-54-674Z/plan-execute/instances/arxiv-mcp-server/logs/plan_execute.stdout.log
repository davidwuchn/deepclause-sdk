[log] bash[229] stdout def _build_query(query: str, categories: Optional[List[str]] = None) -> str:
[log] bash[229] stdout     """Build the arXiv search query with field specifiers and optional category filter.
[log] bash[229] stdout     If the query does not already start with a field specifier, wrap it with `all:`
[log] bash[229] stdout     so that arXiv searches across all fields, improving relevance.  If categories
[log] bash[229] stdout     are provided, append a `cat:` filter for each category.
[log] bash[229] stdout     """
[log] bash[229] stdout     # If no field specifier is present, default to searching all fields
[log] bash[229] stdout     if not _has_field_specifier(query):
[log] bash[229] stdout         query = f"all:{query}"
[log] bash[229] stdout     parts = [query]
[log] bash[229] stdout     if categories:
[log] bash[229] stdout         for cat in categories:
[log] bash[229] stdout             parts.append(f"cat:{cat}")
[log] bash[229] stdout     return " AND ".join(parts)
[log] bash[229] stdout def _validate_date(date_str: str, field_name: str) -> str:
