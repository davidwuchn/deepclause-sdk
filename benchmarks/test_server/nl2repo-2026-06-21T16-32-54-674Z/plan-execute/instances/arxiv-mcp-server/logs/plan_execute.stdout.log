[log] bash[309] stdout async def handle_search(arguments: Dict[str, Any]) -> List[types_TextContent]:
[log] bash[309] stdout     """Handle paper search requests.
[log] bash[309] stdout     Parameters
[log] bash[309] stdout     ----------
[log] bash[309] stdout     arguments : dict
