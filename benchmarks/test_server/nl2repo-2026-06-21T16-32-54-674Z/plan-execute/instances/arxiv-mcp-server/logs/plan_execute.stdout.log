[log] bash[359] stdout """Search tool for ArXiv MCP Server."""
[log] bash[359] stdout import json
[log] bash[359] stdout from datetime import datetime
[log] bash[359] stdout from typing import Any, Dict, List, Optional
[log] bash[359] stdout import arxiv
[log] bash[359] stdout from mcp.types import TextContent as types_TextContent
[log] bash[359] stdout from arxiv_mcp_server.config import settings
[log] bash[359] stdout # Field specifiers supported by arXiv
[log] bash[359] stdout FIELD_SPECIFIERS = {"all:", "ti:", "abs:", "au:", "cat:", "co:", "r:", "j:", "rn:", "yr:", "id:", "or:"}
[log] bash[359] stdout def _has_field_specifier(query: str) -> bool:
[log] bash[359] stdout     """Check if the query already contains a field specifier."""
[log] bash[359] stdout     for specifier in FIELD_SPECIFIERS:
[log] bash[359] stdout         if query.startswith(specifier):
[log] bash[359] stdout             return True
[log] bash[359] stdout     return False
[log] bash[359] stdout def _build_query(query: str, categories: Optional[List[str]] = None) -> str:
[log] bash[359] stdout     """Build the arXiv search query with field specifiers and optional category filter.
[log] bash[359] stdout     If the query does not already start with a field specifier, wrap it with `all:`
[log] bash[359] stdout     so that arXiv searches across all fields, improving relevance.  If categories
[log] bash[359] stdout     are provided, append a `cat:` filter for each category.
[log] bash[359] stdout     """
[log] bash[359] stdout     # If no field specifier is present, default to searching all fields
[log] bash[359] stdout     if not _has_field_specifier(query):
[log] bash[359] stdout         query = f"all:{query}"
[log] bash[359] stdout     parts = [query]
[log] bash[359] stdout     if categories:
[log] bash[359] stdout         for cat in categories:
[log] bash[359] stdout             parts.append(f"cat:{cat}")
[log] bash[359] stdout     return " AND ".join(parts)
[log] bash[359] stdout def _validate_date(date_str: str, field_name: str) -> str:
[log] bash[359] stdout     """Validate and normalize a date string to 'YYYYMMDD' format expected by arxiv API.
[log] bash[359] stdout     Raises ValueError with a descriptive message on invalid input.
[log] bash[359] stdout     """
[log] bash[359] stdout     for fmt in ("%Y-%m-%d", "%Y%m%d", "%Y/%m/%d"):
[log] bash[359] stdout         try:
[log] bash[359] stdout             return datetime.strptime(date_str, fmt).strftime("%Y%m%d")
[log] bash[359] stdout         except ValueError:
[log] bash[359] stdout             continue
[log] bash[359] stdout     raise ValueError(
[log] bash[359] stdout         f"Invalid date format for '{field_name}': '{date_str}'. "
[log] bash[359] stdout         f"Use ISO format (YYYY-MM-DD)."
[log] bash[359] stdout     )
[log] bash[359] stdout def _format_paper(paper: arxiv.Result) -> Dict[str, Any]:
[log] bash[359] stdout     """Convert an arxiv.Result into a plain dict for JSON serialization."""
[log] bash[359] stdout     return {
[log] bash[359] stdout         "id": paper.entry_id.split("/")[-1],
[log] bash[359] stdout         "title": paper.title,
[log] bash[359] stdout         "authors": paper.authors,
[log] bash[359] stdout         "abstract": paper.summary,
[log] bash[359] stdout         "categories": list(paper.categories),
[log] bash[359] stdout         "published": paper.published.isoformat() if paper.published else None,
[log] bash[359] stdout         "url": paper.pdf_url,
[log] bash[359] stdout         "resource_uri": f"arxiv://{paper.entry_id.split('/')[-1]}",
[log] bash[359] stdout     }
[log] bash[359] stdout async def handle_search(arguments: Dict[str, Any]) -> List[types_TextContent]:
[log] bash[359] stdout     """Handle paper search requests.
[log] bash[359] stdout     Parameters
[log] bash[359] stdout     ----------
[log] bash[359] stdout     arguments : dict
[log] bash[359] stdout         - query (str): The search query string.
[log] bash[359] stdout         - max_results (int, optional): Maximum number of results (default: 10).
[log] bash[359] stdout         - date_from (str, optional): Start date in ISO format (YYYY-MM-DD).
[log] bash[359] stdout         - date_to (str, optional): End date in ISO format (YYYY-MM-DD).
[log] bash[359] stdout         - categories (List[str], optional): Category filters (e.g. ["cs.AI", "cs.LG"]).
[log] bash[359] stdout     Returns
[log] bash[359] stdout     -------
[log] bash[359] stdout     List[types.TextContent]
[log] bash[359] stdout         A single-element list whose ``text`` field contains the JSON-serialised
[log] bash[359] stdout         search results.
[log] bash[359] stdout     """
[log] bash[359] stdout     query: str = arguments.get("query", "")
[log] bash[359] stdout     max_results: int = arguments.get("max_results", 10)
[log] bash[359] stdout     date_from: Optional[str] = arguments.get("date_from")
[log] bash[359] stdout     date_to: Optional[str] = arguments.get("date_to")
[log] bash[359] stdout     categories: Optional[List[str]] = arguments.get("categories")
[log] bash[359] stdout     # Clamp max_results to configured limit
[log] bash[359] stdout     if max_results > settings.MAX_RESULTS:
