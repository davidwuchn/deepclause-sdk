        "C:/Users/username/Documents/Papers",
        "C:\\Program Files\\arXiv\\papers",
        "C:\\Users/username\\Documents/Papers",
    ]
    
    for windows_path in windows_style_paths:
        assert Path(windows_path)  # Should not throw an error
        subpath = Path(windows_path) / "subdir"
