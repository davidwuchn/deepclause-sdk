[log] bash[229] stdout # Field specifiers supported by arXiv
[log] bash[229] stdout FIELD_SPECIFIERS = {"all:", "ti:", "abs:", "au:", "cat:", "co:", "r:", "j:", "rn:", "yr:", "id:", "or:"}
[log] bash[229] stdout def _has_field_specifier(query: str) -> bool:
