   assert \"paper_id\" in read_tool.inputSchema[\"required\"]\n\n    def test_all_tools_are_Tool_instances(self):\n        for t in TOOL_REGISTRY.values():\n            assert isinstance(t, Tool)\n\n    def test_tools_have_descriptions(self):\n        for t in TOOL_REGISTRY.values():\n            assert t.description is not None\n            assert len(t.description) > 0\n\n\nclass TestListToolsHandler:\n    @pytest.mark.asyncio\n    async def test_returns_all_tools(self):\n        tools = await list_tools()\n        assert len(tools) == 4\n        names = [t.name for t in tools]\n        assert \"search_papers\" in names\n        assert \"download_paper\" in names\n        assert \"list_papers\" in names\n        assert \"read_paper\" in names\n\n\nclass TestCallToolHandler:\n    @pytest.mark.asyncio\n    async def test_unknown_tool_returns_error(self):\n        result = await call_tool(\"nonexistent_tool\", {})\n        assert len(result) == 1\n        assert \"Unknown tool\" in result[0].text\n\n    @pytest.mark.asyncio\n    async def test_search_papers_dispatches(self):\n        with patch(\"arxiv_mcp_server.server.handle_search\", new_callable=AsyncMock) as mock_search:\n            mock_search.return_value = [MagicMock(type=\"text\", text='{\"total_results\":0}')]\n            result = await call_tool(\"search_papers\", {\"query\": \"test\"})\n            mock_search.assert_awaited_once()\n\n    @pytest.mark.asyncio\n    async def test_download_paper_dispatches(self):\n        with patch(\"arxiv_mcp_server.server.handle_download\", new_callable=AsyncMock) as mock_dl:\n            mock_dl.return_value = [MagicMock(type=\"text\", text='{\"status\":\"success\"}')]\n            result = await call_tool(\"download_paper\", {\"paper_id\": \"123\"})\n            mock_dl.assert_awaited_once()\n\n    @pytest.mark.asyncio\n    async def test_list_papers_dispatches(self):\n        with patch(\"arxiv_mcp_server.server.handle_list_papers\", new_callable=AsyncMock) as mock_lp:\n            mock_lp.return_value = [MagicMock(type=\"text\", text='{\"total_papers\":0}')]\n            result = await call_tool(\"list_papers\", {})\n            mock_lp.assert_awaited_once()\n\n    @pytest.mark.asyncio\n    async def test_read_paper_dispatches(self):\n        with patch(\"arxiv_mcp_server.server.handle_read_paper\", new_callable=AsyncMock) as mock_rp:\n            mock_rp.return_value = [MagicMock(type=\"text\", text='{\"paper_id\":\"123\"}')]\n            result = await call_tool(\"read_paper\", {\"paper_id\": \"123\"})\n            mock_rp.assert_awaited_once()\n\n    @pytest.mark.asyncio\n    async def test_call_tool_exception_wrapped(self):\n        with patch(\"arxiv_mcp_server.server.handle_search\", new_callable=AsyncMock) as mock_s:\n            mock_s.side_effect = Exception(\"boom\")\n            result = await call_tool(\"search_papers\", {\"query\": \"x\"})\n            assert len(result) == 1\n            assert \"Error:\" in result[0].text or \"boom\" in result[0].text\n\n\nclass TestServerPromptHandlers:\n    @pytest.mark.asyncio\n    async def test_handle_list_prompts(self):\n        prompts = await handle_list_prompts()\n        assert isinstance(prompts, list)\n        names = [p.name for p in prompts]\n        assert \"deep-paper-analysis\" in names\n\n    @pytest.mark.asyncio\n    async def test_handle_get_prompt_valid(self):\n        result = await handle_get_prompt(\"deep-paper-analysis\", {\"paper_id\": \"2401.00123\"})\n        assert \"2401.00123\" in result.messages[0].content.text\n\n    @pytest.mark.asyncio\n    async def test_handle_get_prompt_invalid(self):\n        with pytest.raises(ValueError, match=\"Prompt not found\"):\n            await handle_get_prompt(\"nope\", {})\n\n\nclass TestServerResourceHandlers:\n    @pytest.mark.asyncio\n    async def test_handle_list_resources_empty(self, tmp_path, mocker):\n        mock_settings = mocker.patch(\"arxiv_mcp_server.resources.papers.settings\")\n        mock_settings.STORAGE_PATH = tmp_path\n        result = await handle_list_resources()\n        assert result == []\n\n    @pytest.mark.asyncio\n    async def test_handle_read_resource(self, tmp_path, mocker):\n        (tmp_path / \"test.md\").write_text(\"# Paper\\nContent\", encoding=\"utf-8\")\n        mock_settings = mocker.patch(\"arxiv_mcp_server.resources.papers.settings\")\n        mock_settings.STORAGE_PATH = tmp_path\n        result = await handle_read_resource(\"arxiv://test\")\n        items = list(result)\n        assert len(items) == 1\n        assert items[0].content == \"# Paper\\nContent\"\n\n\nclass TestServerInstance:\n    def test_server_name(self):\n        assert server.name == \"arxiv-mcp-server\"\n\n    def test_server_version(self):\n        assert server.version == \"0.2.11\"\n\n    def test_server_instructions(self):\n        assert server.instructions is not None\n        assert \"arXiv\" in server.instructions or \"ArXiv\" in server.instructions\nENDOFFILE"}
