[log] bash[369] stdout     def _get_storage_path_from_args(self) -> Optional[Path]:
[log] bash[369] stdout         """Extract the storage path from command-line arguments."""
[log] bash[369] stdout         args = sys.argv[1:]
[log] bash[369] stdout         for i, arg in enumerate(args):
[log] bash[369] stdout             if arg == "--storage-path" and i + 1 < len(args):
[log] bash[369] stdout                 return Path(args[i + 1])
[log] bash[369] stdout         return None
[log] bash[369] stdout     @property
[log] bash[369] stdout     def STORAGE_PATH(self) -> Path:
[log] bash[369] stdout         """Get and ensure the existence of the storage path."""
[log] bash[369] stdout         path = (
