[log] bash[700] stdout     def _get_storage_path_from_args(self) -> Optional[Path]:
[log] bash[700] stdout         """Extract the storage path from command-line arguments."""
[log] bash[700] stdout         args = sys.argv[1:]
[log] bash[700] stdout         for i, arg in enumerate(args):
[log] bash[700] stdout             if arg == "--storage-path" and i + 1 < len(args):
[log] bash[700] stdout                 return Path(args[i + 1])
[log] bash[700] stdout         return None
[log] bash[700] stdout     @property
[log] bash[700] stdout     def STORAGE_PATH(self) -> Path:
[log] bash[700] stdout         """Get and ensure the existence of the storage path."""
[log] bash[700] stdout         path = (
