  def test_keeps_existing_specifier(self):\n        assert _build_query(\"ti:transformer\") == \"ti:transformer\"\n\n    def test_appends_single_category(self):\n        q = _build_query(\"nlp\", categories=[\"cs.AI\"])\n        assert q == \"all:nlp AND cat:cs.AI\"\n\n    def test_appends_multiple_categories(self):\n        q = _build_query(\"nlp\", categories=[\"cs.AI\", \"cs.LG\"])\n        assert q == \"all:nlp AND cat:cs.AI AND cat:cs.LG\"\n\n    def test_categories_only(self):\n        q = _build_query(\"x\", categories=[\"cs.AI\"])\n        assert q == \"all:x AND cat:cs.AI\"\n\n\n# ------------------------------------------------------------------ date validation\n\nclass TestValidateDate:\n    def test_iso_dash(self):\n        assert _validate_date(\"2023-01-15\", \"d\") == \"20230115\"\n\n    def test_compact(self):\n        assert _validate_date(\"20230115\", \"d\") == \"20230115\"\n\n    def test_slash(self):\n        assert _validate_date(\"2023/01/15\", \"d\") == \"20230115\"\n\n    def test_invalid(self):\n        with pytest.raises(ValueError, match=\"Invalid date format\"):\n            _validate_date(\"not-a-date\", \"d\")\n\n    def test_includes_field_name_in_error(self):\n        with pytest.raises(ValueError, match=\"date_from\"):\n            _validate_date(\"xyz\", \"date_from\")\n\n\n# ------------------------------------------------------------------ format paper\n\nclass TestFormatPaper:\n    def test_full_format(self):\n        paper = _make_mock_result()\n        d = _format_paper(paper)\n        assert d[\"id\"] == \"2103.12345v1\"\n        assert d[\"title\"] == \"Test Paper\"\n        assert d[\"authors\"] == [\"Alice Smith\"]\n        assert d[\"abstract\"] == \"Abstract text\"\n        assert d[\"categories\"] == [\"cs.AI\"]\n        assert d[\"url\"] == \"https://arxiv.org/pdf/2103.12345.pdf\"\n        assert d[\"resource_uri\"] == \"arxiv://2103.12345v1\"\n\n    def test_published_none(self):\n        paper = _make_mock_result(published=None)\n        assert _format_paper(paper)[\"published\"] is None\n\n\n# ------------------------------------------------------------------ handle_search integration (mocked arxiv)\n\nclass TestHandleSearch:\n    @pytest.mark.asyncio\n    async def test_basic_search_returns_papers(self):\n        mock_paper = _make_mock_result()\n        with patch(\"arxiv.Client\") as MockClient, \\\n             patch(\"arxiv.Search\") as MockSearch:\n            mock_client = MagicMock()\n            MockClient.return_value = mock_client\n            mock_client.results.return_value = [mock_paper]\n            result = await handle_search({\"query\": \"test\", \"max_results\": 5})\n            assert len(result) == 1\n            data = json.loads(result[0].text)\n            assert data[\"total_results\"] == 1\n            assert data[\"query\"] == \"test\"\n            assert len(data[\"papers\"]) == 1\n\n    @pytest.mark.asyncio\n    async def test_search_clamps_max_results(self):\n        with patch(\"arxiv.Client\") as MockClient, \\\n             patch(\"arxiv.Search\") as MockSearch:\n            mock_client = MagicMock()\n            MockClient.return_value = mock_client\n            mock_client.results.return_value = []\n            MockSearch.assert_not_called()\n            # max_results=999 should be clamped to MAX_RESULTS (50)\n            await handle_search({\"query\": \"x\", \"max_results\": 999})\n            MockSearch.assert_called_once()\n            call_kwargs = MockSearch.call_args\n            assert call_kwargs.kwargs.get(\"max_results\", call_kwargs[1].get(\"max_results\")) == 50\n\n    @pytest.mark.asyncio\n    async def test_invalid_date_from(self):\n        result = await handle_search({\n            \"query\": \"test\",\n            \"date_from\": \"bad-date\",\n        })\n        assert \"Error: Invalid date format\" in result[0].text\n\n    @pytest.mark.asyncio\n    async def test_invalid_date_to(self):\n        result = await handle_search