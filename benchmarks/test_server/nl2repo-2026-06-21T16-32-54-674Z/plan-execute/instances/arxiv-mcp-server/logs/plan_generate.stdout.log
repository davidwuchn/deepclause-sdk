    "papers": [
        {
            "id": "2103.12345",
            "title": "Test Paper",
            "authors": ["Author Name"],
            "abstract": "Paper abstract...",
            "categories": ["cs.AI"],
            "published": "2021-03-15T00:00:00+00:00",
            "url": "https://arxiv.org/pdf/2103.12345.pdf",
            "resource_uri": "arxiv://2103.12345"
        }
    ]
}
```

