[log] bash[68] stdout     "resource_uri": "file:///path/to/paper.md"
[log] bash[68] stdout }
[log] bash[68] stdout # Conversion status tracking
[log] bash[68] stdout @dataclass
[log] bash[68] stdout class ConversionStatus:
