[log] bash[68] stdout     result = await handle_search({
[log] bash[68] stdout         "query": "test query", 
[log] bash[68] stdout         "max_results": 1
[log] bash[68] stdout     })
[log] bash[68] stdout     
[log] bash[68] stdout     assert len(result) == 1
[log] bash[68] stdout     content = json.loads(result[0].text)
[log] bash[68] stdout     assert content["total_results"] == 1
