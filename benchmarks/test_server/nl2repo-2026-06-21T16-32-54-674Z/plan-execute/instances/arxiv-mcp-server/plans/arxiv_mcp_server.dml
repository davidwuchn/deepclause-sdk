tool(run_bash(Command, Output), "Run a shell command in the workspace. Use cat to read files, use heredocs to write files: cat > path/to/file.py << 'ENDOFFILE'\ncode here\nENDOFFILE\nUse mkdir -p before writing to new directories. Use ls to list directories.") :-
    exec(bash(command: Command), Output).

agent_main :-
    exec(bash(command: 'cat start.md'), SpecResult),
    get_dict(stdout, SpecResult, SpecContent),
    format(string(SysPrompt), "You are an expert Python developer. You MUST implement a complete library from the specification below.\n\nCRITICAL RULES:\n1. Start coding IMMEDIATELY. The full specification is below — do NOT re-read start.md.\n2. Use run_bash for EVERYTHING: write files with heredocs, run commands.\n3. To write a file: run_bash with: mkdir -p dirname && cat > filepath << 'ENDOFFILE'\n... file content ...\nENDOFFILE\n4. NEVER call write_file_content or read_file_content — they do not exist.\n5. After writing each file, verify it with cat or python -c 'import module'.\n6. Work autonomously. No user interaction. No web_search, news_search, url_fetch, or create_skill.\n7. If a task seems unclear, make reasonable assumptions and implement anyway.\n8. DO NOT spend more than 2 iterations reading. By iteration 3 you MUST be writing code.\n9. At the end of each task, briefly summarize what you did and what is left to do. This summary carries forward to the next task.\n\n--- BEGIN SPECIFICATION ---\n~w\n--- END SPECIFICATION ---", [SpecContent]),
    system(SysPrompt),
    task("Set up the project directory structure with all necessary __init__.py files for src/arxiv_mcp_server, src/arxiv_mcp_server/tools, src/arxiv_mcp_server/prompts, and src/arxiv_mcp_server/resources subdirectories.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum1)),
    task("Create pyproject.toml with all required dependencies including arxiv, mcp, pymupdf4llm, aiohttp, pydantic-settings, and dev dependencies for testing.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum2)),
    task("Implement the Settings class in src/arxiv_mcp_server/config.py with BaseSettings inheritance, default attributes for APP_NAME, APP_VERSION, MAX_RESULTS, BATCH_SIZE, REQUEST_TIMEOUT, HOST, and PORT.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum3)),
    task("Implement the STORAGE_PATH property and _get_storage_path_from_args method in src/arxiv_mcp_server/config.py for flexible storage path configuration from command-line arguments.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum4)),
    task("Implement the ConversionStatus dataclass and conversion_statuses global dictionary in src/arxiv_mcp_server/tools/download.py for tracking download and conversion status.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum5)),
    task("Implement the get_paper_path function in src/arxiv_mcp_server/tools/download.py to generate full file paths for paper storage with configurable suffix.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum6)),
    task("Implement the handle_download function in src/arxiv_mcp_server/tools/download.py to handle paper PDF download, PDF-to-Markdown conversion using pymupdf4llm, and status tracking with error handling.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum7)),
    task("Implement the handle_search function in src/arxiv_mcp_server/tools/search.py with support for keyword queries, field specifiers, category filtering, date range filtering, and result formatting as JSON.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum8)),
    task("Implement the handle_list_papers function in src/arxiv_mcp_server/tools/list_papers.py to scan local storage for downloaded papers and return their metadata.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum9)),
    task("Implement the handle_read_paper function in src/arxiv_mcp_server/tools/read_paper.py to read and return Markdown-formatted paper content from local storage.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum10)),
    task("Update src/arxiv_mcp_server/tools/__init__.py to export handle_search and other tool module functions for unified imports.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum11)),
    task("Implement the PAPER_ANALYSIS_PROMPT constant in src/arxiv_mcp_server/prompts/deep_research_analysis_prompt.py with the comprehensive analysis workflow template.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum12)),
    task("Implement the prompt manager in src/arxiv_mcp_server/prompts/prompt_manager.py to register and retrieve available prompts by name.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum13)),
    task("Implement the list_prompts and get_prompt async handler functions in src/arxiv_mcp_server/prompts/handlers.py with proper argument validation and error handling.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum14)),
    task("Implement the papers resource module in src/arxiv_mcp_server/resources/papers.py for providing paper resources through the MCP protocol.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum15)),
    task("Implement the MCP server in src/arxiv_mcp_server/server.py with tool definitions, tool call handlers, prompt handlers, and resource handlers using the mcp library.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum16)),
    task("Implement src/arxiv_mcp_server/__main__.py as the entry point for running the MCP server with uvicorn or the mcp server framework.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum17)),
    task("Implement src/arxiv_mcp_server/__init__.py as the unified API entry point exporting list_prompts, get_prompt, handle_download, get_paper_path, conversion_statuses, handle_search, Settings, and version information.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum18)),
    task("Install the package in development mode and verify that all core module imports work correctly.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum19)),
    task("Write comprehensive unit and integration tests covering search, download, list papers, read paper, prompt handling, configuration, and error handling scenarios.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum20)),
    task("Run the full test suite and fix any failures until all tests pass successfully.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum21)),
    task("Create pyproject.toml or setup.py so the project is installable with pip install -e. Store a summary in the output variable.", string(SumPyproj)),
    task("Install the package with pip install -e . and verify basic imports work. Store a summary in the output variable.", string(SumInstall)),
    task("Run the full test suite and fix any failures until all tests pass. Store a summary in the output variable.", string(SumTests)),
    answer("Done.").

agent_main :-
    answer("Failed.").
