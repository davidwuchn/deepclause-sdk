[log] bash[68] stdout #### 41. Command Class
[log] bash[68] stdout **Class Description**: The class used to store a fully processed command.
[log] bash[68] stdout **Class Definition**:
[log] bash[68] stdout ```python
[log] bash[68] stdout @dataclass
[log] bash[68] stdout class Command:
[log] bash[68] stdout     """A fully processed command"""
[log] bash[68] stdout     function: Callable
[log] bash[68] stdout     name: str
[log] bash[68] stdout     args: List[CommandArg]
[log] bash[68] stdout     description: str = ""
[log] bash[68] stdout     alias: Optional[str] = None
[log] bash[68] stdout     add_help: bool = True
[log] bash[68] stdout     func_arg_names: Set[str] = field(default_factory=set)
[log] bash[68] stdout     cli_arg_map: Dict[str, CommandArg] = field(default_factory=dict)
[log] bash[68] stdout     def __post_init__(self) -> None: 
[log] bash[68] stdout         self.cli_arg_map = dict()
[log] bash[68] stdout         for arg in self.args:
[log] bash[68] stdout             assert arg.func_arg_name not in self.func_arg_names
[log] bash[68] stdout             self.func_arg_names.add(arg.func_arg_name)
[log] bash[68] stdout             if arg.cli_arg_name in self.cli_arg_map:
[log] bash[68] stdout                 raise util.ArguablyException(
[log] bash[68] stdout                     f"Function argument `{arg.func_arg_name}` in `{self.name}` conflicts with "
[log] bash[68] stdout                     f"`{self.cli_arg_map[arg.cli_arg_name].func_arg_name}`, both have the CLI name `{arg.cli_arg_name}`"
[log] bash[68] stdout                 )
[log] bash[68] stdout             self.cli_arg_map[arg.cli_arg_name] = arg
[log] bash[68] stdout     def call(self, parsed_args: Dict[str, Any]) -> Any:
[log] bash[68] stdout         """Filters arguments from argparse to only include the ones used by this command, then calls it
[log] bash[68] stdout         Args:
[log] bash[68] stdout             parsed_args (Dict[str, Any]): The parsed arguments.
[log] bash[68] stdout         Returns:
[log] bash[68] stdout             The result of the function call.
[log] bash[68] stdout         """
[log] bash[68] stdout     def get_subcommand_metavar(self, command_metavar: str) -> str:
[log] bash[68] stdout         """If this command has a subparser (for subcommands of its own), this can be called to generate a unique name
[log] bash[68] stdout         for the subparser's command metavar"""
[log] bash[68] stdout         if self.name == "__root__":
[log] bash[68] stdout             return command_metavar
[log] bash[68] stdout         return f"{self.name.replace(' ', '_')}{'_' if len(self.name) > 0 else ''}{command_metavar}"
[log] bash[68] stdout ```
