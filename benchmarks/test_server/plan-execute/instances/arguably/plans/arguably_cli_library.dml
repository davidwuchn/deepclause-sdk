tool(run_bash(Command, Output), "Run a shell command in the workspace. Use cat to read files, use heredocs to write files: cat > path/to/file.py << 'ENDOFFILE'\ncode here\nENDOFFILE\nUse mkdir -p before writing to new directories. Use ls to list directories.") :-
    exec(bash(command: Command), Output).

agent_main :-
    exec(bash(command: 'cat start.md'), SpecResult),
    get_dict(stdout, SpecResult, SpecContent),
    format(string(SysPrompt), "You are an expert Python developer. You MUST implement a complete library from the specification below.\n\nCRITICAL RULES:\n1. Start coding IMMEDIATELY. The full specification is below — do NOT re-read start.md.\n2. Use run_bash for EVERYTHING: write files with heredocs, run commands.\n3. To write a file: run_bash with: mkdir -p dirname && cat > filepath << 'ENDOFFILE'\n... file content ...\nENDOFFILE\n4. NEVER call write_file_content or read_file_content — they do not exist.\n5. After writing each file, verify it with cat or python -c 'import module'.\n6. Work autonomously. No user interaction. No web_search, news_search, url_fetch, or create_skill.\n7. If a task seems unclear, make reasonable assumptions and implement anyway.\n8. DO NOT spend more than 2 iterations reading. By iteration 3 you MUST be writing code.\n9. At the end of each task, briefly summarize what you did and what is left to do. This summary carries forward to the next task.\n\n--- BEGIN SPECIFICATION ---\n~w\n--- END SPECIFICATION ---", [SpecContent]),
    system(SysPrompt),
    task("Set up the project directory structure with all necessary subdirectories, __init__.py files, and py.typed marker for type checking support.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum1)),
    task("Create pyproject.toml with package metadata, build system configuration, core dependencies including docstring_parser and typing_extensions, and optional test dependencies for pytest, coverage, and pytest-cov.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum2)),
    task("Implement all data classes, exception classes, and the InputMethod enum in _util.py including ArguablyException, ArguablyWarning, NoDefault, EnumFlagInfo, LoadAndRunResult, ArgSpec.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum3)),
    task("Implement string and advanced utility functions in _util.py including camel_case_to_kebab_case, split_unquoted, unwrap_quotes, get_ancestors, normalize_name, normalize_action_input, get_parser_name, get_enum_member_docs, info_for_flags, parse_short_and_long_name, is_async_callable, func_or_class_info, get_callable_methods, log_args, and warn.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum4)),
    task("Implement IO utility functions in _util.py including capture_stdout_stderr, io_redirector, run_redirected_io, RedirectedIO class, get_and_clear_io, run_cli_and_manual, run_cli_and_manual_main, append_argv, load_and_run, and load_and_run_inner.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum5)),
    task("Implement the Command and CommandArg data classes in _commands.py with proper field definitions, post-init validation, cli_arg_map building, call method, and get_subcommand_metavar method.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum6)),
    task("Implement the CommandDecoratorInfo and SubtypeDecoratorInfo data classes in _commands.py with post-init processing and the _process method for converting decorator info to commands.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum7)),
    task("Implement all modifier classes in _modifiers.py including the CommandArgModifier base class, CountedModifier, RequiredModifier, BuilderModifier, HandlerModifier, ChoicesModifier, MissingArgDefaultModifier, ListModifier, and TupleModifier with their modify_arg_dict and check_valid methods.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum8)),
    task("Implement the argparse extension classes in _argparse_extensions.py including ListTupleBuilderAction for building lists and tuples from CLI input, and FlagAction for handling enum.Flag arguments.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum9)),
    task("Implement the _Context class in _context.py with all methods including __init__, reset, add_command, add_subtype, find_subtype, is_target, enum mapping methods, _formatter, _validate_args, _set_up_args, _build_subparser_tree, current_parser context manager, error, _soft_failure, run, _build_subtype, resolve_subtype, and check_and_set_enum_flag_default_status.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum10)),
    task("Implement the arg.py module with the command decorator function that supports both with and without parentheses syntax, subtype decorator function, and helper functions required, count, choices, missing, handler, and builder.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum11)),
    task("Create the arguably __init__.py module to export all public APIs including command, run, error, is_target, subtype, arg module, Permissions, PermissionsAlt, HiBye, get_and_clear_io, run_cli_and_manual, append_argv, and version variable.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum12)),
    task("Create the __main__.py module to support no-integration mode execution via python -m arguably with file loading, argument parsing, and dispatch to load_and_run.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum13)),
    task("Install the package in editable mode using pip and verify that basic imports from arguably work correctly.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum14)),
    task("Write comprehensive test cases covering basic command parsing, type inference for str int float and bool, subcommand handling, enum support, async function execution, version flags, parameter modifiers, subtype resolution, error handling, and help generation.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum15)),
    task("Run the full test suite using pytest and fix any failures until all tests pass successfully.. Store a brief summary of what you implemented and what remains in the output variable.", string(Sum16)),
    task("Create pyproject.toml or setup.py so the project is installable with pip install -e. Store a summary in the output variable.", string(SumPyproj)),
    task("Install the package with pip install -e . and verify basic imports work. Store a summary in the output variable.", string(SumInstall)),
    task("Run the full test suite and fix any failures until all tests pass. Store a summary in the output variable.", string(SumTests)),
    answer("Done.").

agent_main :-
    answer("Failed.").
