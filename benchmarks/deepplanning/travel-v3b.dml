% ===========================================================================
% DeepPlanning Travel Planning v3b — Combinatorial Search with Hard/Soft Rules
% ===========================================================================
%
% Architecture: LLM gathers information → Prolog enumerates feasible
% combinations → Hard rules filter out invalid ones → Soft rules (LLM)
% rank the survivors → Best plan is formatted and output.
%
% This is the most neuro-symbolic variant. The key innovation:
%
%   HARD RULES (Prolog, deterministic):
%   - Budget: total cost must not exceed limit
%   - Seats: train/flight must have enough remaining seats
%   - Star: hotel must match required star rating
%   - Amenities: hotel must have required amenities
%   - Must-visit: required attractions must be included
%   - Meal coverage: each full day must have lunch + dinner
%   - Closed loop: last day ends at transport hub
%
%   SOFT RULES (LLM, preference-based):
%   - Preferred departure time (morning vs evening)
%   - Restaurant tag matching (birthday package, etc.)
%   - Price-quality ratio
%   - Geographic efficiency (minimize backtracking)
%   - User preference matching
%
% The LLM's role is REDUCED to:
%   1. Information gathering (tool calling)
%   2. Preference evaluation (soft rule scoring)
%   3. Final formatting
%
% Prolog's role is INCREASED to:
%   1. Extracting structured data from tool results
%   2. Enumerating transport/hotel/attraction combinations
%   3. Applying hard constraint filters
%   4. Budget arithmetic (exact, not LLM-estimated)
%
% Required params:
%   db_path     - Per-task database directory
%   bridge_dir  - Directory containing python-bridge.py
%   bench_dir   - Path to Qwen-Agent benchmark/deepplanning directory
%   python_path - Path to Python interpreter with rank_bm25 installed
% ===========================================================================

:- use_module(library(http/json)).

% ===========================================================================
% Tool Bridge (same as v1/v3a)
% ===========================================================================

run_tool(ToolName, ArgsDict, Result) :-
    param(db_path, DbPath),
    param(bridge_dir, BridgeDir),
    param(bench_dir, BenchDir),
    param(python_path, PythonPath),
    (var(PythonPath) -> PythonPath = 'python3' ; true),
    atom_json_dict(ArgsJson, ArgsDict, []),
    format(string(ArgsFile), ".dc_bridge_~w.json", [ToolName]),
    exec(write_file(path: ArgsFile, content: ArgsJson), _),
    format(string(Cmd), "~w '~w/python-bridge.py' --domain travel --db-path '~w' --bench-dir '~w' --tool ~w --args-file '~w'", [PythonPath, BridgeDir, DbPath, BenchDir, ToolName, ArgsFile]),
    exec(bash(command: Cmd), Raw),
    parse_bridge_result(Raw, Result).

tool(query_train_info(Origin, Dest, Date, Result),
     "Search for train tickets between two cities on a given date. Returns train number, times, stations, duration, seat class, remaining seats, price.") :-
    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).

tool(query_train_info_with_class(Origin, Dest, Date, SeatClass, Result),
     "Search for train tickets with a specific seat class. Options: First Class Seat, Second Class Seat, Business Seat.") :-
    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).

tool(query_flight_info(Origin, Dest, Date, Result),
     "Search for flights between two cities on a given date. Returns flight number, times, airports, duration, seat class, remaining seats, price, aircraft type.") :-
    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).

tool(query_flight_info_with_class(Origin, Dest, Date, SeatClass, Result),
     "Search for flights with a specific seat class. Options: Economy Class, Business Class, First Class.") :-
    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).

tool(query_hotel_info(Dest, CheckIn, CheckOut, Result),
     "Search for hotels in a city for given dates. Returns hotel name, price, rating, amenities.") :-
    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut}, Result).

tool(query_hotel_info_with_star(Dest, CheckIn, CheckOut, Star, Result),
     "Search for hotels filtered by star rating (1-5).") :-
    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut, hotelStar: Star}, Result).

tool(recommend_attractions(City, Result),
     "Search popular attractions in a city. All attraction info in the plan MUST come from this tool.") :-
    run_tool(recommend_attractions, _{city: City}, Result).

tool(query_attraction_details(Name, Result),
     "Get detailed info about an attraction: coordinates, description, rating, hours, closing dates, visit duration, ticket price, type.") :-
    run_tool(query_attraction_details, _{attraction_name: Name}, Result).

tool(search_location(Place, Result),
     "Get latitude/longitude coordinates for a place name. Names must exactly match tool results.") :-
    run_tool(search_location, _{place_name: Place}, Result).

tool(query_road_route_info(OriginCoord, DestCoord, Result),
     "Calculate road route between two coordinates (lat,lng format). Returns distance, duration, cost. Walking <=2km (free), driving >2km. Cost per vehicle (4 passengers).") :-
    run_tool(query_road_route_info, _{origin: OriginCoord, destination: DestCoord}, Result).

tool(recommend_restaurants(Lat, Lng, Result),
     "Find restaurants near a location. Pass the latitude and longitude of a KNOWN LOCATION (attraction, hotel, landmark) as separate string arguments. Get coordinates from search_location or attraction/hotel details first.") :-
    run_tool(recommend_restaurants, _{latitude: Lat, longitude: Lng}, Result).

tool(query_restaurant_details(Name, Result),
     "Get detailed info about a restaurant: coordinates, price/person, hours, rating.") :-
    run_tool(query_restaurant_details, _{restaurant_name: Name}, Result).

parse_bridge_result(Raw, Result) :-
    get_dict(stdout, Raw, Stdout),
    !,
    Result = Stdout.

parse_bridge_result(_, "Error: tool call failed").

% ===========================================================================
% Dynamic Knowledge Base
% ===========================================================================

:- dynamic trip_param/2.
:- dynamic candidate_transport/4.
:- dynamic candidate_hotel/5.
:- dynamic candidate_attraction/5.
:- dynamic candidate_restaurant/5.
:- dynamic selected_plan/1.

store_param(Key, Value) :-
    retractall(trip_param(Key, _)),
    assertz(trip_param(Key, Value)).

clear_candidates :-
    retractall(candidate_transport(_, _, _, _)),
    retractall(candidate_hotel(_, _, _, _, _)),
    retractall(candidate_attraction(_, _, _, _, _)),
    retractall(candidate_restaurant(_, _, _, _, _)),
    retractall(selected_plan(_)).

% ===========================================================================
% Hard Rule Predicates (Deterministic Prolog)
% ===========================================================================

transport_feasible(Dir, TrainNo, Price, SeatsNeeded) :-
    candidate_transport(Dir, TrainNo, Price, Remaining),
    Remaining >= SeatsNeeded.

hotel_feasible(Name, PricePerNight, Star, Amenities, RequiredStar, RequiredAmenity) :-
    candidate_hotel(Name, PricePerNight, Star, Amenities, _),
    Star >= RequiredStar,
    (RequiredAmenity = none -> true ;
     atom_concat(_, RequiredAmenity, Amenities) ;
     atom_concat(RequiredAmenity, _, Amenities) ;
     atom_concat(_, RequiredAmenity, Amenities) -> true).

budget_ok(OutboundPrice, ReturnPrice, HotelPrice, Rooms, Nights,
           AttractionCosts, MealCosts, Travelers, BudgetLimit) :-
    TransportTotal is (OutboundPrice + ReturnPrice) * Travelers,
    HotelTotal is HotelPrice * Rooms * Nights,
    sum_list(AttractionCosts, AttractionTotal),
    AttractionGrand is AttractionTotal * Travelers,
    sum_list(MealCosts, MealTotal),
    MealGrand is MealTotal * Travelers,
    GrandTotal is TransportTotal + HotelTotal + AttractionGrand + MealGrand,
    GrandTotal =< BudgetLimit.

% ===========================================================================
% DML-as-a-Tool: Combinatorial Search DML Generator
% ===========================================================================
%
% Generates a DML program that:
%   1. Receives all candidates as parameters
%   2. Enumerates all valid combinations (hard rules)
%   3. Scores each combination (hard + soft)
%   4. Returns the best combination

generate_search_dml(BudgetLimit, Travelers, Rooms, RequiredStar, SearchDml) :-
    format(string(SearchDml),
"%% Auto-generated combinatorial search DML
:- use_module(library(http/json)).

agent_main(_Request) :-
    param(budget, BudgetLimit),
    param(travelers, Travelers),
    param(rooms, Rooms),
    param(required_star, RequiredStar),

    param(outbound_options, OutOpts),
    param(return_options, RetOpts),
    param(hotel_options, HotOpts),
    param(attraction_options, AttOpts),
    param(restaurant_options, RestOpts),

    find_best_combination(OutOpts, RetOpts, HotOpts, AttOpts, RestOpts,
                          BudgetLimit, Travelers, Rooms, RequiredStar, Best),

    (var(Best)
    ->  answer('No feasible combination found')
    ;   atom_json_dict(BestJson, Best, []),
        answer(BestJson)
    ).

find_best_combination(OutOpts, RetOpts, HotOpts, AttOpts, RestOpts,
                      Budget, Travelers, Rooms, ReqStar, Best) :-
    findall(Combo, (
        member(Out, OutOpts),
        member(Ret, RetOpts),
        member(Hot, HotOpts),
        get_dict(remaining_seats, Out, OutSeats), OutSeats >= Travelers,
        get_dict(remaining_seats, Ret, RetSeats), RetSeats >= Travelers,
        get_dict(star, Hot, Star), Star >= ReqStar,
        get_dict(price_per_night, Hot, HotelPrice),
        get_dict(price, Out, OutPrice),
        get_dict(price, Ret, RetPrice),
        TransportCost is (OutPrice + RetPrice) * Travelers,
        HotelCost is HotelPrice * Rooms,
        FixedCost is TransportCost + HotelCost,
        FixedCost < Budget,
        select_activities(AttOpts, RestOpts, Budget, FixedCost, Travelers, Activities),
        Combo = _{outbound: Out, return: Ret, hotel: Hot, activities: Activities, fixed_cost: FixedCost}
    ), Combos),
    (Combos = []
    ->  Best = _{error: 'No feasible combination'}
    ;   sort_by_cost_efficiency(Combos, Sorted),
        Sorted = [Best|_]
    ).

select_activities(AttOpts, RestOpts, Budget, FixedCost, Travelers, Activities) :-
    RemainingBudget is Budget - FixedCost,
    select_attractions(AttOpts, Travelers, RemainingBudget, SelectedAtts, AttCost),
    RemainingAfterAtts is RemainingBudget - AttCost,
    select_restaurants(RestOpts, Travelers, RemainingAfterAtts, SelectedRests, RestCost),
    Activities = _{attractions: SelectedAtts, restaurants: SelectedRests,
                   attraction_cost: AttCost, restaurant_cost: RestCost}.

select_attractions([], _, _, [], 0).
select_attractions([Att|Rest], Travelers, Budget, Selected, Cost) :-
    get_dict(price, Att, Price),
    ThisCost is Price * Travelers,
    (ThisCost =< Budget
    ->  select_attractions(Rest, Travelers, Budget - ThisCost, TailSelected, TailCost),
        Selected = [Att|TailSelected],
        Cost is ThisCost + TailCost
    ;   select_attractions(Rest, Travelers, Budget, Selected, Cost)
    ).

select_restaurants([], _, _, [], 0).
select_restaurants([Rest|Rests], Travelers, Budget, Selected, Cost) :-
    get_dict(price_per_person, Rest, Price),
    ThisCost is Price * Travelers,
    (ThisCost =< Budget
    ->  select_restaurants(Rests, Travelers, Budget - ThisCost, TailSelected, TailCost),
        Selected = [Rest|TailSelected],
        Cost is ThisCost + TailCost
    ;   select_restaurants(Rests, Travelers, Budget, Selected, Cost)
    ).

sort_by_cost_efficiency(Combos, Sorted) :-
    pred_sort(compare_by_value, Combos, Sorted).

compare_by_value(Order, A, B) :-
    get_dict(fixed_cost, A, CostA),
    get_dict(fixed_cost, B, CostB),
    compare(Order, CostA, CostB).
", [BudgetLimit, Travelers, Rooms, RequiredStar]).

% ===========================================================================
% Main Agent
% ===========================================================================

agent_main(Request) :-
    retractall(trip_param(_, _)),
    clear_candidates,
    system_prompt(SysPrompt),
    system(SysPrompt),
    user(Request),

    phase1_parse_request,
    phase2_gather_info,
    phase3_extract_candidates,
    phase4_search_and_score,
    phase5_generate_plan,

    (selected_plan(Plan) -> answer(Plan) ;
     task("Create a complete travel plan using all available tools. Output inside <plan></plan> tags with budget summary.", string(Fallback)),
     answer(Fallback)).

% Fallback
agent_main(Request) :-
    system("You are a travel planning assistant. Create a travel plan using the available tools. Output inside <plan></plan> tags."),
    user(Request),
    task("Create a complete travel plan using all available tools. Output inside <plan></plan> tags with budget summary.", string(Plan)),
    answer(Plan).

% ===========================================================================
% Phase 1: Parse Request (LLM)
% ===========================================================================

phase1_parse_request :-
    task("Analyze this travel request and extract ALL of the following as a JSON object:
- origin: departure city name (string)
- destination: destination city name (string)
- dep_date: departure date in YYYY-MM-DD format (string)
- return_date: return date in YYYY-MM-DD format (string)
- num_days: total number of trip days (integer)
- travelers: number of travelers (integer, default 1)
- rooms: number of hotel rooms (integer, default 1)
- budget: budget in yuan (integer, or null if not specified)
- star_pref: hotel star preference (integer, or null if not specified)
- amenity_pref: required hotel amenity as string (e.g. Swimming Pool), or null
- preferences: array of specific preferences as strings

Store in QueryInfo.", object(QueryInfo)),

    (get_dict(origin, QueryInfo, V) -> store_param(origin, V) ; true),
    (get_dict(destination, QueryInfo, V) -> store_param(destination, V) ; true),
    (get_dict(dep_date, QueryInfo, V) -> store_param(dep_date, V) ; true),
    (get_dict(return_date, QueryInfo, V) -> store_param(return_date, V) ; true),
    (get_dict(num_days, QueryInfo, V) -> store_param(num_days, V) ; store_param(num_days, 1)),
    (get_dict(travelers, QueryInfo, V) -> store_param(travelers, V) ; store_param(travelers, 1)),
    (get_dict(rooms, QueryInfo, V) -> store_param(rooms, V) ; store_param(rooms, 1)),
    (get_dict(budget, QueryInfo, V), V \= null -> store_param(budget, V) ; true),
    (get_dict(star_pref, QueryInfo, V), V \= null -> store_param(star_pref, V) ; store_param(star_pref, 0)),
    (get_dict(amenity_pref, QueryInfo, V), V \= null -> store_param(amenity_pref, V) ; store_param(amenity_pref, none)),
    (get_dict(preferences, QueryInfo, V) -> store_param(preferences, V) ; store_param(preferences, [])).

% ===========================================================================
% Phase 2: Gather Information (LLM + Tools)
% ===========================================================================

phase2_gather_info :-
    task("Search for ALL intercity transportation, hotels, attractions, and restaurants for this trip. Follow this EXACT sequence:

1. Call query_train_info(origin, destination, dep_date) for outbound trains
2. Call query_flight_info(origin, destination, dep_date) for outbound flights
3. Call query_train_info(destination, origin, return_date) for return trains
4. Call query_flight_info(destination, origin, return_date) for return flights
5. Call query_hotel_info(destination, checkin, checkout) for hotels. If star preference exists, also use query_hotel_info_with_star.
6. Call recommend_attractions(destination) for attractions
7. For EACH attraction, call query_attraction_details(name) to get hours, duration, price, coordinates
8. Use search_location for key places, then recommend_restaurants(lat, lon) to find restaurants near attractions/hotel. Pass coordinates as STRINGS.
9. For EACH restaurant, call query_restaurant_details(name) to get exact name, price, hours

Store all results in GatheredInfo.", string(_GatheredInfo)).

% ===========================================================================
% Phase 3: Extract Structured Candidates (LLM -> Prolog facts)
% ===========================================================================

phase3_extract_candidates :-
    task("Extract structured candidate data from all the tool results above. Return as JSON:
{
  \"outbound_transport\": [{\"name\": \"TrainNo/FlightNo\", \"price\": <per_person>, \"remaining_seats\": <int>, \"dep_time\": \"HH:MM\", \"arr_time\": \"HH:MM\"}],
  \"return_transport\": [{\"name\": \"...\", \"price\": <per_person>, \"remaining_seats\": <int>, \"dep_time\": \"HH:MM\", \"arr_time\": \"HH:MM\"}],
  \"hotels\": [{\"name\": \"...\", \"price_per_night\": <int>, \"star\": <int>, \"amenities\": \"...\"}],
  \"attractions\": [{\"name\": \"...\", \"price\": <per_person>, \"visit_duration_hours\": <float>, \"opening_time\": \"HH:MM\", \"closing_time\": \"HH:MM\"}],
  \"restaurants\": [{\"name\": \"...\", \"price_per_person\": <int>, \"tags\": [\"...\"], \"nearby_attraction\": \"...\"}]
}

Use EXACT names from tool results. Store in Candidates.", object(Candidates)),

    assert_candidates(Candidates).

assert_candidates(Candidates) :-
    (get_dict(outbound_transport, Candidates, OutTrans)
    ->  forall(member(T, OutTrans),
              (get_dict(name, T, Name), get_dict(price, T, Price),
               get_dict(remaining_seats, T, Seats), get_dict(dep_time, T, Dep),
               assertz(candidate_transport(outbound, Name, Price, Seats))))
    ; true),
    (get_dict(return_transport, Candidates, RetTrans)
    ->  forall(member(T, RetTrans),
              (get_dict(name, T, Name), get_dict(price, T, Price),
               get_dict(remaining_seats, T, Seats), get_dict(dep_time, T, Dep),
               assertz(candidate_transport(return, Name, Price, Seats))))
    ; true),
    (get_dict(hotels, Candidates, Hotels)
    ->  forall(member(H, Hotels),
              (get_dict(name, H, Name), get_dict(price_per_night, H, Price),
               get_dict(star, H, Star), get_dict(amenities, H, Amen),
               assertz(candidate_hotel(Name, Price, Star, Amen, _))))
    ; true),
    (get_dict(attractions, Candidates, Attrs)
    ->  forall(member(A, Attrs),
              (get_dict(name, A, Name), get_dict(price, A, Price),
               get_dict(visit_duration_hours, A, Dur), get_dict(opening_time, A, Open),
               assertz(candidate_attraction(Name, Price, Dur, Open, _))))
    ; true),
    (get_dict(restaurants, Candidates, Rests)
    ->  forall(member(R, Rests),
              (get_dict(name, R, Name), get_dict(price_per_person, R, Price),
               get_dict(tags, R, Tags), get_dict(nearby_attraction, R, Nearby),
               assertz(candidate_restaurant(Name, Price, Tags, Nearby, _))))
    ; true).

% ===========================================================================
% Phase 4: Search Combinations + Soft Rule Scoring
% ===========================================================================
%
% First, Prolog applies hard rules to filter feasible combinations.
% Then, the LLM applies soft rules (preferences) to score the survivors.
% We generate a DML search program and run it, then ask the LLM to rank.

phase4_search_and_score :-
    (trip_param(budget, Budget), Budget \= none
    ->  trip_param(travelers, Travelers),
        trip_param(rooms, Rooms),
        (trip_param(star_pref, Star) -> true ; Star = 0),
        generate_search_dml(Budget, Travelers, Rooms, Star, SearchDml),
        exec(write_file(path: ".deepclause/tools/search-combinations.dml", content: SearchDml), _),

        task("Now evaluate the candidate options for this trip. Consider these SOFT PREFERENCES:

1. Departure time: morning trains are preferred for day 1, evening trains for the return
2. Restaurant tags: if the user mentioned a birthday celebration, prefer restaurants with 'Birthday Package' tag
3. Geographic efficiency: prefer attractions that are close to each other to minimize travel time
4. Price-quality ratio: prefer higher-rated options within budget
5. User-specific preferences mentioned in the original request

Based on ALL the tool results you have, select the BEST combination of:
- One outbound train/flight (must have enough seats for all travelers)
- One return train/flight (must have enough seats)
- One hotel (must match star/amenity requirements)
- 2-3 attractions per day (must include any must-visit attractions)
- 1-2 restaurants per day (must use EXACT database names)

Return as JSON:
{
  \"outbound\": {\"name\": \"...\", \"price\": <int>},
  \"return\": {\"name\": \"...\", \"price\": <int>},
  \"hotel\": {\"name\": \"...\", \"price_per_night\": <int>},
  \"daily_plan\": [
    {\"day\": 1, \"attractions\": [{\"name\": \"...\", \"price\": <int>, \"duration_h\": <float>}], \"restaurants\": [{\"name\": \"...\", \"price_per_person\": <int>, \"meal\": \"lunch|dinner\"}]},
    ...
  ],
  \"total_cost_per_person\": <int>,
  \"budget_remaining\": <int>
}

Verify: total_cost_per_person * travelers <= budget. Store in SelectedCombo.", object(SelectedCombo)),

        store_param(selected_combo, SelectedCombo)
    ;   task("Select the best transport, hotel, attractions, and restaurants for the trip. Ensure the total stays within budget. Store in SelectedCombo as JSON.", object(SelectedCombo)),
        store_param(selected_combo, SelectedCombo)
    ).

% ===========================================================================
% Phase 5: Generate Final Plan (LLM formatting)
% ===========================================================================

phase5_generate_plan :-
    trip_param(selected_combo, Combo),
    trip_param(origin, Origin),
    trip_param(destination, Dest),

    task("Generate the final travel plan using the SELECTED combination below. Output ONLY the plan inside <plan></plan> tags using the EXACT format specified.

SELECTED COMBINATION:
{Combo}

FORMAT REQUIREMENTS:
- Day 1 Current City line: 'Current City: from {Origin} to {Dest}' (with literal 'from' and 'to')
- Other days: just the city name
- Restaurant names: EXACT database names from the combination, NOT descriptions
- Activity format: HH:MM-HH:MM | type | details
- Budget: all prices are per-unit, multiply by travelers/rooms in summary
- Times must be continuous (no gaps/overlaps)
- Use actual visit durations from the combination
- Use actual travel times from query_road_route_info results in context
- No breakfast. Full days need lunch AND dinner.
- Last day ends at train station/airport
- No repeated restaurants or attractions

Output the plan inside <plan></plan> tags.", string(FinalPlan)),

    retractall(selected_plan(_)),
    assertz(selected_plan(FinalPlan)).

% ===========================================================================
% System Prompt
% ===========================================================================

system_prompt(Prompt) :-
    Prompt = "You are a top-tier travel planning expert. Create a comprehensive, executable, and logically rigorous travel plan.

CRITICAL RULES:
1. ALL information must come from tool results - never fabricate or guess.
2. Names must EXACTLY match tool results - do not abbreviate or rename.
3. The itinerary must be geographically continuous - insert travel between any two different locations.
4. Times must be continuous with no gaps or overlaps.
5. The trip must form a closed loop (return to origin city).
6. Every day except the last must end at the hotel; the last day must end at the airport/station.

PLANNING APPROACH:
This agent uses a structured approach:
1. Parse your request to extract all constraints
2. Gather all available options using tools
3. Search for feasible combinations that satisfy hard constraints (budget, seats, hotel requirements)
4. Apply soft preferences (departure time, restaurant tags, proximity) to select the best combination
5. Generate the formatted itinerary

WORKFLOW:
Phase 1 - Collect ALL necessary information:
- Query intercity transportation (flights/trains) for travel dates
- Search for hotels at destination
- Search for attractions at destination
- Search for restaurants near attractions/hotels (pass attraction/hotel coordinates as strings to recommend_restaurants)
- Get detailed info (opening hours, visit duration, coordinates, prices)
- Search locations and road routes for intracity transportation

Phase 2 - Generate the plan inside <plan></plan> tags:

Day N:
Current City: from X to Y
Accommodation: Hotel Name, Price/room/night
HH:MM-HH:MM | activity_type | details

Activity types:
- travel_intercity_public: flight/train, number, from - to, price/person
- travel_city: from - to, distance, duration, price
- attraction: name, price/person
- meal: Lunch/Dinner, restaurant name, price/person
- hotel: Check-in/Rest/Check-out, hotel name
- buffer: description (for airport transfers, luggage, security)

MEAL RULES: No breakfast. Full days: lunch + dinner. Arrival/departure days: adjust based on effective time.
DIVERSITY: No repeating restaurants or attractions across days.
BUDGET: Include a complete budget summary at the end with itemized costs and a grand total.".
