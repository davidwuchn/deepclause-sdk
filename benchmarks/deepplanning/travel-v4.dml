% ===========================================================================
% DeepPlanning Travel Planning v4 — Atomic Task Decomposition with
% Prolog-Driven Backtracking
% ===========================================================================
%
% Architecture: LLM gathers → Prolog selects & backtracks → LLM schedules
%
% The "clever" part: Prolog's native backtracking IS the repair mechanism.
%
%   1. LLM makes atomic task() calls that each return STRUCTURED data
%   2. Prolog iterates through candidate combinations using member/2
%   3. Hard constraints (budget, seats, star) prune infeasible choices
%   4. If a combination fails scheduling or verification, Prolog
%      automatically backtracks to the next candidate — no retry loop
%   5. The LLM is only called for creative work (gathering, scheduling,
%      formatting), never for arithmetic or constraint checking
%
% Atomic guarantees:
%   - Each task() does ONE thing and returns typed data
%   - Each selection step is verified before proceeding
%   - A failure at any step backtracks only to the last choice point
%   - The LLM never re-gathers information — it's called once per category
%
% Required params:
%   db_path     - Per-task database directory
%   bridge_dir  - Directory containing python-bridge.py
%   bench_dir   - Path to Qwen-Agent benchmark/deepplanning directory
%   python_path - Path to Python interpreter with rank_bm25 installed
% ===========================================================================

:- use_module(library(http/json)).

% ===========================================================================
% Tool Bridge
% ===========================================================================

run_tool(ToolName, ArgsDict, Result) :-
    param(db_path, DbPath),
    param(bridge_dir, BridgeDir),
    param(bench_dir, BenchDir),
    param(python_path, PythonPath),
    (var(PythonPath) -> PythonPath = 'python3' ; true),
    atom_json_dict(ArgsJson, ArgsDict, []),
    format(string(ArgsFile), ".dc_bridge_~w.json", [ToolName]),
    exec(write_file(path: ArgsFile, content: ArgsJson), _),
    format(string(Cmd), "~w '~w/python-bridge.py' --domain travel --db-path '~w' --bench-dir '~w' --tool ~w --args-file '~w'", [PythonPath, BridgeDir, DbPath, BenchDir, ToolName, ArgsFile]),
    exec(bash(command: Cmd), Raw),
    parse_bridge_result(Raw, Result).

tool(query_train_info(Origin, Dest, Date, Result),
     "Search for train tickets between two cities on a given date. Returns train number, times, stations, duration, seat class, remaining seats, price.") :-
    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).

tool(query_train_info_with_class(Origin, Dest, Date, SeatClass, Result),
     "Search for train tickets with a specific seat class. Options: First Class Seat, Second Class Seat, Business Seat.") :-
    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).

tool(query_flight_info(Origin, Dest, Date, Result),
     "Search for flights between two cities on a given date. Returns flight number, times, airports, duration, seat class, remaining seats, price, aircraft type.") :-
    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).

tool(query_flight_info_with_class(Origin, Dest, Date, SeatClass, Result),
     "Search for flights with a specific seat class. Options: Economy Class, Business Class, First Class.") :-
    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).

tool(query_hotel_info(Dest, CheckIn, CheckOut, Result),
     "Search for hotels in a city for given dates. Returns hotel name, price, rating, amenities.") :-
    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut}, Result).

tool(query_hotel_info_with_star(Dest, CheckIn, CheckOut, Star, Result),
     "Search for hotels filtered by star rating (1-5).") :-
    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut, hotelStar: Star}, Result).

tool(recommend_attractions(City, Result),
     "Search popular attractions in a city. All attraction info in the plan MUST come from this tool.") :-
    run_tool(recommend_attractions, _{city: City}, Result).

tool(query_attraction_details(Name, Result),
     "Get detailed info about an attraction: coordinates, description, rating, hours, closing dates, visit duration, ticket price, type.") :-
    run_tool(query_attraction_details, _{attraction_name: Name}, Result).

tool(search_location(Place, Result),
     "Get latitude/longitude coordinates for a place name. Names must exactly match tool results.") :-
    run_tool(search_location, _{place_name: Place}, Result).

tool(query_road_route_info(OriginCoord, DestCoord, Result),
     "Calculate road route between two coordinates (lat,lng format). Returns distance, duration, cost. Walking <=2km (free), driving >2km. Cost per vehicle (4 passengers).") :-
    run_tool(query_road_route_info, _{origin: OriginCoord, destination: DestCoord}, Result).

tool(recommend_restaurants(Lat, Lng, Result),
     "Find restaurants near a location. Pass the latitude and longitude of a KNOWN LOCATION (attraction, hotel, landmark) as separate string arguments. Get coordinates from search_location or attraction/hotel details first.") :-
    run_tool(recommend_restaurants, _{latitude: Lat, longitude: Lng}, Result).

tool(query_restaurant_details(Name, Result),
     "Get detailed info about a restaurant: coordinates, price/person, hours, rating.") :-
    run_tool(query_restaurant_details, _{restaurant_name: Name}, Result).

parse_bridge_result(Raw, Result) :-
    get_dict(stdout, Raw, Stdout),
    !,
    Result = Stdout.

parse_bridge_result(_, "Error: tool call failed").

% ===========================================================================
% Inline Verification Tool (same as v3a)
% ===========================================================================

tool(verify_plan(PlanJson, BudgetLimitIn, TravelersIn, Result),
     "Verify a travel plan against hard constraints. Checks budget, time overlaps/gaps, name diversity, and last-day structure. Returns PASS or specific violation descriptions.\n\nArguments:\n  PlanJson: JSON string. Must include: {total_cost: <number>, days: [{day_number: <int>, activities: [{name: <string>, time_start: \"HH:MM\", time_end: \"HH:MM\", type: <string>, cost: <number>}]}]}\n  BudgetLimitIn: Total budget limit (integer). Total cost = total_cost * Travelers.\n  TravelersIn: Number of travelers (integer).\n\nActivity type values must be strings: \"attraction\", \"meal\", \"travel_intercity_public\", \"buffer\" etc.\nLast-day last activity must be type \"travel_intercity_public\" or \"buffer\".\nTime gaps >60min between adjacent activities are flagged.\nDuplicate attraction/meal names across days are flagged.") :-
    atom_json_dict(PlanJson, PlanData, []),
    coerce_int(BudgetLimitIn, BudgetLimit),
    coerce_int(TravelersIn, Travelers),
    verify_all(PlanData, BudgetLimit, Travelers, Violations),
    (Violations = []
    ->  Result = "PASS: All constraints satisfied"
    ;   format(string(Result), "FAIL: ~w", [Violations])
    ).

verify_all(PlanData, BudgetLimit, Travelers, Violations) :-
    findall(V, (
        verify_budget(PlanData, BudgetLimit, Travelers, V) ;
        verify_time(PlanData, V) ;
        verify_diversity(PlanData, V) ;
        verify_last_day(PlanData, V)
    ), Violations).

verify_budget(PlanData, BudgetLimit, Travelers, V) :-
    get_dict(total_cost, PlanData, ReportedRaw),
    coerce_int(ReportedRaw, ReportedTotal),
    TotalCost is ReportedTotal * Travelers,
    TotalCost > BudgetLimit,
    Over is TotalCost - BudgetLimit,
    format(string(V), 'BUDGET: ~w total (per-person ~w x ~w travelers) exceeds ~w limit by ~w', [TotalCost, ReportedTotal, Travelers, BudgetLimit, Over]).

verify_time(PlanData, V) :-
    get_dict(days, PlanData, Days),
    member(Day, Days),
    get_dict(day_number, Day, DayNum),
    get_dict(activities, Day, Acts),
    adjacent_activities(Acts, A, B),
    get_dict(time_end, A, EndStr),
    get_dict(time_start, B, StartStr),
    time_to_min(EndStr, EndMin),
    time_to_min(StartStr, StartMin),
    (StartMin < EndMin
    ->  get_dict(name, A, NA),
        get_dict(name, B, NB),
        format(string(V), 'DAY ~w TIME OVERLAP: "~w" ends ~w but "~w" starts ~w', [DayNum, NA, EndStr, NB, StartStr])
    ;   Gap is StartMin - EndMin,
        Gap > 60,
        get_dict(name, A, NA),
        get_dict(name, B, NB),
        format(string(V), 'DAY ~w TIME GAP: "~w" to "~w" has ~w min gap', [DayNum, NA, NB, Gap])
    ).

adjacent_activities([A, B|_], A, B).
adjacent_activities([_|Rest], A, B) :-
    adjacent_activities(Rest, A, B).

verify_diversity(PlanData, V) :-
    get_dict(days, PlanData, Days),
    findall(Name, (
        member(Day, Days),
        get_dict(activities, Day, Acts),
        member(Act, Acts),
        get_dict(type, Act, T),
        member(T, ["attraction", "meal"]),
        get_dict(name, Act, Name)
    ), AllNames),
    sort(AllNames, Unique),
    length(AllNames, Total),
    length(Unique, UniqueCount),
    Dups is Total - UniqueCount,
    Dups > 0,
    format(string(V), 'DIVERSITY: ~w repeated name(s) across days', [Dups]).

verify_last_day(PlanData, V) :-
    get_dict(days, PlanData, Days),
    Days \= [],
    last(Days, LastDay),
    get_dict(activities, LastDay, Acts),
    Acts \= [],
    last(Acts, LastAct),
    get_dict(type, LastAct, LastType),
    \+ member(LastType, ["travel_intercity_public", "buffer"]),
    format(string(V), 'STRUCTURE: last day ends with ~w, should end at transport hub', [LastType]).

time_to_min(TimeStr, Min) :-
    split_string(TimeStr, ":", "", [H, M|_]),
    number_string(Hour, H),
    number_string(Minute, M),
    Min is Hour * 60 + Minute.

coerce_int(Val, Int) :-
    integer(Val), !, Int = Val.
coerce_int(Val, Int) :-
    number(Val), !, Int is round(Val).
coerce_int(Val, Int) :-
    atom(Val), !, atom_number(Val, Int).
coerce_int(Val, Int) :-
    string(Val), !, number_string(Int, Val).

% ===========================================================================
% Main Agent: Atomic Decomposition with Prolog Backtracking
% ===========================================================================
%
% The key design: each atomic task() returns structured data that Prolog
% can reason about. Prolog's backtracking provides automatic repair.
%
% Flow:
%   1. parse_request      — LLM extracts constraints (object)
%   2. gather_all          — LLM calls tools, returns structured candidates (object)
%   3. Prolog selects      — member/2 + hard constraints, no LLM needed
%   4. schedule_itinerary  — LLM builds schedule from selected combo (object)
%   5. verify              — Prolog checks (inline)
%   6. If fail -> backtrack to step 3 (next combination)
%   7. format_output       — LLM formats into <plan> tags (string)
%
% Steps 3-5 are a single Prolog conjunction. If verification fails,
% Prolog automatically tries the next combination from step 3.
% No explicit retry loop. No DML generation. Just Prolog.

agent_main(Request) :-
    system_prompt(SysPrompt),
    system(SysPrompt),
    user(Request),

    parse_request(QueryInfo),
    gather_all(QueryInfo, Candidates),
    select_and_schedule(QueryInfo, Candidates, Itinerary),
    format_output(QueryInfo, Itinerary, Plan),
    answer(Plan).

% Fallback
agent_main(Request) :-
    system("You are a travel planning assistant. Create a travel plan using the available tools. Output inside <plan></plan> tags."),
    user(Request),
    task("Create a complete travel plan using all available tools. Output inside <plan></plan> tags with budget summary.", string(Plan)),
    answer(Plan).

% ===========================================================================
% Atomic Step 1: Parse Request
% ===========================================================================

parse_request(QueryInfo) :-
    task("Analyze this travel request and extract ALL of the following as a JSON object:
- origin: departure city name (string)
- destination: destination city name (string)
- dep_date: departure date in YYYY-MM-DD format (string)
- return_date: return date in YYYY-MM-DD format (string)
- num_days: total number of trip days (integer)
- travelers: number of travelers (integer, default 1)
- rooms: number of hotel rooms (integer, default 1)
- budget: budget in yuan (integer, or null if not specified)
- star_pref: hotel star preference (integer, or null)
- amenity_pref: required hotel amenity as string or null
- must_visit: array of must-visit attraction names (strings), or empty array
- preferences: array of specific preferences as strings

Store in QueryInfo.", object(QueryInfo)).

% ===========================================================================
% Atomic Step 2: Gather All Information
% ===========================================================================
% Single task() call that returns structured candidate lists.
% The LLM calls all tools and returns the results in a typed structure.

gather_all(QueryInfo, Candidates) :-
    get_dict(origin, QueryInfo, Origin),
    get_dict(destination, QueryInfo, Dest),
    get_dict(dep_date, QueryInfo, DepDate),
    get_dict(return_date, QueryInfo, RetDate),

    task("Gather ALL travel information using the available tools. Follow this EXACT sequence:

1. query_train_info('{Origin}', '{Dest}', '{DepDate}') — outbound trains
2. query_flight_info('{Origin}', '{Dest}', '{DepDate}') — outbound flights
3. query_train_info('{Dest}', '{Origin}', '{RetDate}') — return trains
4. query_flight_info('{Dest}', '{Origin}', '{RetDate}') — return flights
5. query_hotel_info('{Dest}', '{DepDate}', '{RetDate}') — hotels
6. If star preference exists, also query_hotel_info_with_star
7. recommend_attractions('{Dest}') — attractions
8. For EACH attraction, query_attraction_details(name) — get hours, duration, price, coords
9. search_location for key places, then recommend_restaurants(lat, lon) near each attraction/hotel — pass coordinates as STRINGS
10. For EACH restaurant, query_restaurant_details(name) — get exact name, price, hours, tags

After gathering, extract ALL options into this EXACT JSON structure:
{
  \"outbound\": [
    {\"name\": \"TrainNo\", \"price\": <per_person_int>, \"seats\": <remaining_int>, \"dep\": \"HH:MM\", \"arr\": \"HH:MM\"}
  ],
  \"return\": [
    {\"name\": \"TrainNo\", \"price\": <per_person_int>, \"seats\": <remaining_int>, \"dep\": \"HH:MM\", \"arr\": \"HH:MM\"}
  ],
  \"hotels\": [
    {\"name\": \"HotelName\", \"price\": <per_night_int>, \"star\": <int>, \"amenities\": \"...\"}
  ],
  \"attractions\": [
    {\"name\": \"AttrName\", \"price\": <per_person_int>, \"duration_min\": <int>, \"open\": \"HH:MM\", \"close\": \"HH:MM\"}
  ],
  \"restaurants\": [
    {\"name\": \"RestName\", \"price\": <per_person_int>, \"tags\": [\"...\"], \"nearby\": \"AttrName\"}
  ]
}

Use EXACT names from tool results. Include ALL options found. Store in Candidates.", object(Candidates)).

% ===========================================================================
% Atomic Step 3-5: Select, Schedule, Verify (Prolog backtracking)
% ===========================================================================
%
% This is a single Prolog conjunction. The backtracking works as follows:
%
%   select_transport_outbound  — picks one option from Candidates.outbound
%   hard_constraint: seats     — fails if not enough seats -> backtrack
%   select_transport_return    — picks one option from Candidates.return
%   hard_constraint: seats     — fails -> backtrack
%   select_hotel               — picks one option from Candidates.hotels
%   hard_constraint: star      — fails -> backtrack
%   hard_constraint: amenity   — fails -> backtrack
%   budget_check               — fails -> backtrack to try cheaper combo
%   schedule_itinerary         — LLM builds day-by-day schedule
%   verify_schedule            — Prolog checks constraints
%                                fails -> backtrack to step 3
%
% The LLM is only called once in this block (scheduling).
% All selection and verification is pure Prolog.

select_and_schedule(QueryInfo, Candidates, Itinerary) :-
    get_dict(outbound, Candidates, OutOpts),
    get_dict(return, Candidates, RetOpts),
    get_dict(hotels, Candidates, HotelOpts),
    get_dict(attractions, Candidates, AttOpts),
    get_dict(restaurants, Candidates, RestOpts),

    get_dict(travelers, QueryInfo, TravelersRaw),
    coerce_int(TravelersRaw, Travelers),

    select_outbound(OutOpts, Travelers, Outbound),
    select_return(RetOpts, Travelers, Return),
    select_hotel(HotelOpts, QueryInfo, Hotel),
    budget_feasible(Outbound, Return, Hotel, QueryInfo),

    pick_attractions(AttOpts, QueryInfo, SelectedAtts),
    pick_restaurants(RestOpts, QueryInfo, SelectedAtts, SelectedRests),

    schedule_itinerary(QueryInfo, Outbound, Return, Hotel,
                       SelectedAtts, SelectedRests, Itinerary).

% --- Outbound selection with seat check ---

select_outbound(OutOpts, Travelers, Out) :-
    member(Out, OutOpts),
    get_dict(seats, Out, SeatsRaw),
    coerce_int(SeatsRaw, Seats),
    Seats >= Travelers.

% --- Return selection with seat check ---

select_return(RetOpts, Travelers, Ret) :-
    member(Ret, RetOpts),
    get_dict(seats, Ret, SeatsRaw),
    coerce_int(SeatsRaw, Seats),
    Seats >= Travelers.

% --- Hotel selection with star/amenity check ---

select_hotel(HotelOpts, QueryInfo, Hotel) :-
    member(Hotel, HotelOpts),
    (get_dict(star_pref, QueryInfo, StarRaw), StarRaw \= null
    ->  coerce_int(StarRaw, RequiredStar),
        get_dict(star, Hotel, HotelStarRaw),
        coerce_int(HotelStarRaw, HotelStar),
        HotelStar >= RequiredStar
    ;   true),
    (get_dict(amenity_pref, QueryInfo, Amenity), Amenity \= null
    ->  get_dict(amenities, Hotel, HotelAmenities),
        (atom(HotelAmenities) -> atom_concat(_, Amenity, HotelAmenities) ;
         string(HotelAmenities) -> string_concat(_, Amenity, HotelAmenities) ;
         true)
    ;   true).

% --- Budget check (hard constraint) ---
% Verifies that fixed costs (transport + hotel) leave room for activities.

budget_feasible(Outbound, Return, Hotel, QueryInfo) :-
    get_dict(budget, QueryInfo, BudgetRaw),
    BudgetRaw \= null,
    !,
    coerce_int(BudgetRaw, Budget),
    get_dict(travelers, QueryInfo, TravelersRaw),
    coerce_int(TravelersRaw, Travelers),
    get_dict(rooms, QueryInfo, RoomsRaw),
    coerce_int(RoomsRaw, Rooms),
    get_dict(num_days, QueryInfo, DaysRaw),
    coerce_int(DaysRaw, NumDays),
    Nights is NumDays - 1,

    get_dict(price, Outbound, OutPriceRaw),
    get_dict(price, Return, RetPriceRaw),
    get_dict(price, Hotel, HotelPriceRaw),
    coerce_int(OutPriceRaw, OutPrice),
    coerce_int(RetPriceRaw, RetPrice),
    coerce_int(HotelPriceRaw, HotelPrice),

    TransportCost is (OutPrice + RetPrice) * Travelers,
    HotelCost is HotelPrice * Rooms * Nights,
    FixedCost is TransportCost + HotelCost,

    ActivitiesBudget is Budget - FixedCost,
    ActivitiesBudget > 0.

budget_feasible(_, _, _, _).

% --- Attraction selection ---
% Picks attractions ensuring must-visit ones are included.

pick_attractions(AttOpts, QueryInfo, SelectedAtts) :-
    (get_dict(must_visit, QueryInfo, MustVisit), is_list(MustVisit), MustVisit \= []
    ->  include_must_visit(AttOpts, MustVisit, MustAtts),
        RemainingAtts = AttOpts
    ;   MustAtts = [],
       RemainingAtts = AttOpts
    ),
    append(MustAtts, RemainingAtts, AllAtts),
    dedup_by_name(AllAtts, SelectedAtts).

include_must_visit(_, [], []).
include_must_visit(AttOpts, [Name|Names], [Att|Rest]) :-
    member(Att, AttOpts),
    get_dict(name, Att, AttName),
    (AttName = Name ; atom_concat(Name, _, AttName) ; atom_concat(_, Name, AttName)),
    !,
    include_must_visit(AttOpts, Names, Rest).
include_must_visit(AttOpts, [_|Names], Rest) :-
    include_must_visit(AttOpts, Names, Rest).

dedup_by_name(List, Deduped) :-
    dedup_by_name(List, [], Deduped).
dedup_by_name([], _, []).
dedup_by_name([H|T], Seen, Result) :-
    get_dict(name, H, Name),
    member(Name, Seen),
    !,
    dedup_by_name(T, Seen, Result).
dedup_by_name([H|T], Seen, [H|Rest]) :-
    get_dict(name, H, Name),
    dedup_by_name(T, [Name|Seen], Rest).

% --- Restaurant selection ---
% Picks restaurants grouped by nearby attraction, with tag preference.

pick_restaurants(RestOpts, QueryInfo, SelectedAtts, SelectedRests) :-
    findall(Rest, (
        member(Att, SelectedAtts),
        get_dict(name, Att, AttName),
        member(Rest, RestOpts),
        get_dict(nearby, Rest, Nearby),
        (Nearby = AttName ; atom_concat(_, AttName, Nearby) ; atom_concat(AttName, _, Nearby))
    ), NearbyRests),
    prefer_tagged(NearbyRests, QueryInfo, SelectedRests).

prefer_tagged(Rests, QueryInfo, Preferred) :-
    (get_dict(preferences, QueryInfo, Prefs), is_list(Prefs),
     member(Pref, Prefs),
     (atom_concat(_, birthday, Pref) ; atom_concat(_, Birthday, Pref), downcase_atom(Pref, PrefLower), atom_concat(_, birthday, PrefLower))
    ->  tag_prefer(Rests, birthday_package, Preferred)
    ;   dedup_by_name(Rests, Preferred)
    ).

tag_prefer(Rests, Tag, Preferred) :-
    findall(R, (member(R, Rests), get_dict(tags, R, Tags), is_list(Tags), member(Tag, Tags)), Tagged),
    (Tagged \= [] -> Preferred = Tagged ; dedup_by_name(Rests, Preferred)).

% --- Atomic Step 4: Schedule Itinerary (LLM) ---

schedule_itinerary(QueryInfo, Outbound, Return, Hotel,
                   Attractions, Restaurants, Itinerary) :-
    task("Build a day-by-day itinerary from the selected options below. Return ONLY valid JSON (no markdown, no code fences):
{
  \"total_cost\": <per_person total>,
  \"days\": [
    {
      \"day_number\": <int>,
      \"activities\": [
        {\"time_start\": \"HH:MM\", \"time_end\": \"HH:MM\", \"type\": \"travel_intercity_public|travel_city|attraction|meal|hotel|buffer\", \"name\": \"<exact name>\", \"cost\": <per_unit_cost>}
      ]
    }
  ]
}

SELECTED OPTIONS:
Outbound transport: {Outbound}
Return transport: {Return}
Hotel: {Hotel}
Attractions: {Attractions}
Restaurants: {Restaurants}

TRIP CONSTRAINTS: {QueryInfo}

SCHEDULING RULES:
- Day 1 starts with outbound transport, ends at hotel
- Last day starts at hotel, ends with return transport
- Insert travel_city between different locations
- Use actual attraction durations for visit times
- No breakfast. Full days need lunch AND dinner. Arrival/departure days adjust accordingly
- Times must be continuous (each activity starts when previous ends)
- Use EXACT names from the selected options
- All costs are per-unit (per-person for transport/attractions/meals, per-room for hotels)
- total_cost is per-person sum of all activity costs

Store in Itinerary.", object(Itinerary)).

% ===========================================================================
% Atomic Step 6: Format Output (LLM)
% ===========================================================================

format_output(QueryInfo, Itinerary, Plan) :-
    get_dict(origin, QueryInfo, Origin),
    get_dict(destination, QueryInfo, Dest),

    task("Convert this structured itinerary into a travel plan inside <plan></plan> tags. Use the EXACT format below.

ITINERARY DATA:
{Itinerary}

ORIGIN: {Origin}
DESTINATION: {Dest}

OUTPUT FORMAT:
Day N:
Current City: from OriginCity to DestCity   (day 1 only, with literal 'from' and 'to')
Current City: CityName                       (other days)
Accommodation: Hotel Name, Price/room/night

HH:MM-HH:MM | travel_intercity_public | Train/Flight Number, From - To, Seat Class, Price/person
HH:MM-HH:MM | travel_city | From Place - To Place, Distance, Duration, Price/vehicle
HH:MM-HH:MM | attraction | Attraction Name, Price/person
HH:MM-HH:MM | meal | Lunch/Dinner, Restaurant EXACT Name, Price/person
HH:MM-HH:MM | hotel | Check-in/Rest/Check-out, Hotel Name
HH:MM-HH:MM | buffer | Description

Then a budget summary at the end.

RULES:
- Restaurant names must be EXACT from the itinerary data, not descriptions
- Current City on day 1 must start with 'from' (e.g. 'from Hefei to Nanjing')
- All prices are per-unit; multiply by travelers/rooms in budget summary
- Verify total <= budget before outputting

Output the plan inside <plan></plan> tags.", string(Plan)).

% ===========================================================================
% System Prompt
% ===========================================================================

system_prompt(Prompt) :-
    Prompt = "You are a top-tier travel planning expert. Create a comprehensive, executable, and logically rigorous travel plan.

CRITICAL RULES:
1. ALL information must come from tool results - never fabricate or guess.
2. Names must EXACTLY match tool results - do not abbreviate or rename.
3. The itinerary must be geographically continuous - insert travel between any two different locations.
4. Times must be continuous with no gaps or overlaps.
5. The trip must form a closed loop (return to origin city).
6. Every day except the last must end at the hotel; the last day must end at the airport/station.

APPROACH:
This agent uses a structured, verifiable approach:
1. Extract your constraints from the request
2. Gather all available options using tools
3. Automatically select feasible combinations (budget, seats, star rating)
4. Schedule the selected options into a day-by-day itinerary
5. Verify the schedule against hard constraints
6. If any step fails, the system automatically tries the next combination

WORKFLOW:
Phase 1 - Collect ALL necessary information:
- Query intercity transportation (flights/trains) for travel dates
- Search for hotels at destination
- Search for attractions at destination
- Search for restaurants near attractions/hotels (pass attraction/hotel coordinates as strings to recommend_restaurants)
- Get detailed info (opening hours, visit duration, coordinates, prices)
- Search locations and road routes for intracity transportation

Phase 2 - Generate the plan inside <plan></plan> tags:

Day N:
Current City: from X to Y
Accommodation: Hotel Name, Price/room/night
HH:MM-HH:MM | activity_type | details

Activity types:
- travel_intercity_public: flight/train, number, from - to, price/person
- travel_city: from - to, distance, duration, price
- attraction: name, price/person
- meal: Lunch/Dinner, restaurant name, price/person
- hotel: Check-in/Rest/Check-out, hotel name
- buffer: description (for airport transfers, luggage, security)

MEAL RULES: No breakfast. Full days: lunch + dinner. Arrival/departure days: adjust based on effective time.
DIVERSITY: No repeating restaurants or attractions across days.
BUDGET: Include a complete budget summary at the end with itemized costs and a grand total.".
