% ===========================================================================
% DeepPlanning Travel Planning v3a — v1 + Inline Verification Tool
% ===========================================================================
%
% Based on v1 (4-phase sequential task approach) but adds a Prolog-native
% verification tool that the LLM can call to check constraints.
%
% The key insight: Prolog is already running — no need to generate a
% separate DML file and run_skill. Just define verify_plan as a tool
% and let the LLM call it like any other tool.
%
% LLM responsibilities:  NL understanding, tool calling, formatting
% Prolog responsibilities: constraint checking (budget, time, diversity)
%
% Required params:
%   db_path     - Per-task database directory
%   bridge_dir  - Directory containing python-bridge.py
%   bench_dir   - Path to Qwen-Agent benchmark/deepplanning directory
%   python_path - Path to Python interpreter with rank_bm25 installed
% ===========================================================================

:- use_module(library(http/json)).

% ===========================================================================
% Tool Bridge
% ===========================================================================

run_tool(ToolName, ArgsDict, Result) :-
    param(db_path, DbPath),
    param(bridge_dir, BridgeDir),
    param(bench_dir, BenchDir),
    param(python_path, PythonPath),
    (var(PythonPath) -> PythonPath = 'python3' ; true),
    atom_json_dict(ArgsJson, ArgsDict, []),
    format(string(ArgsFile), ".dc_bridge_~w.json", [ToolName]),
    exec(write_file(path: ArgsFile, content: ArgsJson), _),
    format(string(Cmd), "~w '~w/python-bridge.py' --domain travel --db-path '~w' --bench-dir '~w' --tool ~w --args-file '~w'", [PythonPath, BridgeDir, DbPath, BenchDir, ToolName, ArgsFile]),
    exec(bash(command: Cmd), Raw),
    parse_bridge_result(Raw, Result).

tool(query_train_info(Origin, Dest, Date, Result),
     "Search for train tickets between two cities on a given date. Returns train number, times, stations, duration, seat class, remaining seats, price.") :-
    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).

tool(query_train_info_with_class(Origin, Dest, Date, SeatClass, Result),
     "Search for train tickets with a specific seat class. Options: First Class Seat, Second Class Seat, Business Seat.") :-
    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).

tool(query_flight_info(Origin, Dest, Date, Result),
     "Search for flights between two cities on a given date. Returns flight number, times, airports, duration, seat class, remaining seats, price, aircraft type.") :-
    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).

tool(query_flight_info_with_class(Origin, Dest, Date, SeatClass, Result),
     "Search for flights with a specific seat class. Options: Economy Class, Business Class, First Class.") :-
    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).

tool(query_hotel_info(Dest, CheckIn, CheckOut, Result),
     "Search for hotels in a city for given dates. Returns hotel name, price, rating, amenities.") :-
    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut}, Result).

tool(query_hotel_info_with_star(Dest, CheckIn, CheckOut, Star, Result),
     "Search for hotels filtered by star rating (1-5).") :-
    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut, hotelStar: Star}, Result).

tool(recommend_attractions(City, Result),
     "Search popular attractions in a city. All attraction info in the plan MUST come from this tool.") :-
    run_tool(recommend_attractions, _{city: City}, Result).

tool(query_attraction_details(Name, Result),
     "Get detailed info about an attraction: coordinates, description, rating, hours, closing dates, visit duration, ticket price, type.") :-
    run_tool(query_attraction_details, _{attraction_name: Name}, Result).

tool(search_location(Place, Result),
     "Get latitude/longitude coordinates for a place name. Names must exactly match tool results.") :-
    run_tool(search_location, _{place_name: Place}, Result).

tool(query_road_route_info(OriginCoord, DestCoord, Result),
     "Calculate road route between two coordinates (lat,lng format). Returns distance, duration, cost. Walking <=2km (free), driving >2km. Cost per vehicle (4 passengers).") :-
    run_tool(query_road_route_info, _{origin: OriginCoord, destination: DestCoord}, Result).

tool(recommend_restaurants(Lat, Lng, Result),
     "Find restaurants near a location. Pass the latitude and longitude of a KNOWN LOCATION (attraction, hotel, landmark) as separate string arguments. Get coordinates from search_location or attraction/hotel details first.") :-
    run_tool(recommend_restaurants, _{latitude: Lat, longitude: Lng}, Result).

tool(query_restaurant_details(Name, Result),
     "Get detailed info about a restaurant: coordinates, price/person, hours, rating.") :-
    run_tool(query_restaurant_details, _{restaurant_name: Name}, Result).

parse_bridge_result(Raw, Result) :-
    get_dict(stdout, Raw, Stdout),
    !,
    Result = Stdout.

parse_bridge_result(_, "Error: tool call failed").

% ===========================================================================
% Inline Verification Tool
% ===========================================================================
%
% A pure-Prolog tool that checks plan constraints deterministically.
% The LLM calls this like any other tool, passing structured plan data.
% No file I/O, no nested DML execution — just Prolog arithmetic.

tool(verify_plan(PlanJson, BudgetLimitIn, TravelersIn, Result),
     "Verify a travel plan against hard constraints. Pass: PlanJson (JSON string with {total_cost, days:[{activities:[{time_start,time_end,type,name,cost}]}]}), BudgetLimit (integer), Travelers (integer). Returns PASS or specific violation descriptions.") :-
    atom_json_dict(PlanJson, PlanData, []),
    coerce_int(BudgetLimitIn, BudgetLimit),
    coerce_int(TravelersIn, Travelers),
    verify_all(PlanData, BudgetLimit, Travelers, Violations),
    (Violations = []
    ->  Result = "PASS: All constraints satisfied"
    ;   format(string(Result), "FAIL: ~w", [Violations])
    ).

verify_all(PlanData, BudgetLimit, Travelers, Violations) :-
    findall(V, (
        verify_budget(PlanData, BudgetLimit, Travelers, V) ;
        verify_time(PlanData, V) ;
        verify_diversity(PlanData, V) ;
        verify_last_day(PlanData, V)
    ), Violations).

verify_budget(PlanData, BudgetLimit, Travelers, V) :-
    get_dict(total_cost, PlanData, ReportedRaw),
    coerce_int(ReportedRaw, ReportedTotal),
    TotalCost is ReportedTotal * Travelers,
    TotalCost > BudgetLimit,
    Over is TotalCost - BudgetLimit,
    format(string(V), 'BUDGET: ~w total (per-person ~w x ~w travelers) exceeds ~w limit by ~w', [TotalCost, ReportedTotal, Travelers, BudgetLimit, Over]).

verify_time(PlanData, V) :-
    get_dict(days, PlanData, Days),
    member(Day, Days),
    get_dict(day_number, Day, DayNum),
    get_dict(activities, Day, Acts),
    adjacent_activities(Acts, A, B),
    get_dict(time_end, A, EndStr),
    get_dict(time_start, B, StartStr),
    time_to_min(EndStr, EndMin),
    time_to_min(StartStr, StartMin),
    (StartMin < EndMin
    ->  get_dict(name, A, NA),
        get_dict(name, B, NB),
        format(string(V), 'DAY ~w TIME OVERLAP: "~w" ends ~w but "~w" starts ~w', [DayNum, NA, EndStr, NB, StartStr])
    ;   Gap is StartMin - EndMin,
        Gap > 60,
        get_dict(name, A, NA),
        get_dict(name, B, NB),
        format(string(V), 'DAY ~w TIME GAP: "~w" to "~w" has ~w min gap', [DayNum, NA, NB, Gap])
    ).

adjacent_activities([A, B|_], A, B).
adjacent_activities([_|Rest], A, B) :-
    adjacent_activities(Rest, A, B).

verify_diversity(PlanData, V) :-
    get_dict(days, PlanData, Days),
    findall(Name, (
        member(Day, Days),
        get_dict(activities, Day, Acts),
        member(Act, Acts),
        get_dict(type, Act, T),
        member(T, [attraction, meal]),
        get_dict(name, Act, Name)
    ), AllNames),
    sort(AllNames, Unique),
    length(AllNames, Total),
    length(Unique, UniqueCount),
    Dups is Total - UniqueCount,
    Dups > 0,
    format(string(V), 'DIVERSITY: ~w repeated name(s) across days', [Dups]).

verify_last_day(PlanData, V) :-
    get_dict(days, PlanData, Days),
    Days \= [],
    last(Days, LastDay),
    get_dict(activities, LastDay, Acts),
    Acts \= [],
    last(Acts, LastAct),
    get_dict(type, LastAct, LastType),
    \+ member(LastType, [travel_intercity_public, buffer]),
    format(string(V), 'STRUCTURE: last day ends with ~w, should end at transport hub', [LastType]).

time_to_min(TimeStr, Min) :-
    split_string(TimeStr, ":", "", [H, M|_]),
    number_string(Hour, H),
    number_string(Minute, M),
    Min is Hour * 60 + Minute.

coerce_int(Val, Int) :-
    integer(Val), !, Int = Val.
coerce_int(Val, Int) :-
    number(Val), !, Int is round(Val).
coerce_int(Val, Int) :-
    atom(Val), !, atom_number(Val, Int).
coerce_int(Val, Int) :-
    string(Val), !, number_string(Int, Val).

% ===========================================================================
% Main Agent: v1 flow + verification-guided repair
% ===========================================================================

agent_main(Request) :-
    system_prompt(SysPrompt),
    system(SysPrompt),
    user(Request),

    task("Step 1: Identify the origin city, destination city, departure date, return date, number of travelers, budget, and any special preferences from the travel request. Then search for ALL intercity transportation options (both trains AND flights) for the outbound and return journeys. Call query_train_info and query_flight_info for both directions. Store results in TravelInfo.", string(_TravelInfo)),

    task("Step 2: Search for hotels at the destination for the travel dates. If a star rating is specified, use query_hotel_info_with_star. Then search for ALL attractions at the destination using recommend_attractions. For EACH attraction found, call query_attraction_details to get coordinates, opening hours, visit duration, and ticket price. Store in DestinationInfo.", string(_DestinationInfo)),

    task("Step 3: Search for restaurants near the attractions and hotel. Use search_location to get coordinates for each attraction and the hotel. Then pass those coordinates (as strings) to recommend_restaurants to find nearby restaurants. For EACH restaurant returned, call query_restaurant_details to get the exact name, price per person, and hours. Also use query_road_route_info between consecutive locations to get actual travel times. Store in DetailedInfo.", string(_DetailedInfo)),

    task("Step 4: Create the complete travel itinerary. You MUST use the EXACT names, prices, and times from the tool results above. Output the plan inside <plan></plan> tags.

CRITICAL FORMAT REQUIREMENTS:

1. Current City line: On the first day (intercity travel day), write: Current City: from OriginCity to DestCity (with literal 'from' and 'to'). On other days, write just the city name.

2. Restaurant names: Use the EXACT restaurant_name from recommend_restaurants/query_restaurant_details. NEVER write descriptions like 'Lunch near X' or 'Dinner at a restaurant'. NEVER add parenthetical notes.

3. Activity format (one per line):
   HH:MM-HH:MM | travel_intercity_public | Train/Flight Number, From Station - To Station, Seat Class, Price/person
   HH:MM-HH:MM | travel_city | From Place - To Place, Distance, Duration, Price/vehicle
   HH:MM-HH:MM | attraction | Attraction EXACT Name, Price/person
   HH:MM-HH:MM | meal | Lunch/Dinner, Restaurant EXACT Name, Price/person
   HH:MM-HH:MM | hotel | Check-in/Rest/Check-out, Hotel Name
   HH:MM-HH:MM | buffer | Description

4. Budget: All prices are per-unit (per-person for transport/attractions/meals, per-vehicle for city transport, per-room for hotels). At the end, show a budget summary multiplying by the number of travelers/rooms as appropriate. Verify total <= budget.

5. Rules: Times must be continuous (no gaps/overlaps). Use actual travel times from query_road_route_info. Use recommended visit durations from query_attraction_details. No breakfast. Full days need lunch AND dinner. Last day ends at airport/station. No repeated restaurants or attractions.

6. After generating the plan, call verify_plan to check it. Pass the plan as structured JSON, along with the budget limit and number of travelers. If it returns FAIL, fix the specific violations and try again.", string(Plan)),

    answer(Plan).

% Fallback: simple single-pass
agent_main(Request) :-
    system("You are a travel planning assistant. Create a travel plan using the available tools. Output inside <plan></plan> tags."),
    user(Request),
    task("Create a complete travel plan using all available tools. Output inside <plan></plan> tags with budget summary.", string(Plan)),
    answer(Plan).

% ===========================================================================
% System Prompt
% ===========================================================================

system_prompt(Prompt) :-
    Prompt = "You are a top-tier travel planning expert. Create a comprehensive, executable, and logically rigorous travel plan.

CRITICAL RULES:
1. ALL information must come from tool results - never fabricate or guess.
2. Names must EXACTLY match tool results - do not abbreviate or rename.
3. The itinerary must be geographically continuous - insert travel between any two different locations.
4. Times must be continuous with no gaps or overlaps.
5. The trip must form a closed loop (return to origin city).
6. Every day except the last must end at the hotel; the last day must end at the airport/station.

VERIFICATION TOOL:
After generating the plan, you MUST call verify_plan to check it. This tool runs deterministic Prolog checks on:
- Budget: total_cost x travelers must not exceed budget_limit
- Time continuity: no overlapping or gapped time slots (>60 min gap)
- Diversity: no repeated restaurant or attraction names across days
- Last day structure: must end with travel_intercity_public or buffer

If verify_plan returns FAIL, fix the specific violations and regenerate the plan.

WORKFLOW:
Phase 1 - Collect ALL necessary information:
- Query intercity transportation (flights/trains) for travel dates
- Search for hotels at destination
- Search for attractions at destination
- Search for restaurants near attractions/hotels (pass attraction/hotel coordinates as strings to recommend_restaurants)
- Get detailed info (opening hours, visit duration, coordinates, prices)
- Search locations and road routes for intracity transportation

Phase 2 - Generate the plan inside <plan></plan> tags:

Day N:
Current City: from X to Y
Accommodation: Hotel Name, Price/room/night
HH:MM-HH:MM | activity_type | details

Activity types:
- travel_intercity_public: flight/train, number, from - to, price/person
- travel_city: from - to, distance, duration, price
- attraction: name, price/person
- meal: Lunch/Dinner, restaurant name, price/person
- hotel: Check-in/Rest/Check-out, hotel name
- buffer: description (for airport transfers, luggage, security)

MEAL RULES: No breakfast. Full days: lunch + dinner. Arrival/departure days: adjust based on effective time.
DIVERSITY: No repeating restaurants or attractions across days.
BUDGET: Include a complete budget summary at the end with itemized costs and a grand total.".
