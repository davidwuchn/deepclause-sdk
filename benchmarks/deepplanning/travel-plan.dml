% ===========================================================================
% DeepPlanning Travel Plan Skill (Plan Phase)
% ===========================================================================
%
% Generates a self-contained DML file for the Execute phase.
%
% This is the PLAN phase — it does NOT call travel tools. It analyzes the
% request and produces a task list. The generated DML contains all travel
% tool definitions, a system prompt, and the task steps.
%
% The Execute phase runs the generated DML, which calls the travel tools
% and produces the final itinerary inside <plan></plan> tags.
%
% No params needed (plan phase doesn't call travel tools).
% The generated DML requires: db_path, bridge_dir, bench_dir, python_path
% ===========================================================================

:- use_module(library(http/json)).

agent_main(Request) :-
    format(string(SystemPrompt), "You create structured travel planning execution plans for DeepClause.

Current travel request:
~w

Your job is to break this travel request into 3 to 6 concrete GATHERING tasks.
Each task will be executed sequentially by a travel planning agent that has
access to travel search tools (trains, flights, hotels, attractions, restaurants).

Rules for the task list:
- Each task should be ONE focused gathering step (gather transport, gather hotels, etc.)
- Tasks should be ordered: gather transport first, then hotels/attractions, then restaurants
- Each task must be a plain natural-language description, not code or DML
- Do NOT include a plan generation step — the system adds that automatically
- Do NOT include tool definitions or DML syntax — just task descriptions
- Be specific about what to search for (city names, dates, constraints from the request)

Return only the ordered list of task descriptions.", [Request]),
    system(SystemPrompt),

    task("Create a short file-safe slug for this travel request: '{Request}'.
Requirements:
- lowercase letters, digits, and underscores only
- 2 to 6 words
- no file extension
Store only the slug in PlanSlug.", string(PlanSlug)),

    task("Break this travel request into 3 to 6 information-gathering tasks for a travel planning agent: '{Request}'.

The agent has these tools available:
- query_train_info, query_flight_info: search intercity transport
- query_hotel_info, query_hotel_info_with_star: search hotels
- recommend_attractions, query_attraction_details: search attractions
- search_location, query_road_route_info: get coordinates and routes
- recommend_restaurants, query_restaurant_details: search restaurants (pass attraction/hotel coordinates as STRINGS)
- verify_plan: verify the plan against hard constraints (budget, time, diversity)

Do NOT include a plan generation step — the system adds that automatically.
Each task should be a focused gathering step. Be specific about cities, dates, and constraints.

Return only the ordered list of task descriptions in PlanTasks.", list(string(PlanTasks))),

    derive_system_prompt(Request, PlanTasks, PlanSystemPrompt),

    make_directory_path('plans'),
    format(string(FilePath), "plans/~w.dml", [PlanSlug]),

    assemble_travel_dml(PlanSystemPrompt, PlanTasks, PlanDml),
    exec(write_file(path: FilePath, content: PlanDml), _),
    exec(validate_dml(dml_file: FilePath), ValidationResult),

    finish_plan_creation(FilePath, PlanSlug, PlanTasks, ValidationResult).

derive_system_prompt(Request, PlanTasks, PlanSystemPrompt) :-
    task("Create a concise system prompt for a travel planning agent that will execute this plan: '{Request}'.

Planned steps: {PlanTasks}.

The prompt must include these rules:
- All information must come from tool results — never fabricate names or prices
- Restaurant names must be EXACT from recommend_restaurants/query_restaurant_details results
- Use recommend_restaurants with attraction/hotel coordinates (as strings), not restaurant coordinates
- Current City on intercity days must use 'from CityA to CityB' format (literal 'from' and 'to')
- Budget: all prices are per-unit, multiply by travelers/rooms in summary
- Times must be continuous, no breakfast, full days need lunch+dinner
- Last day should end at the departure station/airport
- Proceed autonomously without asking for user input

Keep the prompt concise and actionable. Store only the system prompt text in SystemPrompt.", string(PlanSystemPrompt)).

assemble_travel_dml(PlanSystemPrompt, PlanTasks, PlanDml) :-
    travel_tool_block(ToolBlock),
    build_gather_lines(PlanTasks, GatherLines),
    format(string(PlanDml),
           "% Generated DeepClause travel plan.\n% This file was assembled deterministically from a task list.\n\n:- use_module(library(http/json)).\n\n~s\n\nagent_main(Request) :-\n    system(~q),\n    user(Request),\n~s    task('Based on all gathered information, generate the complete travel itinerary inside <plan></plan> tags. Include day-by-day schedule with times, Current City, attractions, meals with EXACT restaurant names from tool results, transport details, and a budget summary where per-unit costs are multiplied by number of travelers/rooms.', string(FinalPlan)),\n    answer(FinalPlan).\n\nagent_main(Request) :-\n    system('You are a travel planning assistant. Create a travel plan using the available tools. Output inside <plan></plan> tags with budget summary.'),\n    user(Request),\n    task('Create a complete travel plan using all available tools. Output inside <plan></plan> tags.', string(Plan)),\n    answer(Plan).\n",
           [ToolBlock, PlanSystemPrompt, GatherLines]).

build_gather_lines([], "").
build_gather_lines([Task|Rest], Lines) :-
    format(string(Line), "    task(~q),\n", [Task]),
    build_gather_lines(Rest, RestLines),
    string_concat(Line, RestLines, Lines).

finish_plan_creation(FilePath, PlanSlug, PlanTasks, ValidationResult) :-
    get_dict(valid, ValidationResult, true),
    build_step_review(PlanTasks, 1, Review),
    format(string(Message), "Travel plan created in ~w.\n\nPlanned steps:\n~s\nRun it with /run ~w or /~w.", [FilePath, Review, FilePath, PlanSlug]),
    answer(Message).

finish_plan_creation(FilePath, _, _, _) :-
    format(string(Message), "Plan file ~w created but failed validation.", [FilePath]),
    answer(Message).

build_step_review([], _, "").
build_step_review([Task|Rest], N, Review) :-
    format(string(Line), "~w. ~w\n", [N, Task]),
    NextN is N + 1,
    build_step_review(Rest, NextN, RestReview),
    string_concat(Line, RestReview, Review).

travel_tool_block(ToolBlock) :-
    ToolLines = [
        '% --- Travel Tool Bridge ---',
        '',
        'run_tool(ToolName, ArgsDict, Result) :-',
        '    param(db_path, DbPath),',
        '    param(bridge_dir, BridgeDir),',
        '    param(bench_dir, BenchDir),',
        '    param(python_path, PythonPath),',
        '    (var(PythonPath) -> PythonPath = \'python3\' ; true),',
        '    atom_json_dict(ArgsJson, ArgsDict, []),',
        '    format(string(ArgsFile), ".dc_bridge_~w.json", [ToolName]),',
        '    exec(write_file(path: ArgsFile, content: ArgsJson), _),',
        '    format(string(Cmd), "~w \'~w/python-bridge.py\' --domain travel --db-path \'~w\' --bench-dir \'~w\' --tool ~w --args-file \'~w\'", [PythonPath, BridgeDir, DbPath, BenchDir, ToolName, ArgsFile]),',
        '    exec(bash(command: Cmd), Raw),',
        '    parse_bridge_result(Raw, Result).',
        '',
        'tool(query_train_info(Origin, Dest, Date, Result),',
        '     "Search for train tickets between two cities on a given date. Returns train number, times, stations, duration, seat class, remaining seats, price.") :-',
        '    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).',
        '',
        'tool(query_train_info_with_class(Origin, Dest, Date, SeatClass, Result),',
        '     "Search for train tickets with a specific seat class. Options: First Class Seat, Second Class Seat, Business Seat.") :-',
        '    run_tool(query_train_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).',
        '',
        'tool(query_flight_info(Origin, Dest, Date, Result),',
        '     "Search for flights between two cities on a given date. Returns flight number, times, airports, duration, seat class, remaining seats, price, aircraft type.") :-',
        '    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date}, Result).',
        '',
        'tool(query_flight_info_with_class(Origin, Dest, Date, SeatClass, Result),',
        '     "Search for flights with a specific seat class. Options: Economy Class, Business Class, First Class.") :-',
        '    run_tool(query_flight_info, _{origin: Origin, destination: Dest, depDate: Date, seatClassName: SeatClass}, Result).',
        '',
        'tool(query_hotel_info(Dest, CheckIn, CheckOut, Result),',
        '     "Search for hotels in a city for given dates. Returns hotel name, price, rating, amenities.") :-',
        '    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut}, Result).',
        '',
        'tool(query_hotel_info_with_star(Dest, CheckIn, CheckOut, Star, Result),',
        '     "Search for hotels filtered by star rating (1-5).") :-',
        '    run_tool(query_hotel_info, _{destination: Dest, checkinDate: CheckIn, checkoutDate: CheckOut, hotelStar: Star}, Result).',
        '',
        'tool(recommend_attractions(City, Result),',
        '     "Search popular attractions in a city. All attraction info in the plan MUST come from this tool.") :-',
        '    run_tool(recommend_attractions, _{city: City}, Result).',
        '',
        'tool(query_attraction_details(Name, Result),',
        '     "Get detailed info about an attraction: coordinates, description, rating, hours, closing dates, visit duration, ticket price, type.") :-',
        '    run_tool(query_attraction_details, _{attraction_name: Name}, Result).',
        '',
        'tool(search_location(Place, Result),',
        '     "Get latitude/longitude coordinates for a place name. Names must exactly match tool results.") :-',
        '    run_tool(search_location, _{place_name: Place}, Result).',
        '',
        'tool(query_road_route_info(OriginCoord, DestCoord, Result),',
        '     "Calculate road route between two coordinates (lat,lng format). Returns distance, duration, cost. Walking <=2km (free), driving >2km. Cost per vehicle (4 passengers).") :-',
        '    run_tool(query_road_route_info, _{origin: OriginCoord, destination: DestCoord}, Result).',
        '',
        'tool(recommend_restaurants(Lat, Lng, Result),',
        '     "Find restaurants near a location. Pass the latitude and longitude of a KNOWN LOCATION as separate string arguments. Get coordinates from search_location or attraction/hotel details first.") :-',
        '    run_tool(recommend_restaurants, _{latitude: Lat, longitude: Lng}, Result).',
        '',
        'tool(query_restaurant_details(Name, Result),',
        '     "Get detailed info about a restaurant: coordinates, price/person, hours, rating.") :-',
        '    run_tool(query_restaurant_details, _{restaurant_name: Name}, Result).',
        '',
        'parse_bridge_result(Raw, Result) :-',
        '    get_dict(stdout, Raw, Stdout),',
        '    !,',
        '    Result = Stdout.',
        '',
        'parse_bridge_result(_, "Error: tool call failed").',
        '',
        'coerce_int(Val, Int) :- integer(Val), !, Int = Val.',
        'coerce_int(Val, Int) :- number(Val), !, Int is round(Val).',
        'coerce_int(Val, Int) :- atom(Val), !, atom_number(Val, Int).',
        'coerce_int(Val, Int) :- string(Val), !, number_string(Int, Val).',
        '',
        'tool(verify_plan(PlanJson, BudgetLimitIn, TravelersIn, Result),',
        '     "Verify a travel plan against hard constraints. Pass: PlanJson (JSON string with {total_cost, days}), BudgetLimit (integer), Travelers (integer). Returns PASS or violation descriptions.") :-',
        '    atom_json_dict(PlanJson, PlanData, []),',
        '    coerce_int(BudgetLimitIn, BudgetLimit),',
        '    coerce_int(TravelersIn, Travelers),',
        '    verify_all(PlanData, BudgetLimit, Travelers, Violations),',
        '    (Violations = []',
        '    ->  Result = "PASS: All constraints satisfied"',
        '    ;   format(string(Result), "FAIL: ~w", [Violations])',
        '    ).',
        '',
        'verify_all(PlanData, BudgetLimit, Travelers, Violations) :-',
        '    findall(V, (',
        '        verify_budget(PlanData, BudgetLimit, Travelers, V) ;',
        '        verify_time(PlanData, V) ;',
        '        verify_diversity(PlanData, V) ;',
        '        verify_last_day(PlanData, V)',
        '    ), Violations).',
        '',
        'verify_budget(PlanData, BudgetLimit, Travelers, V) :-',
        '    get_dict(total_cost, PlanData, ReportedRaw),',
        '    coerce_int(ReportedRaw, ReportedTotal),',
        '    TotalCost is ReportedTotal * Travelers,',
        '    TotalCost > BudgetLimit,',
        '    Over is TotalCost - BudgetLimit,',
        '    format(string(V), \'BUDGET: ~w total exceeds ~w limit by ~w\', [TotalCost, BudgetLimit, Over]).',
        '',
        'verify_time(PlanData, V) :-',
        '    get_dict(days, PlanData, Days),',
        '    member(Day, Days),',
        '    get_dict(day_number, Day, DayNum),',
        '    get_dict(activities, Day, Acts),',
        '    adjacent_activities(Acts, A, B),',
        '    get_dict(time_end, A, EndStr),',
        '    get_dict(time_start, B, StartStr),',
        '    time_to_min(EndStr, EndMin),',
        '    time_to_min(StartStr, StartMin),',
        '    (StartMin < EndMin',
        '    ->  get_dict(name, A, NA), get_dict(name, B, NB),',
        '        format(string(V), \'DAY ~w OVERLAP: "~w" ends ~w, "~w" starts ~w\', [DayNum, NA, EndStr, NB, StartStr])',
        '    ;   Gap is StartMin - EndMin, Gap > 60,',
        '        get_dict(name, A, NA), get_dict(name, B, NB),',
        '        format(string(V), \'DAY ~w GAP: ~w min between "~w" and "~w"\', [DayNum, Gap, NA, NB])',
        '    ).',
        'adjacent_activities([A, B|_], A, B).',
        'adjacent_activities([_|Rest], A, B) :- adjacent_activities(Rest, A, B).',
        '',
        'verify_diversity(PlanData, V) :-',
        '    get_dict(days, PlanData, Days),',
        '    findall(Name, (member(Day, Days), get_dict(activities, Day, Acts),',
        '                   member(Act, Acts), get_dict(type, Act, T), member(T, [attraction, meal]),',
        '                   get_dict(name, Act, Name)), AllNames),',
        '    sort(AllNames, Unique), length(AllNames, Total), length(Unique, UC),',
        '    Dups is Total - UC, Dups > 0,',
        '    format(string(V), \'DIVERSITY: ~w repeated name(s)\', [Dups]).',
        '',
        'verify_last_day(PlanData, V) :-',
        '    get_dict(days, PlanData, Days), Days \\= [],',
        '    last(Days, LastDay), get_dict(activities, LastDay, Acts), Acts \\= [],',
        '    last(Acts, LastAct), get_dict(type, LastAct, LastType),',
        '    \\+ member(LastType, [travel_intercity_public, buffer]),',
        '    format(string(V), \'STRUCTURE: last day ends with ~w\', [LastType]).',
        '',
        'time_to_min(TimeStr, Min) :-',
        '    split_string(TimeStr, ":", "", [H, M|_]),',
        '    number_string(Hour, H), number_string(Minute, M),',
        '    Min is Hour * 60 + Minute.'
    ],
    atomics_to_string(ToolLines, "\n", ToolBlock).

agent_main(Request) :-
    format(string(Message), "Could not create a travel plan for: ~w", [Request]),
    answer(Message).
