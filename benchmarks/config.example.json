{
  "dataset": {
    "name": "lite",
    "split": "test",
    "instanceIds": [
      "astropy__astropy-12907"
    ],
    "limit": 1,
    "offset": 0
  },
  "modes": [
    "prompt",
    "plan-execute"
  ],
  "deepclause": {
    "version": "latest",
    "packageTarball": null,
    "models": {
      "gateway": "openai:gpt-4o",
      "run": "openai:gpt-4o",
      "compile": "openai:gpt-4o"
    },
    "temperatures": {
      "gateway": 0.7,
      "run": 0.7,
      "compile": 0.4
    },
    "shell": {
      "wrapper": "clean-room",
      "strictIsolation": false
    },
    "agentvm": {
      "network": false
    }
  },
  "execution": {
    "maxWorkers": 1,
    "agentTimeoutSeconds": 2700,
    "setupTimeoutSeconds": 1800,
    "repoCacheDir": null,
    "repoSetup": {
      "mode": "best-effort",
      "commands": []
    }
  },
  "docker": {
    "platform": "linux/amd64",
    "workerImage": "deepclause-swebench-worker:latest",
    "evaluatorImage": "deepclause-swebench-evaluator:latest",
    "rebuildImages": false,
    "skipImageBuild": false
  },
  "artifacts": {
    "outputRoot": "benchmarks/runs"
  },
  "evaluation": {
    "datasetName": "SWE-bench/SWE-bench_Lite",
    "maxWorkers": 4,
    "cacheLevel": "env",
    "clean": false,
    "namespace": "swebench",
    "swebenchVersion": "latest"
  }
}
