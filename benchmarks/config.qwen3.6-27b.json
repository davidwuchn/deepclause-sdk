{
  "dataset": {
    "name": "lite",
    "split": "test",
    "instanceIds": [
      "astropy__astropy-12907"
    ],
    "limit": 1,
    "offset": 0
  },
  "modes": [
    "plan-execute"
  ],
  "deepclause": {
    "version": "latest",
    "models": {
      "gateway": "custom:aliyun:qwen3.6-27b",
      "run": "custom:aliyun:qwen3.6-27b",
      "compile": "custom:aliyun:qwen3.6-27b"
    },
    "temperatures": {
      "gateway": 1.0,
      "run": 1.0,
      "compile": 1.0
    },
    "shell": {
      "wrapper": "clean-room",
      "strictIsolation": false
    },
    "agentvm": {
      "network": false
    }
  },
  "execution": {
    "maxWorkers": 1,
    "agentTimeoutSeconds": 2700,
    "setupTimeoutSeconds": 1800,
    "repoSetup": {
      "mode": "best-effort",
      "commands": []
    }
  },
  "docker": {
    "platform": "linux/amd64",
    "workerImage": "deepclause-swebench-worker:latest",
    "evaluatorImage": "deepclause-swebench-evaluator:latest",
    "rebuildImages": false,
    "skipImageBuild": false
  },
  "artifacts": {
    "outputRoot": "benchmarks/runs"
  },
  "evaluation": {
    "datasetName": "SWE-bench/SWE-bench_Lite",
    "maxWorkers": 4,
    "cacheLevel": "env",
    "clean": false,
    "namespace": "swebench",
    "swebenchVersion": "latest"
  }
}
